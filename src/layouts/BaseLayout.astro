---
import { ViewTransitions } from 'astro:transitions';
import MobileNav from '../components/MobileNav.astro';
import TopicNav from '../components/TopicNav.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  canonical?: string;
}

const {
  title,
  description,
  ogImage = '/assets/og-image.png',
  ogType = 'website',
  canonical
} = Astro.props;

const siteUrl = 'https://tune-health.vercel.app';
const canonicalUrl = canonical || Astro.url.pathname;
// Ensure OG image is always an absolute URL for social platforms
const resolvedOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="description" content={description}>
  <meta name="robots" content="index, follow">
  <meta name="author" content="alumi news">
  <meta name="theme-color" content="#dc2626" media="(prefers-color-scheme: light)">
  <meta name="theme-color" content="#ef4444" media="(prefers-color-scheme: dark)">
  <title>{title}</title>

  <!-- Open Graph -->
  <meta property="og:type" content={ogType}>
  <meta property="og:url" content={`${siteUrl}${canonicalUrl}`}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={resolvedOgImage}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="675">
  <meta property="og:site_name" content="alumi news">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@aluminews">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={resolvedOgImage}>

  <!-- Preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <!-- Typography — preload critical fonts, defer rest -->
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" as="style" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Inter:wght@400;500;600;700&family=Crimson+Pro:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">
  <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png">
  <link rel="manifest" href="/manifest.json">
  <link rel="canonical" href={`${siteUrl}${canonicalUrl}`}>

  <!-- RSS Autodiscovery -->
  <link rel="alternate" type="application/rss+xml" title="alumi news RSS Feed" href={`${siteUrl}/rss.xml`}>

  <!-- View Transitions -->
  <ViewTransitions />

  <!-- Additional head content (for SEO, etc.) -->
  <slot name="head" />
</head>
<body class="overflow-x-hidden">
  <!-- Skip Link -->
  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-primary-600 focus:text-white focus:rounded-lg focus:outline-none">
    Skip to main content
  </a>

  <!-- Noise Overlay -->
  <div class="noise-overlay" aria-hidden="true"></div>

  <!-- Scroll Progress -->
  <div class="scroll-progress" id="scrollProgress" role="progressbar" aria-label="Reading progress" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0"></div>

  <slot name="header" />
  <TopicNav />

  <main id="main-content">
    <slot />
  </main>

  <slot name="footer" />

  <!-- Mobile Bottom Navigation -->
  <MobileNav />

  <!-- Back to Top -->
  <button class="back-to-top" id="backToTop" aria-label="Back to top">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M18 15l-6-6-6 6" stroke-width="2"/>
    </svg>
  </button>

  <!-- Command Palette Container -->
  <div id="command-palette-root"></div>

  <script>
    // Theme management — supports 'system' (default), 'light', and 'dark'
    const html = document.documentElement;
    const systemQuery = window.matchMedia('(prefers-color-scheme: dark)');

    // Resolve effective theme from stored preference
    const getStoredPreference = (): 'system' | 'light' | 'dark' => {
      const stored = localStorage.getItem('theme');
      if (stored === 'light' || stored === 'dark') return stored;
      return 'system';
    };

    const resolveTheme = (pref: 'system' | 'light' | 'dark'): 'light' | 'dark' => {
      if (pref === 'system') return systemQuery.matches ? 'dark' : 'light';
      return pref;
    };

    const applyTheme = (pref: 'system' | 'light' | 'dark') => {
      const effective = resolveTheme(pref);
      html.classList.toggle('dark', effective === 'dark');
      // Store preference (including 'system')
      if (pref === 'system') {
        localStorage.removeItem('theme');
      } else {
        localStorage.setItem('theme', pref);
      }
      // Update toggle button icons across all instances
      document.querySelectorAll('[data-theme-icon]').forEach(el => {
        const mode = el.getAttribute('data-theme-icon');
        (el as HTMLElement).style.display = mode === pref ? '' : 'none';
      });
    };

    // Apply immediately
    applyTheme(getStoredPreference());

    // Listen for system preference changes (only matters when set to 'system')
    systemQuery.addEventListener('change', () => {
      if (getStoredPreference() === 'system') applyTheme('system');
    });

    // Cycle: system → light → dark → system
    (window as unknown as { toggleTheme: () => void }).toggleTheme = () => {
      const current = getStoredPreference();
      const next = current === 'system' ? 'light' : current === 'light' ? 'dark' : 'system';
      applyTheme(next);
    };

    // Persist theme across View Transitions — apply BEFORE swap to prevent light flash
    document.addEventListener('astro:before-swap', (e: any) => {
      const pref = getStoredPreference();
      const effective = resolveTheme(pref);
      e.newDocument.documentElement.classList.toggle('dark', effective === 'dark');
    });
    document.addEventListener('astro:after-swap', () => {
      applyTheme(getStoredPreference());
    });
  </script>

  <script>
    let coreController: AbortController | null = null;

    // Core interactions - runs on every page
    function initInteractions() {
      if (coreController) coreController.abort();
      coreController = new AbortController();
      const signal = coreController.signal;

      const header = document.getElementById('header');
      const topicNav = document.getElementById('topicNav');
      const scrollProgress = document.getElementById('scrollProgress');
      const backToTop = document.getElementById('backToTop');
      const themeToggle = document.getElementById('themeToggle');
      const menuToggle = document.getElementById('menuToggle');
      const mobileMenu = document.getElementById('mobileMenu');

      // Sticky header hide/show on scroll (like Medium/Substack)
      let lastScrollY = window.scrollY;
      const HEADER_DEAD_ZONE = 8;
      const isArticlePage = !!document.getElementById('article-content');

      // Header scroll effect
      let ticking = false;
      const updateScroll = () => {
        const scrollY = window.scrollY;

        // Scrolled state (glass border + backdrop)
        if (scrollY > 50) {
          header?.classList.add('scrolled');
        } else {
          header?.classList.remove('scrolled');
        }

        // Reveal topic nav on homepage after scrolling past hero
        if (topicNav?.classList.contains('topic-nav-hidden')) {
          const hero = document.querySelector('.hero') as HTMLElement;
          const threshold = hero ? hero.offsetHeight * 0.6 : 400;
          if (scrollY > threshold) {
            topicNav.classList.remove('topic-nav-hidden');
          }
        }

        // Sticky hide/show — only on article pages, desktop only
        if (isArticlePage && header && window.innerWidth >= 1024) {
          const delta = scrollY - lastScrollY;
          if (Math.abs(delta) > HEADER_DEAD_ZONE) {
            if (delta > 0 && scrollY > 300) {
              header.classList.add('header-hidden');
              topicNav?.classList.add('header-hidden');
            } else {
              header.classList.remove('header-hidden');
              topicNav?.classList.remove('header-hidden');
            }
            lastScrollY = scrollY;
          }
        } else {
          header?.classList.remove('header-hidden');
          topicNav?.classList.remove('header-hidden');
        }

        // Progress bar
        if (scrollProgress) {
          const vh = window.visualViewport?.height ?? window.innerHeight;
          const docHeight = document.documentElement.scrollHeight - vh;
          const progress = docHeight > 0 ? Math.min(scrollY / docHeight, 1) : 0;
          scrollProgress.style.transform = `scaleX(${progress})`;
          scrollProgress.setAttribute('aria-valuenow', String(Math.round(progress * 100)));
        }

        // Back to top
        if (backToTop) {
          if (scrollY > 400) {
            backToTop.classList.add('visible');
          } else {
            backToTop.classList.remove('visible');
          }
        }

        ticking = false;
      };

      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(updateScroll);
          ticking = true;
        }
      }, { passive: true, signal });

      // Theme toggle
      themeToggle?.addEventListener('click', () => {
        (window as unknown as { toggleTheme?: () => void }).toggleTheme?.();
      }, { signal });

      // Mobile menu
      menuToggle?.addEventListener('click', () => {
        menuToggle.classList.toggle('active');
        mobileMenu?.classList.toggle('active');
        document.body.classList.toggle('menu-open');
      }, { signal });

      // Back to top
      backToTop?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }, { signal });

      // Escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          mobileMenu?.classList.remove('active');
          menuToggle?.classList.remove('active');
          document.body.classList.remove('menu-open');
        }
      }, { signal });

      // Reveal animations
      const reveals = document.querySelectorAll('.reveal:not(.active)');
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('active');
            revealObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });

      reveals.forEach((el) => {
        const rect = el.getBoundingClientRect();
        if (rect.top < window.innerHeight + 100) {
          // In or near viewport — show instantly (no stutter after page swap)
          (el as HTMLElement).style.transition = 'none';
          el.classList.add('active');
          // Re-enable transitions after paint for any future interactions
          requestAnimationFrame(() => {
            (el as HTMLElement).style.transition = '';
          });
        } else {
          // Below fold — animate on scroll
          revealObserver.observe(el);
        }
      });

      // Run scroll handler immediately to sync header state
      // (prevents stale .scrolled / .header-hidden classes after View Transition)
      updateScroll();
    }

    // Run on initial load
    initInteractions();

    // Run after View Transitions
    document.addEventListener('astro:after-swap', initInteractions);
  </script>
</body>
</html>
