---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingTOC from '../components/FloatingTOC.astro';
import CommandPaletteWrapper from '../components/CommandPaletteWrapper.astro';
import SEO from '../components/SEO.astro';
import Newsletter from '../components/Newsletter.astro';
import ArticleCTA from '../components/ArticleCTA.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ShareButtons from '../components/ShareButtons.astro';
import SeriesNav from '../components/SeriesNav.astro';
import BookmarkButton from '../components/BookmarkButton.astro';
import FloatingShareBar from '../components/FloatingShareBar.astro';
import HighlightShare from '../components/HighlightShare.astro';
import SideNav from '../components/SideNav.astro';
import { fade, slide } from 'astro:transitions';
import { getRelatedArticles, getArticleGradientStyle, getArticles } from '../utils/articles';

interface Props {
  title: string;
  description: string;
  category: string;
  readTime: string;
  publishDate: string;
  ogImage?: string;
  tags?: string[];
  slug?: string;
}

const {
  title,
  description,
  category,
  readTime,
  publishDate,
  ogImage,
  tags = [],
  slug = Astro.url.pathname.replace(/\/$/, '').split('/').pop() || 'article',
} = Astro.props;

const relatedArticles = await getRelatedArticles(slug, 3);

// Resolve per-article OG image from heroImage if no explicit ogImage
const allArticles = await getArticles();
const currentArticle = allArticles.find((a) => a.slug === slug);
const resolvedOgImage = ogImage || currentArticle?.heroImage || '/assets/og-image.png';
const articleSeries = currentArticle?.series;
---

<BaseLayout
  title={`${title} | alumi news`}
  description={description}
  ogType="article"
  ogImage={resolvedOgImage}
>
  <!-- Structured Data -->
  <SEO
    slot="head"
    type="article"
    article={{
      title,
      description,
      publishDate,
      author: 'alumi news Editorial',
      category,
      tags,
      heroImage: resolvedOgImage,
      heroImageAlt: currentArticle?.heroImageAlt,
    }}
  />

  <Header slot="header" variant="article" />

  <!-- Article Hero -->
  <section
    class="article-hero bg-stone-50 dark:bg-stone-950"
    transition:animate={fade({ duration: '0.3s' })}
  >
    <div class="container-editorial">
      <Breadcrumbs
        items={[
          { label: 'Home', href: '/' },
          { label: 'Articles', href: '/articles' },
          { label: category, href: `/articles?topic=${category.toLowerCase().replace(/\s+/g, '-')}` },
        ]}
        class="mb-8 justify-center"
      />
      <div class="article-header">
        <div class="flex items-center justify-center gap-2 mb-8">
          <span
            class="px-3 py-1 bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400 text-xs font-semibold uppercase tracking-widest rounded-full"
            transition:name={`category-${slug}`}
          >
            {category}
          </span>
          <span class="text-stone-300 dark:text-stone-700">/</span>
          <span class="text-xs text-stone-500 uppercase tracking-wide">{publishDate}</span>
          <span class="text-stone-300 dark:text-stone-700">/</span>
          <span class="text-xs text-stone-500 uppercase tracking-wide">{readTime}</span>
        </div>

        <h1
          class="font-serif text-display-2 font-semibold mb-6 text-balance leading-tight"
          transition:name={`title-${slug}`}
          transition:animate={slide({ duration: '0.4s' })}
        >
          {title}
        </h1>

        <p
          class="font-body text-body-lg text-stone-600 dark:text-stone-400 max-w-2xl mx-auto mb-10"
          style="line-height: 1.8;"
          transition:animate={fade({ duration: '0.4s', delay: '0.1s' })}
        >
          {description}
        </p>

        <div class="flex items-center justify-center gap-3">
          <div class="w-10 h-10 rounded-full bg-primary-600 flex items-center justify-center text-white text-sm font-semibold">
            an
          </div>
          <div class="text-left">
            <span class="block text-sm font-semibold">alumi news Editorial</span>
            <span class="block text-xs text-stone-500">Medical Review Board</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature Image Slot -->
  <div class="container-editorial">
    <div
      class="article-feature-image reveal"
      transition:name={`image-${slug}`}
      transition:animate={slide({ duration: '0.5s', delay: '0.1s' })}
    >
      <slot name="feature-image" />
    </div>
  </div>

  <!-- Article Content -->
  <article
    class="article-body"
    id="article-content"
    transition:animate={fade({ duration: '0.4s', delay: '0.2s' })}
  >
    <div class="container-editorial">
      <div class="max-w-article mx-auto">
        <slot />

        <!-- Share & Tags -->
        <div class="mt-14 pt-8 border-t border-stone-200 dark:border-stone-800 reveal">
          <div class="flex flex-wrap items-center justify-between gap-4 mb-4">
            <ShareButtons title={title} url={`/articles/${slug}`} description={description} />
            <BookmarkButton slug={slug} title={title} />
          </div>
          <div class="flex flex-wrap gap-2">
            <slot name="tags" />
          </div>
        </div>

        <!-- Author Card -->
        <div class="author-card mt-10 reveal">
          <div class="author-avatar">an</div>
          <div class="flex-1">
            <span class="block font-semibold mb-1">alumi news Editorial</span>
            <p class="text-sm text-stone-600 dark:text-stone-400 leading-relaxed">
              Our editorial team reviews the latest research across health and medicine,
              synthesizing evidence into accessible, actionable insights.
            </p>
          </div>
        </div>

        <!-- App CTA — contextual per category -->
        <ArticleCTA category={category} slug={slug} />

        <!-- Series Navigation (if article belongs to a series) -->
        {articleSeries && (
          <SeriesNav series={articleSeries} currentSlug={slug} />
        )}
      </div>
    </div>
  </article>

  <!-- Related Articles -->
  {relatedArticles.length > 0 && (
    <section class="related-articles" transition:animate={fade({ duration: '0.3s', delay: '0.3s' })}>
      <div class="container-editorial">
        <div class="flex items-center gap-6 mb-10">
          <span class="section-label">Continue Reading</span>
          <div class="flex-1 h-px bg-stone-200 dark:bg-stone-800"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {relatedArticles.map((article, i) => (
            <a href={article.href} class={`article-card group reveal${i > 0 ? ` reveal-delay-${i}` : ''}`}>
              <div class="article-card-image">
                <div class="article-card-image-inner relative overflow-hidden" style={article.heroImage ? undefined : getArticleGradientStyle(article.category)}>
                  {article.heroImage && (
                    <img src={article.heroImage} alt={article.heroImageAlt || article.title} class="w-full h-full object-cover" loading="lazy" />
                  )}
                  <span class="article-card-number absolute bottom-4 left-4">{String(i + 1).padStart(2, '0')}</span>
                </div>
              </div>
              <div class="article-card-content">
                <div class="flex items-center gap-2 mb-3">
                  <span class="text-xs font-semibold uppercase tracking-widest text-primary-600">{article.category}</span>
                  <span class="text-stone-300 dark:text-stone-700">/</span>
                  <span class="text-xs text-stone-400">{article.readTime} min</span>
                </div>
                <h3 class="font-serif text-lg font-semibold mb-2 group-hover:text-primary-600 transition-colors leading-snug">{article.title}</h3>
                <p class="font-body text-sm text-stone-500 dark:text-stone-400 line-clamp-2">{article.description}</p>
              </div>
            </a>
          ))}
        </div>

        <!-- Browse category CTA -->
        <div class="mt-8 text-center reveal">
          <a
            href={`/articles?topic=${category.toLowerCase().replace(/\s+/g, '-')}`}
            class="inline-flex items-center gap-2 text-sm font-medium text-stone-500 dark:text-stone-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
          >
            <span>More in {category}</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path d="M5 12h14M12 5l7 7-7 7" stroke-width="2"/>
            </svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Newsletter CTA -->
  <Newsletter variant="compact" />

  <Footer slot="footer" />
  <FloatingTOC />
  <FloatingShareBar title={title} url={`/articles/${slug}`} description={description} />
  <HighlightShare articleUrl={`/articles/${slug}`} />
  <CommandPaletteWrapper />
  <SideNav />
</BaseLayout>

<style is:global>
  /* Custom View Transition animations for articles */
  @keyframes article-fade-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes article-fade-out {
    from {
      opacity: 1;
      transform: translateY(0);
    }
    to {
      opacity: 0;
      transform: translateY(-10px);
    }
  }

  /* Article title transition */
  ::view-transition-old(article-title) {
    animation: article-fade-out 0.3s ease-out forwards;
  }

  ::view-transition-new(article-title) {
    animation: article-fade-in 0.4s ease-out forwards;
  }

  /* Smooth hero image transitions */
  ::view-transition-old(article-image),
  ::view-transition-new(article-image) {
    animation-duration: 0.4s;
    animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* Respect reduced motion preference */
  @media (prefers-reduced-motion: reduce) {
    ::view-transition-old(article-title),
    ::view-transition-new(article-title),
    ::view-transition-old(article-image),
    ::view-transition-new(article-image) {
      animation: none;
    }
  }
</style>
