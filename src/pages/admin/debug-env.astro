---
export const prerender = false;

const envKeys = Object.keys(import.meta.env).filter(k => k.includes('ADMIN') || k.includes('PUBLIC'));
const processKeys = Object.keys(process.env).filter(k => k.includes('ADMIN') || k.includes('PUBLIC'));
---
<html><body>
<pre>
import.meta.env keys: {JSON.stringify(envKeys)}
process.env keys: {JSON.stringify(processKeys)}
PUBLIC_ADMIN_TOKEN exists: {String(!!import.meta.env.PUBLIC_ADMIN_TOKEN)}
PUBLIC_ADMIN_TOKEN length: {String(import.meta.env.PUBLIC_ADMIN_TOKEN?.length || 0)}
</pre>
</body></html>
