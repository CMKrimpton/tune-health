---
export const prerender = false;
import ArticleEditor from '../../components/admin/ArticleEditor';

const edgeFunctionBase = (process.env.PUBLIC_SUPABASE_URL || import.meta.env.PUBLIC_SUPABASE_URL || '').trim();
const apiBase = edgeFunctionBase ? `${edgeFunctionBase}/functions/v1` : '';
const adminTokenValue = Astro.cookies.get('admin_token')?.value || '';
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>New Article | alumi admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Crimson+Pro:wght@400;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/admin.css" />
  <meta name="admin-token" content={adminTokenValue} />
</head>
<body class="admin-body">
  <header class="admin-header">
    <div class="admin-header-inner">
      <div class="admin-logo">
        <span class="admin-logo-accent">a</span>lumi
        <span class="admin-logo-badge">mission control</span>
      </div>
      <nav class="admin-nav">
        <a href="/admin" class="admin-nav-link">Dashboard</a>
        <a href="/admin/new" class="admin-nav-link active">New Article</a>
        <a href="/admin/social-preview" class="admin-nav-link">Social Preview</a>
        <a href="/admin/typography" class="admin-nav-link">Typography</a>
        <a href="/" class="admin-nav-link" target="_blank">View Site &rarr;</a>
      </nav>
    </div>
  </header>

  <ArticleEditor client:load apiBase={apiBase} />
</body>
</html>
