---
export const prerender = false;

// If already authenticated, redirect to dashboard
const cookie = Astro.cookies.get('admin_token');
const adminToken = (process.env.ADMIN_TOKEN || import.meta.env.ADMIN_TOKEN || process.env.PUBLIC_ADMIN_TOKEN || import.meta.env.PUBLIC_ADMIN_TOKEN || '').trim();
if (cookie && cookie.value === adminToken) {
  return Astro.redirect('/admin');
}

// Check if redirected here after a failed auth attempt
const hasError = Astro.url.searchParams.get('error') === '1';

// If they arrived with an error, clear the bad cookie so they can try again
if (hasError && cookie) {
  Astro.cookies.delete('admin_token', { path: '/' });
}
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Login | alumi news</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', sans-serif;
      background: #1b1a18;
      color: #e7e6e3;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .login-card {
      width: 100%;
      max-width: 400px;
      padding: 2.5rem;
      background: #292524;
      border: 1px solid #44403c;
      border-radius: 1rem;
    }
    .logo { font-size: 1.25rem; font-weight: 600; margin-bottom: 0.5rem; }
    .logo span { color: #dc2626; font-weight: 700; }
    .subtitle { font-size: 0.875rem; color: #a8a29e; margin-bottom: 2rem; }
    label {
      display: block; font-size: 0.75rem; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.05em;
      color: #a8a29e; margin-bottom: 0.5rem;
    }
    input[type="password"] {
      width: 100%; padding: 0.75rem 1rem;
      background: #1c1917; border: 1px solid #44403c;
      border-radius: 0.5rem; color: #e7e6e3;
      font-size: 1rem; font-family: inherit; outline: none;
    }
    input:focus { border-color: #dc2626; box-shadow: 0 0 0 3px rgba(220,38,38,0.15); }
    button {
      width: 100%; margin-top: 1.5rem; padding: 0.75rem;
      background: #dc2626; color: white; border: none;
      border-radius: 0.5rem; font-size: 0.875rem;
      font-weight: 600; font-family: inherit; cursor: pointer;
    }
    button:hover { background: #b91c1c; }
    .error {
      margin-top: 1rem; padding: 0.5rem 0.75rem;
      background: #7f1d1d; border: 1px solid #991b1b;
      border-radius: 0.375rem; font-size: 0.8125rem; color: #fecaca;
      display: none;
    }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="logo"><span>a</span>lumi admin</div>
    <p class="subtitle">Publishing portal</p>
    <form id="loginForm">
      <label for="token">Admin Token</label>
      <input type="password" id="token" name="token" placeholder="Enter your admin token" required autofocus />
      <button type="submit">Sign In</button>
    </form>
    <div id="error" class="error" style={hasError ? 'display: block' : 'display: none'}>
      {hasError ? 'Invalid admin token. Please try again.' : ''}
    </div>
  </div>

  <script>
    // Clear error param from URL without reload (so refresh doesn't re-show error)
    if (window.location.search.includes('error=1')) {
      history.replaceState(null, '', '/admin/login');
    }

    document.getElementById('loginForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const token = document.getElementById('token').value.trim();
      if (!token) return;

      const errorEl = document.getElementById('error');
      const btn = e.target.querySelector('button');
      errorEl.style.display = 'none';
      btn.textContent = 'Verifying...';
      btn.disabled = true;

      // Set cookie client-side, then verify against /admin
      document.cookie = `admin_token=${encodeURIComponent(token)}; path=/; max-age=${60*60*24*7}; samesite=lax${location.protocol === 'https:' ? '; secure' : ''}`;

      try {
        const res = await fetch('/admin', { redirect: 'manual' });
        // If middleware rejects: opaque redirect (type 'opaqueredirect') or non-200
        if (res.type === 'opaqueredirect' || res.status === 302 || res.status === 301) {
          // Token was wrong — clear the bad cookie
          document.cookie = 'admin_token=; path=/; max-age=0';
          errorEl.textContent = 'Invalid admin token. Please try again.';
          errorEl.style.display = 'block';
          btn.textContent = 'Sign In';
          btn.disabled = false;
          document.getElementById('token').value = '';
          document.getElementById('token').focus();
          return;
        }
        // Success — navigate
        window.location.href = '/admin';
      } catch {
        // Network error or other failure — just navigate and let server handle it
        window.location.href = '/admin';
      }
    });
  </script>
</body>
</html>
