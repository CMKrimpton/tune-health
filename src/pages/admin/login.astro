---
export const prerender = false;

// If already authenticated, redirect to dashboard
const cookie = Astro.cookies.get('admin_token');
const adminToken = (process.env.ADMIN_TOKEN || import.meta.env.ADMIN_TOKEN || process.env.PUBLIC_ADMIN_TOKEN || import.meta.env.PUBLIC_ADMIN_TOKEN || '').trim();
if (cookie && cookie.value === adminToken) {
  return Astro.redirect('/admin');
}

// Check if redirected here after a failed auth attempt
const hasError = Astro.url.searchParams.get('error') === '1';

// If they arrived with an error, clear the bad cookie so they can try again
if (hasError && cookie) {
  Astro.cookies.delete('admin_token', { path: '/' });
}
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Login | alumi news</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Inter', -apple-system, sans-serif;
      background: #0f0e0c;
      color: #eae8e4;
      min-height: 100dvh;
      display: flex;
      align-items: center;
      justify-content: center;
      -webkit-font-smoothing: antialiased;
      overflow: hidden;
    }

    /* Animated gradient background */
    .bg-glow {
      position: fixed;
      inset: 0;
      overflow: hidden;
      pointer-events: none;
    }

    .bg-glow::before {
      content: '';
      position: absolute;
      width: 600px;
      height: 600px;
      top: 30%;
      left: 50%;
      transform: translate(-50%, -50%);
      background: radial-gradient(circle, rgba(239, 68, 68, 0.12) 0%, rgba(239, 68, 68, 0.03) 40%, transparent 70%);
      animation: glow-drift 8s ease-in-out infinite;
    }

    .bg-glow::after {
      content: '';
      position: absolute;
      width: 400px;
      height: 400px;
      bottom: 20%;
      right: 20%;
      background: radial-gradient(circle, rgba(167, 139, 250, 0.06) 0%, transparent 60%);
      animation: glow-drift 12s ease-in-out infinite reverse;
    }

    @keyframes glow-drift {
      0%, 100% { transform: translate(-50%, -50%) scale(1); }
      50% { transform: translate(-45%, -55%) scale(1.1); }
    }

    /* Grid pattern */
    .bg-grid {
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
      background-size: 60px 60px;
      pointer-events: none;
      mask-image: radial-gradient(ellipse 60% 50% at 50% 50%, black, transparent);
    }

    .login-wrapper {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 400px;
      padding: 0 1.5rem;
    }

    .login-card {
      padding: 2.5rem;
      background: rgba(26, 25, 23, 0.7);
      backdrop-filter: blur(24px) saturate(1.3);
      -webkit-backdrop-filter: blur(24px) saturate(1.3);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
      box-shadow:
        0 8px 32px rgba(0, 0, 0, 0.4),
        0 1px 0 rgba(255, 255, 255, 0.04) inset;
      animation: card-enter 0.5s cubic-bezier(0.22, 1, 0.36, 1);
    }

    @keyframes card-enter {
      from { opacity: 0; transform: translateY(16px) scale(0.98); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }

    .logo {
      font-size: 1.375rem;
      font-weight: 600;
      margin-bottom: 0.25rem;
      letter-spacing: -0.01em;
    }

    .logo span {
      color: #ef4444;
      font-weight: 700;
    }

    .subtitle {
      font-size: 0.8125rem;
      color: #7d7871;
      margin-bottom: 2rem;
    }

    .badge {
      display: inline-block;
      font-size: 0.5625rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      padding: 0.1875rem 0.5rem;
      background: rgba(239, 68, 68, 0.12);
      border: 1px solid rgba(239, 68, 68, 0.2);
      border-radius: 999px;
      color: #f87171;
      font-weight: 600;
      margin-left: 0.5rem;
      vertical-align: middle;
    }

    label {
      display: block;
      font-size: 0.6875rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #7d7871;
      margin-bottom: 0.5rem;
    }

    input[type="password"] {
      width: 100%;
      padding: 0.75rem 1rem;
      background: rgba(15, 14, 12, 0.8);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 10px;
      color: #eae8e4;
      font-size: 1rem;
      font-family: inherit;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    input:focus {
      border-color: #ef4444;
      box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.15), 0 0 20px rgba(239, 68, 68, 0.08);
    }

    input::placeholder { color: #5c5752; }

    button[type="submit"] {
      width: 100%;
      margin-top: 1.5rem;
      padding: 0.75rem;
      background: #ef4444;
      color: white;
      border: none;
      border-radius: 10px;
      font-size: 0.875rem;
      font-weight: 600;
      font-family: inherit;
      cursor: pointer;
      transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
      box-shadow: 0 1px 4px rgba(239, 68, 68, 0.3);
    }

    button[type="submit"]:hover {
      background: #dc2626;
      box-shadow: 0 4px 20px rgba(239, 68, 68, 0.35);
      transform: translateY(-1px);
    }

    button[type="submit"]:active {
      transform: translateY(0);
      box-shadow: 0 1px 4px rgba(239, 68, 68, 0.3);
    }

    button[type="submit"]:disabled {
      opacity: 0.6;
      cursor: not-allowed;
      transform: none;
    }

    .error {
      margin-top: 1rem;
      padding: 0.625rem 0.875rem;
      background: rgba(239, 68, 68, 0.1);
      border: 1px solid rgba(239, 68, 68, 0.2);
      border-radius: 8px;
      font-size: 0.8125rem;
      color: #fca5a5;
      display: none;
      animation: error-in 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    }

    @keyframes error-in {
      from { opacity: 0; transform: translateY(-4px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .footer-text {
      text-align: center;
      margin-top: 1.5rem;
      font-size: 0.6875rem;
      color: #5c5752;
      letter-spacing: 0.02em;
    }
  </style>
</head>
<body>
  <div class="bg-glow"></div>
  <div class="bg-grid"></div>

  <div class="login-wrapper">
    <div class="login-card">
      <div class="logo"><span>a</span>lumi <span class="badge">mission control</span></div>
      <p class="subtitle">Editorial publishing portal</p>
      <form id="loginForm">
        <label for="token">Admin Token</label>
        <input type="password" id="token" name="token" placeholder="Enter your admin token" required autofocus />
        <button type="submit">Sign In</button>
      </form>
      <div id="error" class="error" style={hasError ? 'display: block' : 'display: none'}>
        {hasError ? 'Invalid admin token. Please try again.' : ''}
      </div>
    </div>
    <p class="footer-text">alumi news &middot; Evidence. Wherever it leads.</p>
  </div>

  <script>
    // Clear error param from URL without reload
    if (window.location.search.includes('error=1')) {
      history.replaceState(null, '', '/admin/login');
    }

    document.getElementById('loginForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const token = document.getElementById('token').value.trim();
      if (!token) return;

      const errorEl = document.getElementById('error');
      const btn = e.target.querySelector('button');
      errorEl.style.display = 'none';
      btn.textContent = 'Verifying\u2026';
      btn.disabled = true;

      // Set cookie client-side, then verify against /admin
      document.cookie = `admin_token=${encodeURIComponent(token)}; path=/; max-age=${60*60*24*7}; samesite=lax${location.protocol === 'https:' ? '; secure' : ''}`;

      try {
        const res = await fetch('/admin', { redirect: 'manual' });
        // If middleware rejects: opaque redirect (type 'opaqueredirect') or non-200
        if (res.type === 'opaqueredirect' || res.status === 302 || res.status === 301) {
          // Token was wrong — clear the bad cookie
          document.cookie = 'admin_token=; path=/; max-age=0';
          errorEl.textContent = 'Invalid admin token. Please try again.';
          errorEl.style.display = 'block';
          btn.textContent = 'Sign In';
          btn.disabled = false;
          document.getElementById('token').value = '';
          document.getElementById('token').focus();
          return;
        }
        // Success — navigate
        window.location.href = '/admin';
      } catch {
        // Network error or other failure — just navigate and let server handle it
        window.location.href = '/admin';
      }
    });
  </script>
</body>
</html>
