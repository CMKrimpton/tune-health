---
export const prerender = false;
// admin.css loaded via <link> in <head> (SSR pages can't use frontmatter CSS imports)

const { slug } = Astro.params;
const edgeFunctionBase = (process.env.PUBLIC_SUPABASE_URL || import.meta.env.PUBLIC_SUPABASE_URL || '').trim();
const apiBase = edgeFunctionBase ? `${edgeFunctionBase}/functions/v1` : '';

// Fetch article from database
interface EditArticle {
  slug: string; title: string; description: string; category: string;
  tags: string[]; keywords: string[]; featured: boolean; draft: boolean;
  coming_soon: boolean; read_time: number; publish_date: string;
  gradient_from: string; gradient_to: string;
  hero_image: string | null; hero_image_alt: string | null; hero_image_light: string | null;
  article_html: string; toc: unknown[];
  source_text: string | null; status: string; sort_order: number | null;
  independence_score: number | null; editor_score: number | null;
  narration_url: string | null; error?: string;
  created_at: string; updated_at: string; published_at: string | null;
}
let article: EditArticle | null = null;
try {
  const res = await fetch(`${apiBase}/articles-api`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ action: 'get', slug }),
  });
  if (res.ok) article = await res.json();
} catch (err) {
  console.error(`[admin/edit] Failed to fetch article "${slug}":`, err);
}

if (!article || article.error) {
  return Astro.redirect('/admin');
}

const liveUrl = `/articles/${slug}`;
const independenceScore = article.independence_score ?? null;
const editorScore = article.editor_score ?? null;

// Category options for select
const categories = ['Mental Health', 'Neuroscience', 'Nutrition', 'Longevity', 'Fitness', 'Sleep Science', 'Clinical Evidence', 'Research Summary', 'Environmental Health', 'Pharmacology'];

// Gradient presets per category
const gradientPresets: Record<string, { from: string; to: string }> = {
  'Mental Health': { from: 'rose-600', to: 'pink-700' },
  'Neuroscience': { from: 'violet-600', to: 'purple-700' },
  'Nutrition': { from: 'emerald-600', to: 'green-700' },
  'Longevity': { from: 'amber-600', to: 'orange-700' },
  'Fitness': { from: 'blue-600', to: 'indigo-700' },
  'Sleep Science': { from: 'indigo-600', to: 'blue-700' },
  'Clinical Evidence': { from: 'teal-600', to: 'cyan-700' },
  'Research Summary': { from: 'slate-600', to: 'gray-700' },
  'Environmental Health': { from: 'lime-600', to: 'emerald-700' },
  'Pharmacology': { from: 'fuchsia-600', to: 'purple-700' },
};
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Edit: {article.title} | alumi admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/admin.css" />
  <style>
    /* ─── Edit page overrides ─── */
    .autosave-indicator {
      display: inline-flex; align-items: center; gap: 0.375rem;
      font-size: 0.6875rem; color: var(--admin-text-4); font-family: 'Inter', sans-serif;
      transition: opacity 0.3s;
    }
    .autosave-indicator.saving { color: var(--admin-yellow); }
    .autosave-indicator.saved { color: var(--admin-green-light); }
    .autosave-indicator.error { color: var(--admin-red-pale); }

    .score-badges { display: flex; gap: 0.5rem; margin-top: 0.5rem; }
    .score-badge {
      display: inline-flex; align-items: center; gap: 0.25rem;
      padding: 0.25rem 0.625rem; border-radius: 1rem;
      font-size: 0.6875rem; font-family: 'Inter', sans-serif; font-weight: 600;
      background: var(--admin-surface-2); border: 1px solid var(--admin-border-2); color: var(--admin-text-3);
    }
    .score-badge-value { color: var(--admin-text); font-variant-numeric: tabular-nums; }
    .score-badge-high .score-badge-value { color: var(--admin-green-light); }
    .score-badge-mid .score-badge-value { color: var(--admin-yellow-light); }
    .score-badge-low .score-badge-value { color: var(--admin-red-pale); }

    .status-pill {
      display: inline-flex; align-items: center; gap: 0.375rem;
      padding: 0.25rem 0.75rem; border-radius: 1rem;
      font-size: 0.6875rem; font-family: 'Inter', sans-serif; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.04em;
    }
    .status-published { background: var(--admin-green-dim); color: var(--admin-green-light); }
    .status-draft { background: var(--admin-yellow-dim); color: var(--admin-yellow-light); }
    .status-archived { background: rgba(120,113,108,0.15); color: var(--admin-text-3); }

    .admin-danger-btn {
      display: inline-flex; align-items: center; gap: 0.375rem;
      padding: 0.625rem 1.25rem; background: transparent; border: 1px solid #991b1b;
      border-radius: var(--admin-radius); color: var(--admin-red-pale); font-size: 0.8125rem;
      font-family: 'Inter', sans-serif; cursor: pointer; transition: all 0.15s; font-weight: 500;
    }
    .admin-danger-btn:hover { background: #7f1d1d; border-color: #dc2626; color: #fecaca; }
    .admin-danger-btn:disabled { opacity: 0.4; cursor: not-allowed; }

    .admin-back-link {
      display: inline-flex; align-items: center; gap: 0.375rem;
      padding: 0.625rem 1.25rem; background: transparent; border: 1px solid var(--admin-border-2);
      border-radius: var(--admin-radius); color: var(--admin-text-3); font-size: 0.8125rem;
      font-family: 'Inter', sans-serif; cursor: pointer; transition: all 0.15s;
      text-decoration: none; font-weight: 500;
    }
    .admin-back-link:hover { border-color: var(--admin-text-4); color: var(--admin-text); }

    .deploy-actions { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.75rem; }
    .deploy-actions .admin-publish-btn { flex: 1; min-width: 0; }
    .kbd-hint {
      font-size: 0.625rem; color: var(--admin-text-4); font-family: var(--admin-mono);
      margin-left: 0.375rem;
    }

    /* ─── Section dividers ─── */
    .edit-section {
      padding-top: 1.25rem; margin-top: 1.25rem;
      border-top: 1px solid var(--admin-border);
    }
    .edit-section:first-child { padding-top: 0; margin-top: 0; border-top: none; }
    .edit-section-title {
      font-size: 0.6875rem; text-transform: uppercase; letter-spacing: 0.05em;
      color: var(--admin-text-4); font-weight: 600; margin-bottom: 0.75rem;
      font-family: 'Inter', sans-serif;
    }

    /* ─── Hero image preview ─── */
    .hero-preview {
      display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem;
      margin-top: 0.5rem; border-radius: var(--admin-radius); overflow: hidden;
    }
    .hero-preview-single { grid-template-columns: 1fr; }
    .hero-preview-card {
      position: relative; aspect-ratio: 16/10; border-radius: var(--admin-radius);
      overflow: hidden; border: 1px solid var(--admin-border);
    }
    .hero-preview-card img {
      width: 100%; height: 100%; object-fit: cover;
      transition: opacity 0.2s;
    }
    .hero-preview-card img[src=""] { display: none; }
    .hero-preview-label {
      position: absolute; bottom: 0; left: 0; right: 0;
      padding: 0.25rem 0.5rem; font-size: 0.625rem; font-weight: 600;
      font-family: 'Inter', sans-serif; letter-spacing: 0.04em; text-transform: uppercase;
    }
    .hero-preview-dark { background: #0f0e0c; }
    .hero-preview-dark .hero-preview-label { background: rgba(0,0,0,0.7); color: var(--admin-text-3); }
    .hero-preview-light { background: #e7e6e3; }
    .hero-preview-light .hero-preview-label { background: rgba(255,255,255,0.7); color: #57534e; }
    .hero-preview-empty {
      display: flex; align-items: center; justify-content: center;
      color: var(--admin-text-4); font-size: 0.75rem; font-family: 'Inter', sans-serif;
    }

    /* ─── Narration player ─── */
    .narration-player {
      display: flex; align-items: center; gap: 0.75rem;
      padding: 0.625rem 0.875rem; border-radius: var(--admin-radius);
      background: var(--admin-surface-2); border: 1px solid var(--admin-border);
      margin-top: 0.5rem;
    }
    .narration-play-btn {
      width: 32px; height: 32px; border-radius: 50%;
      background: var(--admin-accent); border: none; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      color: white; transition: all 0.15s; flex-shrink: 0;
    }
    .narration-play-btn:hover { background: #dc2626; transform: scale(1.05); }
    .narration-play-btn:disabled { opacity: 0.3; cursor: not-allowed; transform: none; }
    .narration-progress {
      flex: 1; height: 3px; background: var(--admin-border-2);
      border-radius: 2px; overflow: hidden; cursor: pointer;
    }
    .narration-progress-bar {
      height: 100%; background: var(--admin-accent); border-radius: 2px;
      width: 0%; transition: width 0.1s linear;
    }
    .narration-time {
      font-size: 0.6875rem; color: var(--admin-text-4);
      font-family: var(--admin-mono); font-variant-numeric: tabular-nums;
      min-width: 3rem; text-align: right;
    }
    .narration-empty {
      font-size: 0.75rem; color: var(--admin-text-4);
      font-family: 'Inter', sans-serif; font-style: italic;
    }

    /* ─── Generate action buttons (inline) ─── */
    .generate-btn {
      display: inline-flex; align-items: center; gap: 0.375rem;
      padding: 0.375rem 0.75rem; border-radius: var(--admin-radius-sm);
      background: var(--admin-surface-3); border: 1px solid var(--admin-border-2);
      color: var(--admin-text-3); font-size: 0.6875rem; font-weight: 500;
      font-family: 'Inter', sans-serif; cursor: pointer; transition: all 0.15s;
    }
    .generate-btn:hover { border-color: var(--admin-accent); color: var(--admin-accent); background: var(--admin-accent-dim); }
    .generate-btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .generate-btn svg { flex-shrink: 0; }

    /* ─── Gradient preview swatch ─── */
    .gradient-preview {
      height: 2.5rem; border-radius: var(--admin-radius);
      border: 1px solid var(--admin-border); margin-top: 0.375rem;
      transition: background 0.3s;
    }
    .gradient-preset-btn {
      padding: 0.25rem 0.5rem; border-radius: var(--admin-radius-sm);
      background: var(--admin-surface-3); border: 1px solid var(--admin-border);
      color: var(--admin-text-3); font-size: 0.625rem; font-weight: 500;
      font-family: 'Inter', sans-serif; cursor: pointer; transition: all 0.15s;
    }
    .gradient-preset-btn:hover { border-color: var(--admin-accent); color: var(--admin-text); }

    /* ─── Description char count ─── */
    .char-count {
      font-size: 0.625rem; color: var(--admin-text-4);
      font-family: var(--admin-mono); font-variant-numeric: tabular-nums;
      text-align: right; margin-top: 0.25rem;
    }
    .char-count.warn { color: var(--admin-yellow); }
    .char-count.over { color: var(--admin-red-light); }
  </style>
</head>
<body class="admin-body">
  <header class="admin-header">
    <div class="admin-header-inner">
      <div class="admin-logo">
        <span class="admin-logo-accent">a</span>lumi
        <span class="admin-logo-badge">admin</span>
      </div>
      <nav class="admin-nav">
        <a href="/admin" class="admin-nav-link">&larr; Dashboard</a>
        <a href="/admin/new" class="admin-nav-link">New Article</a>
        <a href="/admin/social-preview" class="admin-nav-link">Social Preview</a>
        <a href={liveUrl} class="admin-nav-link" target="_blank">View Live &rarr;</a>
        <button id="logoutBtn" class="admin-nav-link" style="border:none;background:none;cursor:pointer;font-family:inherit;font-size:inherit">Logout</button>
      </nav>
    </div>
  </header>

  <div class="admin-edit-layout">
    <!-- Left Panel -->
    <div class="admin-edit-left">
      <div class="admin-tabs" role="tablist" aria-label="Edit sections">
        <button class="admin-tab active" data-tab="metadata" role="tab" aria-selected="true" aria-controls="tab-metadata" id="edit-tab-metadata">Metadata</button>
        <button class="admin-tab" data-tab="content" role="tab" aria-selected="false" aria-controls="tab-content" id="edit-tab-content" tabindex="-1">Content</button>
        <button class="admin-tab" data-tab="refine" role="tab" aria-selected="false" aria-controls="tab-refine" id="edit-tab-refine" tabindex="-1">AI Refine</button>
        <span id="autosaveIndicator" class="autosave-indicator" style="margin-left:auto"></span>
      </div>

      <div class="admin-edit-scroll">
        <!-- METADATA TAB -->
        <div id="tab-metadata" class="admin-tab-panel" role="tabpanel" aria-labelledby="edit-tab-metadata" style="display:block;padding-top:1.25rem">
          <div class="admin-edit-header">
            <div style="display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap">
              <span class="admin-edit-label">Editing</span>
              <span class={`status-pill ${article.status === 'published' ? 'status-published' : article.draft ? 'status-draft' : 'status-draft'}`}>
                {article.status === 'published' ? 'Published' : article.draft ? 'Draft' : 'Draft'}
              </span>
            </div>
            <h1 class="admin-edit-title">{article.title}</h1>
            {(independenceScore !== null || editorScore !== null) && (
              <div class="score-badges">
                {independenceScore !== null && (
                  <span class={`score-badge ${independenceScore >= 7 ? 'score-badge-high' : independenceScore >= 4 ? 'score-badge-mid' : 'score-badge-low'}`}>
                    Independence <span class="score-badge-value">{independenceScore}/10</span>
                  </span>
                )}
                {editorScore !== null && (
                  <span class={`score-badge ${editorScore >= 7 ? 'score-badge-high' : editorScore >= 4 ? 'score-badge-mid' : 'score-badge-low'}`}>
                    Editor <span class="score-badge-value">{editorScore}/10</span>
                  </span>
                )}
              </div>
            )}
          </div>

          <form id="editForm" class="admin-edit-form">
            <!-- Core fields -->
            <div class="edit-section" style="border-top:none;margin-top:0;padding-top:0">
              <div class="edit-section-title">Core</div>
              <div class="admin-edit-field">
                <label for="title">Title</label>
                <input id="title" name="title" value={article.title} />
              </div>
              <div class="admin-edit-field">
                <label for="description">Description</label>
                <textarea id="description" name="description" rows="3">{article.description}</textarea>
                <div id="descCharCount" class="char-count"></div>
              </div>
              <div class="admin-edit-row">
                <div class="admin-edit-field">
                  <label for="category">Category</label>
                  <select id="category" name="category">
                    {categories.map(c => (
                      <option value={c} selected={c === article.category}>{c}</option>
                    ))}
                  </select>
                </div>
                <div class="admin-edit-field">
                  <label for="readTime">Read Time (min)</label>
                  <input id="readTime" name="readTime" type="number" value={article.read_time} min="1" />
                </div>
              </div>
              <div class="admin-edit-row">
                <div class="admin-edit-field">
                  <label for="publishDate">Publish Date</label>
                  <input id="publishDate" name="publishDate" type="date" value={article.publish_date} />
                </div>
                <div class="admin-edit-field">
                  <label for="sortOrder">Sort Order</label>
                  <input id="sortOrder" name="sortOrder" type="number" value={article.sort_order || ''} min="1" placeholder="Auto" />
                </div>
              </div>
              <div class="admin-edit-field">
                <label for="tags">Tags (comma-separated)</label>
                <input id="tags" name="tags" value={(article.tags || []).join(', ')} />
              </div>
              <div class="admin-edit-field">
                <label for="keywords">Keywords (comma-separated)</label>
                <input id="keywords" name="keywords" value={(article.keywords || []).join(', ')} />
              </div>
              <div class="admin-edit-row">
                <label class="admin-checkbox-label">
                  <input type="checkbox" id="featured" name="featured" checked={article.featured} />
                  Featured
                </label>
                <label class="admin-checkbox-label">
                  <input type="checkbox" id="draft" name="draft" checked={article.draft} />
                  Draft
                </label>
                <label class="admin-checkbox-label">
                  <input type="checkbox" id="comingSoon" name="comingSoon" checked={article.coming_soon} />
                  Coming Soon
                </label>
              </div>
            </div>

            <!-- Hero Image -->
            <div class="edit-section">
              <div style="display:flex;align-items:center;justify-content:space-between">
                <div class="edit-section-title" style="margin-bottom:0">Hero Image</div>
                <button type="button" id="generateIllustrationBtn" class="generate-btn">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                  Generate
                </button>
              </div>
              <div id="heroPreview" class={`hero-preview ${!article.hero_image_light ? 'hero-preview-single' : ''}`}>
                {article.hero_image ? (
                  <div class="hero-preview-card hero-preview-dark">
                    <img id="heroPreviewDark" src={article.hero_image} alt="Dark variant" loading="lazy" />
                    <div class="hero-preview-label">Dark</div>
                  </div>
                ) : (
                  <div class="hero-preview-card hero-preview-dark hero-preview-empty">No image</div>
                )}
                {article.hero_image_light && (
                  <div class="hero-preview-card hero-preview-light">
                    <img id="heroPreviewLight" src={article.hero_image_light} alt="Light variant" loading="lazy" />
                    <div class="hero-preview-label">Light</div>
                  </div>
                )}
              </div>
              <div style="margin-top:0.75rem;display:flex;flex-direction:column;gap:0.75rem">
                <div class="admin-edit-field">
                  <label for="heroImage">Dark Image URL</label>
                  <input id="heroImage" name="heroImage" value={article.hero_image || ''} placeholder="https://..." />
                </div>
                <div class="admin-edit-field">
                  <label for="heroImageLight">Light Image URL</label>
                  <input id="heroImageLight" name="heroImageLight" value={article.hero_image_light || ''} placeholder="https://..." />
                </div>
                <div class="admin-edit-field">
                  <label for="heroImageAlt">Alt Text</label>
                  <input id="heroImageAlt" name="heroImageAlt" value={article.hero_image_alt || ''} placeholder="Editorial illustration for..." />
                </div>
              </div>
              <div id="illustrationStatus" style="display:none;margin-top:0.5rem" class="admin-edit-status"></div>
              <div id="illustrationError" style="display:none;margin-top:0.5rem" class="admin-error"></div>
            </div>

            <!-- Narration -->
            <div class="edit-section">
              <div style="display:flex;align-items:center;justify-content:space-between">
                <div class="edit-section-title" style="margin-bottom:0">Narration</div>
                <button type="button" id="generateNarrationBtn" class="generate-btn">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg>
                  Generate
                </button>
              </div>
              {article.narration_url ? (
                <div class="narration-player" id="narrationPlayer">
                  <button type="button" class="narration-play-btn" id="narrationPlayBtn" aria-label="Play narration">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" id="narrationPlayIcon"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                  </button>
                  <div class="narration-progress" id="narrationProgress">
                    <div class="narration-progress-bar" id="narrationProgressBar"></div>
                  </div>
                  <span class="narration-time" id="narrationTime">0:00</span>
                  <audio id="narrationAudio" src={article.narration_url} preload="metadata"></audio>
                </div>
              ) : (
                <div class="narration-player">
                  <span class="narration-empty">No narration generated yet</span>
                </div>
              )}
              <div class="admin-edit-field" style="margin-top:0.75rem">
                <label for="narrationUrl">Narration URL</label>
                <input id="narrationUrl" name="narrationUrl" value={article.narration_url || ''} placeholder="Auto-generated by pipeline" />
              </div>
              <div id="narrationStatus" style="display:none;margin-top:0.5rem" class="admin-edit-status"></div>
              <div id="narrationError" style="display:none;margin-top:0.5rem" class="admin-error"></div>
            </div>

            <!-- Gradient -->
            <div class="edit-section">
              <div style="display:flex;align-items:center;justify-content:space-between">
                <div class="edit-section-title" style="margin-bottom:0">Gradient</div>
                <button type="button" id="gradientPresetBtn" class="gradient-preset-btn">Use Category Preset</button>
              </div>
              <div class="admin-edit-row" style="margin-top:0.75rem">
                <div class="admin-edit-field">
                  <label for="gradientFrom">From</label>
                  <input id="gradientFrom" name="gradientFrom" value={article.gradient_from || ''} placeholder="e.g. violet-600" />
                </div>
                <div class="admin-edit-field">
                  <label for="gradientTo">To</label>
                  <input id="gradientTo" name="gradientTo" value={article.gradient_to || ''} placeholder="e.g. purple-700" />
                </div>
              </div>
              <div id="gradientPreview" class="gradient-preview"></div>
            </div>

            <div id="metaStatus" style="display:none" class="admin-edit-status"></div>
            <div id="metaError" style="display:none" class="admin-error"></div>
            <div class="admin-edit-actions">
              <button type="submit" class="admin-publish-btn" id="saveMetaBtn">Save Metadata <span class="kbd-hint">{'\u2318'}S</span></button>
            </div>
          </form>

          <!-- Deploy / Delete / Dashboard -->
          <div class="edit-section">
            <div class="edit-section-title">Deploy to Live Site</div>
            <p style="font-size:0.8125rem;color:var(--admin-text-3);margin-bottom:1rem;line-height:1.5">Push the current database version to GitHub, triggering a Vercel rebuild.</p>
            <div id="publishStatus" style="display:none" class="admin-edit-status"></div>
            <div id="publishError" style="display:none" class="admin-error"></div>
            <div class="deploy-actions">
              <button id="publishGitHubBtn" class="admin-publish-btn" style="background:var(--admin-accent);justify-content:center">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 19V5M5 12l7-7 7 7"/>
                </svg>
                Publish to GitHub
              </button>
            </div>
            <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-top:0.75rem">
              <button id="deleteGitHubBtn" class="admin-danger-btn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                </svg>
                Delete Article
              </button>
              <a href="/admin" class="admin-back-link">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M19 12H5M12 19l-7-7 7-7"/>
                </svg>
                Back to Dashboard
              </a>
            </div>
            <div id="deleteStatus" style="display:none;margin-top:0.75rem" class="admin-edit-status"></div>
            <div id="deleteError" style="display:none;margin-top:0.75rem" class="admin-error"></div>
          </div>
        </div>

        <!-- CONTENT TAB -->
        <div id="tab-content" class="admin-tab-panel" role="tabpanel" aria-labelledby="edit-tab-content" style="display:none">
          <div class="admin-content-toolbar">
            <span class="admin-content-toolbar-label">Article HTML</span>
            <span id="contentWordCount" class="admin-content-toolbar-info"></span>
          </div>
          <textarea id="contentHtml" class="admin-code-editor" spellcheck="false">{article.article_html || ''}</textarea>
          <div id="contentStatus" style="display:none" class="admin-edit-status"></div>
          <div id="contentError" style="display:none" class="admin-error"></div>
          <div class="admin-edit-actions" style="gap:0.5rem">
            <button id="previewContentBtn" class="admin-cancel-btn" style="padding:0.625rem 1.25rem" type="button">Preview</button>
            <button id="saveContentBtn" class="admin-publish-btn">Save Content <span class="kbd-hint">{'\u2318'}S</span></button>
          </div>
        </div>

        <!-- REFINE TAB -->
        <div id="tab-refine" class="admin-tab-panel" role="tabpanel" aria-labelledby="edit-tab-refine" style="display:none">
          {article.article_html ? (
            <div class="admin-refine-chat">
              <div id="refineMessages" class="admin-chat-messages">
                <div class="admin-chat-msg admin-chat-msg-assistant">
                  Article loaded ({article.read_time} min read). Tell me what to change.
                </div>
              </div>
              <div class="admin-refine-templates" id="refineTemplates">
                <span class="admin-refine-label">Quick actions</span>
                <button class="admin-template-btn" data-prompt="Make the introduction more compelling and punchy.">Punchier intro</button>
                <button class="admin-template-btn" data-prompt="Add more specific data points and study citations.">More evidence</button>
                <button class="admin-template-btn" data-prompt="Make the article more concise. Cut filler.">Shorter</button>
                <button class="admin-template-btn" data-prompt="Rewrite the conclusion to be more actionable.">Stronger conclusion</button>
                <button class="admin-template-btn" data-prompt="Simplify the language. Shorter sentences.">Simplify</button>
              </div>
              <div class="admin-chat-input-area">
                <input type="text" id="refineInput" class="admin-chat-input" placeholder="Tell Claude what to change..." />
                <button id="refineSendBtn" class="admin-chat-send">Send</button>
              </div>
              <div id="refineStatus" style="display:none" class="admin-edit-status"></div>
              <div id="refineError" style="display:none" class="admin-error"></div>
              <div class="admin-edit-actions">
                <button id="saveRefineBtn" class="admin-publish-btn" disabled>Save Refined Article</button>
              </div>
            </div>
          ) : (
            <div style="padding:2rem;text-align:center;color:var(--admin-text-4)">
              <p>No article content yet. Generate an article first using the "New Article" editor, or paste HTML in the Content tab.</p>
            </div>
          )}
        </div>
      </div>
    </div>

    <!-- Right: Preview -->
    <div class="admin-edit-right">
      <div class="admin-preview-toolbar">
        <span class="admin-preview-toolbar-label">Preview</span>
        <a href={liveUrl} target="_blank" class="admin-preview-toolbar-link">
          Open live
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
            <polyline points="15 3 21 3 21 9"/>
            <line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
        </a>
      </div>
      <iframe id="previewFrame" src={liveUrl} class="admin-preview-frame" title="Article Preview"></iframe>
    </div>
  </div>

  <script define:vars={{ slug, apiBase, articleData: article, gradientPresets }}>
    const getToken = () => (document.cookie.match(/(?:^|;\s*)admin_token=([^;]*)/)?.[1] || '');
    const esc = s => String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');

    // ─── Styled confirm dialog ───
    function styledConfirm(title, message, confirmLabel, danger) {
      return new Promise(resolve => {
        const modal = document.createElement('div');
        modal.className = 'admin-modal';
        modal.setAttribute('role', 'dialog');
        modal.setAttribute('aria-modal', 'true');
        modal.innerHTML = '<div class="admin-modal-backdrop"></div>'
          + '<div class="admin-modal-card">'
          + '<h3 class="admin-modal-title">' + esc(title) + '</h3>'
          + '<p class="admin-modal-text">' + esc(message) + '</p>'
          + '<div class="admin-modal-actions">'
          + '<button class="admin-action-btn admin-action-btn-muted" data-role="cancel">' + esc('Cancel') + '</button>'
          + '<button class="admin-action-btn ' + (danger ? 'admin-action-delete' : 'admin-action-btn-primary') + '" data-role="confirm">' + esc(confirmLabel || 'Confirm') + '</button>'
          + '</div></div>';
        document.body.appendChild(modal);
        const cleanup = (v) => { modal.remove(); resolve(v); };
        modal.querySelector('[data-role="cancel"]').addEventListener('click', () => cleanup(false));
        modal.querySelector('[data-role="confirm"]').addEventListener('click', () => cleanup(true));
        modal.querySelector('.admin-modal-backdrop').addEventListener('click', () => cleanup(false));
        const onKey = (e) => { if (e.key === 'Escape') { document.removeEventListener('keydown', onKey); cleanup(false); } };
        document.addEventListener('keydown', onKey);
        modal.querySelector('[data-role="cancel"]').focus();
      });
    }

    let currentHtml = articleData.article_html || '';
    let suppressAutosave = false;

    // ─── Helper: create a chat message DOM element safely (no innerHTML XSS) ───
    function createChatMsg(text, role) {
      const div = document.createElement('div');
      div.className = 'admin-chat-msg admin-chat-msg-' + role;
      div.textContent = text;
      return div;
    }

    function createSpinnerMsg(id) {
      const div = document.createElement('div');
      div.className = 'admin-chat-msg admin-chat-msg-assistant';
      div.id = id;
      const spinner = document.createElement('div');
      spinner.className = 'admin-spinner';
      div.appendChild(spinner);
      return div;
    }

    // ─── Autosave indicator ───
    const autosaveEl = document.getElementById('autosaveIndicator');
    function showAutosave(state, msg) {
      if (!autosaveEl) return;
      autosaveEl.className = 'autosave-indicator ' + state;
      autosaveEl.textContent = msg;
      if (state === 'saved') {
        setTimeout(() => { autosaveEl.textContent = ''; autosaveEl.className = 'autosave-indicator'; }, 3000);
      }
    }

    // ─── Autosave debounce logic ───
    let autosaveTimer = null;
    let autosaveInFlight = false;
    function scheduleAutosave(saveFn) {
      if (autosaveTimer) clearTimeout(autosaveTimer);
      showAutosave('saving', 'Unsaved changes...');
      autosaveTimer = setTimeout(async () => {
        if (autosaveInFlight) return;
        autosaveInFlight = true;
        showAutosave('saving', 'Autosaving...');
        try {
          await saveFn();
          showAutosave('saved', 'Saved');
        } catch (err) {
          showAutosave('error', 'Autosave failed');
        } finally {
          autosaveInFlight = false;
        }
      }, 2000);
    }

    // ─── Description character count ───
    function updateDescCharCount() {
      const desc = document.getElementById('description');
      const counter = document.getElementById('descCharCount');
      if (!desc || !counter) return;
      const len = desc.value.length;
      counter.textContent = len + '/160 chars';
      counter.className = 'char-count' + (len > 160 ? ' over' : len > 140 ? ' warn' : '');
    }
    updateDescCharCount();
    document.getElementById('description')?.addEventListener('input', updateDescCharCount);

    // ─── Gradient preview ───
    const twToHex = {
      'rose-600': '#e11d48', 'pink-700': '#be185d', 'violet-600': '#7c3aed', 'purple-700': '#7e22ce',
      'emerald-600': '#059669', 'green-700': '#15803d', 'amber-600': '#d97706', 'orange-700': '#c2410c',
      'blue-600': '#2563eb', 'indigo-700': '#4338ca', 'indigo-600': '#4f46e5', 'teal-600': '#0d9488',
      'cyan-700': '#0e7490', 'slate-600': '#475569', 'gray-700': '#374151', 'lime-600': '#65a30d',
      'fuchsia-600': '#c026d3', 'red-600': '#dc2626', 'red-700': '#b91c1c', 'sky-600': '#0284c7',
    };
    function updateGradientPreview() {
      const from = document.getElementById('gradientFrom')?.value || '';
      const to = document.getElementById('gradientTo')?.value || '';
      const preview = document.getElementById('gradientPreview');
      if (!preview) return;
      const fromHex = twToHex[from] || '#333';
      const toHex = twToHex[to] || '#333';
      preview.style.background = 'linear-gradient(135deg, ' + fromHex + ', ' + toHex + ')';
    }
    updateGradientPreview();
    document.getElementById('gradientFrom')?.addEventListener('input', updateGradientPreview);
    document.getElementById('gradientTo')?.addEventListener('input', updateGradientPreview);

    // ─── Gradient preset button ───
    document.getElementById('gradientPresetBtn')?.addEventListener('click', () => {
      const cat = document.getElementById('category')?.value;
      if (cat && gradientPresets[cat]) {
        document.getElementById('gradientFrom').value = gradientPresets[cat].from;
        document.getElementById('gradientTo').value = gradientPresets[cat].to;
        updateGradientPreview();
        scheduleAutosave(doSaveMetadata);
      }
    });

    // ─── Hero image preview update on URL change ───
    function updateHeroPreview() {
      const darkUrl = document.getElementById('heroImage')?.value?.trim() || '';
      const lightUrl = document.getElementById('heroImageLight')?.value?.trim() || '';
      const container = document.getElementById('heroPreview');
      if (!container) return;

      const hasLight = !!lightUrl;
      container.className = 'hero-preview' + (hasLight ? '' : ' hero-preview-single');

      container.innerHTML = '';

      // Dark card
      const darkCard = document.createElement('div');
      darkCard.className = 'hero-preview-card hero-preview-dark' + (darkUrl ? '' : ' hero-preview-empty');
      if (darkUrl) {
        const img = document.createElement('img');
        img.src = darkUrl;
        img.alt = 'Dark variant';
        img.loading = 'lazy';
        img.onerror = () => { darkCard.classList.add('hero-preview-empty'); img.style.display = 'none'; darkCard.textContent = 'Failed to load'; };
        darkCard.appendChild(img);
        const label = document.createElement('div');
        label.className = 'hero-preview-label';
        label.textContent = 'Dark';
        darkCard.appendChild(label);
      } else {
        darkCard.textContent = 'No image';
      }
      container.appendChild(darkCard);

      // Light card
      if (hasLight) {
        const lightCard = document.createElement('div');
        lightCard.className = 'hero-preview-card hero-preview-light';
        const img = document.createElement('img');
        img.src = lightUrl;
        img.alt = 'Light variant';
        img.loading = 'lazy';
        img.onerror = () => { lightCard.classList.add('hero-preview-empty'); img.style.display = 'none'; lightCard.textContent = 'Failed to load'; };
        lightCard.appendChild(img);
        const label = document.createElement('div');
        label.className = 'hero-preview-label';
        label.textContent = 'Light';
        lightCard.appendChild(label);
        container.appendChild(lightCard);
      }
    }
    document.getElementById('heroImage')?.addEventListener('change', updateHeroPreview);
    document.getElementById('heroImageLight')?.addEventListener('change', updateHeroPreview);

    // ─── Narration audio player ───
    const narrationAudio = document.getElementById('narrationAudio');
    const narrationPlayBtn = document.getElementById('narrationPlayBtn');
    const narrationPlayIcon = document.getElementById('narrationPlayIcon');
    const narrationProgressBar = document.getElementById('narrationProgressBar');
    const narrationProgress = document.getElementById('narrationProgress');
    const narrationTime = document.getElementById('narrationTime');

    function formatTime(s) {
      if (!s || isNaN(s)) return '0:00';
      const m = Math.floor(s / 60);
      const sec = Math.floor(s % 60);
      return m + ':' + (sec < 10 ? '0' : '') + sec;
    }

    if (narrationAudio && narrationPlayBtn) {
      narrationPlayBtn.addEventListener('click', () => {
        if (narrationAudio.paused) {
          narrationAudio.play();
          narrationPlayIcon.innerHTML = '<rect x="6" y="4" width="4" height="16" fill="currentColor"/><rect x="14" y="4" width="4" height="16" fill="currentColor"/>';
        } else {
          narrationAudio.pause();
          narrationPlayIcon.innerHTML = '<polygon points="5 3 19 12 5 21 5 3"/>';
        }
      });
      narrationAudio.addEventListener('timeupdate', () => {
        if (narrationAudio.duration) {
          const pct = (narrationAudio.currentTime / narrationAudio.duration) * 100;
          if (narrationProgressBar) narrationProgressBar.style.width = pct + '%';
          if (narrationTime) narrationTime.textContent = formatTime(narrationAudio.currentTime);
        }
      });
      narrationAudio.addEventListener('ended', () => {
        narrationPlayIcon.innerHTML = '<polygon points="5 3 19 12 5 21 5 3"/>';
        if (narrationProgressBar) narrationProgressBar.style.width = '0%';
        if (narrationTime) narrationTime.textContent = '0:00';
      });
      narrationAudio.addEventListener('loadedmetadata', () => {
        if (narrationTime) narrationTime.textContent = formatTime(narrationAudio.duration);
      });
      if (narrationProgress) {
        narrationProgress.addEventListener('click', (e) => {
          if (!narrationAudio.duration) return;
          const rect = narrationProgress.getBoundingClientRect();
          const pct = (e.clientX - rect.left) / rect.width;
          narrationAudio.currentTime = pct * narrationAudio.duration;
        });
      }
    }

    // ─── Autosave: save metadata fields to DB ───
    async function doSaveMetadata() {
      const f = document.getElementById('editForm');
      if (!f) return;
      const res = await fetch(apiBase + '/articles-api', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + getToken() },
        body: JSON.stringify({
          action: 'save',
          article: {
            slug,
            title: f.title.value.trim(),
            description: f.description.value.trim(),
            category: f.category.value,
            read_time: parseInt(f.readTime.value) || articleData.read_time,
            publish_date: f.publishDate.value || articleData.publish_date,
            sort_order: f.sortOrder.value ? parseInt(f.sortOrder.value) : null,
            tags: f.tags.value.split(',').map(t => t.trim()).filter(Boolean),
            keywords: f.keywords.value.split(',').map(t => t.trim()).filter(Boolean),
            hero_image: f.heroImage.value.trim() || null,
            hero_image_light: f.heroImageLight.value.trim() || null,
            hero_image_alt: f.heroImageAlt.value.trim() || null,
            gradient_from: f.gradientFrom.value.trim() || null,
            gradient_to: f.gradientTo.value.trim() || null,
            narration_url: f.narrationUrl.value.trim() || null,
            featured: f.featured.checked,
            draft: f.draft.checked,
            coming_soon: f.comingSoon.checked,
          }
        }),
      });
      if (!res.ok) throw new Error('Autosave failed');
    }

    // ─── Autosave: save content to DB ───
    async function doSaveContent() {
      const html = document.getElementById('contentHtml')?.value;
      if (html == null) return;
      const res = await fetch(apiBase + '/articles-api', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + getToken() },
        body: JSON.stringify({
          action: 'save',
          article: { slug, article_html: html }
        }),
      });
      if (!res.ok) throw new Error('Autosave failed');
      currentHtml = html;
    }

    // ─── Attach autosave listeners to metadata form fields ───
    document.querySelectorAll('#editForm input, #editForm textarea, #editForm select').forEach(el => {
      el.addEventListener('input', () => scheduleAutosave(doSaveMetadata));
      el.addEventListener('change', () => scheduleAutosave(doSaveMetadata));
    });

    // ─── Attach autosave listener to content textarea ───
    document.getElementById('contentHtml')?.addEventListener('input', () => {
      if (!suppressAutosave) scheduleAutosave(doSaveContent);
    });

    // Logout
    document.getElementById('logoutBtn')?.addEventListener('click', () => {
      document.cookie = 'admin_token=; path=/; max-age=0';
      window.location.href = '/admin/login';
    });

    // ─── Generate Illustration ───
    document.getElementById('generateIllustrationBtn')?.addEventListener('click', async () => {
      if (!await styledConfirm('Generate Illustration', 'Generate a new hero image pair (dark + light) for this article? This will overwrite any existing images.', 'Generate')) return;
      const btn = document.getElementById('generateIllustrationBtn');
      const status = document.getElementById('illustrationStatus');
      const error = document.getElementById('illustrationError');
      btn.disabled = true; btn.textContent = 'Generating...';
      error.style.display = 'none'; status.style.display = 'none';

      try {
        const res = await fetch(apiBase + '/generate-illustration', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            action: 'generate',
            slug,
            title: document.getElementById('title').value,
            description: document.getElementById('description').value,
            category: document.getElementById('category').value,
            variant: 'both',
          }),
        });
        if (!res.ok) throw new Error('Generation failed');
        const data = await res.json();

        status.textContent = 'Illustration generated! Updating preview...';
        status.style.display = 'block';

        // Refresh article data to get new URLs
        const getRes = await fetch(apiBase + '/articles-api', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'get', slug }),
        });
        if (getRes.ok) {
          const updated = await getRes.json();
          if (updated.hero_image) document.getElementById('heroImage').value = updated.hero_image;
          if (updated.hero_image_light) document.getElementById('heroImageLight').value = updated.hero_image_light;
          if (updated.hero_image_alt) document.getElementById('heroImageAlt').value = updated.hero_image_alt;
          updateHeroPreview();
        }
        status.textContent = 'Illustration generated successfully.';
      } catch (err) {
        error.textContent = 'Generation failed: ' + err.message;
        error.style.display = 'block';
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg> Generate';
      }
    });

    // ─── Generate Narration ───
    document.getElementById('generateNarrationBtn')?.addEventListener('click', async () => {
      if (!await styledConfirm('Generate Narration', 'Generate a new TTS narration for this article\'s description?', 'Generate')) return;
      const btn = document.getElementById('generateNarrationBtn');
      const status = document.getElementById('narrationStatus');
      const error = document.getElementById('narrationError');
      btn.disabled = true; btn.textContent = 'Generating...';
      error.style.display = 'none'; status.style.display = 'none';

      try {
        const res = await fetch(apiBase + '/generate-narration', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'generate', slug, force: true }),
        });
        if (!res.ok) throw new Error('Narration generation failed');
        const data = await res.json();

        // Update URL field
        if (data.narration_url || data.url) {
          const url = data.narration_url || data.url;
          document.getElementById('narrationUrl').value = url;
          scheduleAutosave(doSaveMetadata);
          status.textContent = 'Narration generated. Reload page to use the audio player.';
        } else {
          status.textContent = 'Narration generated.';
        }
        status.style.display = 'block';
      } catch (err) {
        error.textContent = 'Narration failed: ' + err.message;
        error.style.display = 'block';
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg> Generate';
      }
    });

    // ─── Publish to GitHub ───
    document.getElementById('publishGitHubBtn')?.addEventListener('click', async () => {
      if (!await styledConfirm('Publish article', 'Publish this article to the live site?', 'Publish')) return;
      const btn = document.getElementById('publishGitHubBtn');
      const status = document.getElementById('publishStatus');
      const error = document.getElementById('publishError');
      btn.textContent = 'Saving...'; btn.disabled = true;
      error.style.display = 'none'; status.style.display = 'none';

      try {
        // Force save metadata + content to DB before publishing
        if (autosaveTimer) { clearTimeout(autosaveTimer); autosaveTimer = null; }
        await doSaveMetadata();
        await doSaveContent();
        btn.textContent = 'Publishing...';

        // Get latest article data from DB (includes all fields)
        const getRes = await fetch(apiBase + '/articles-api', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'get', slug }),
        });
        if (!getRes.ok) throw new Error('Failed to load article from database');
        const db = await getRes.json();

        // Assemble .astro file
        const publishDate = new Date(db.publish_date).toLocaleDateString('en-US', { month: 'long', year: 'numeric' });

        const tagsHtml = (db.tags || [])
          .map(tag => '    <span class="px-3 py-1 bg-stone-100 dark:bg-stone-800 rounded-full text-sm">' + tag + '</span>')
          .join('\n');

        const tocHtml = (db.toc || [])
          .map(item => '      <a href="#' + item.id + '" class="block text-sm text-stone-600 dark:text-stone-400 hover:text-primary-600 transition-colors">' + item.title + '</a>')
          .join('\n');

        const title = db.title.replace(/"/g, '&quot;');
        const desc = db.description.replace(/"/g, '&quot;');

        // Deduplicate: if the first <p> in <section id="introduction"> matches
        // the description (rendered as standfirst by ArticleLayout), strip it
        // so the reader doesn't see the same text twice.
        let articleHtml = db.article_html || '';
        const descPlain = (db.description || '').replace(/\s+/g, ' ').trim();
        if (descPlain.length > 30) {
          const introMatch = articleHtml.match(
            /(<section[^>]*id="introduction"[^>]*>\s*)(<p[^>]*>)([\s\S]*?)(<\/p>)/i
          );
          if (introMatch) {
            const firstParaText = introMatch[3].replace(/<[^>]+>/g, '').replace(/\s+/g, ' ').trim();
            if (descPlain.startsWith(firstParaText.slice(0, 80)) || firstParaText.startsWith(descPlain.slice(0, 80))) {
              articleHtml = articleHtml.replace(introMatch[0], introMatch[1]);
            }
          }
        }

        const astroContent = '---\nimport ArticleLayout from \'../../layouts/ArticleLayout.astro\';\n---\n\n<ArticleLayout\n  title="' + title + '"\n  description="' + desc + '"\n  category="' + db.category + '"\n  readTime="' + db.read_time + ' min read"\n  publishDate="' + publishDate + '"\n>\n' +
          '  <div class="mb-12 p-6 bg-stone-100 dark:bg-stone-900 rounded-2xl reveal">\n    <h2 class="font-serif text-lg font-semibold mb-4">In This Article</h2>\n    <nav class="space-y-2">\n' + tocHtml + '\n    </nav>\n  </div>\n\n  <div class="article-content">\n' + articleHtml + '\n  </div>\n\n  <Fragment slot="tags">\n' + tagsHtml + '\n  </Fragment>\n</ArticleLayout>\n';

        // Build metadata JSON — include ALL fields from DB
        const metadata = {
          title: db.title,
          description: db.description,
          category: db.category,
          publishDate: db.publish_date,
          author: { name: 'alumi news Editorial', role: 'Medical Review Board' },
          readTime: db.read_time,
          featured: db.featured,
          draft: db.draft || false,
          tags: db.tags || [],
          gradient: { from: db.gradient_from, to: db.gradient_to },
          keywords: db.keywords || [],
          comingSoon: db.coming_soon || false,
        };
        // Only include optional fields if they have values (keeps JSON clean)
        if (db.hero_image) metadata.heroImage = db.hero_image;
        if (db.hero_image_alt) metadata.heroImageAlt = db.hero_image_alt;
        if (db.hero_image_light) metadata.heroImageLight = db.hero_image_light;
        if (db.narration_url) metadata.narrationUrl = db.narration_url;
        if (db.sort_order) metadata.sortOrder = db.sort_order;

        // Commit to GitHub
        const pubRes = await fetch(apiBase + '/publish-article', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + getToken() },
          body: JSON.stringify({
            slug,
            astroContent,
            metadata,
            commitMessage: 'feat: Publish \'' + db.title + '\' from admin',
          }),
        });

        if (!pubRes.ok) throw new Error('GitHub publish failed');

        // Update database status
        await fetch(apiBase + '/articles-api', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + getToken() },
          body: JSON.stringify({ action: 'save', article: { slug, status: 'published', published_at: new Date().toISOString() } }),
        });

        status.textContent = 'Published to GitHub! Vercel will rebuild in ~60 seconds.';
        status.style.display = 'block';
        btn.textContent = 'Published';
      } catch (err) {
        error.textContent = 'Publish failed: ' + err.message;
        error.style.display = 'block';
        btn.textContent = 'Publish to GitHub';
      } finally {
        btn.disabled = false;
      }
    });

    // ─── Delete from GitHub ───
    document.getElementById('deleteGitHubBtn')?.addEventListener('click', async () => {
      if (!await styledConfirm('Delete article', 'Permanently delete this article? This removes it from GitHub, the database, and cleans up illustrations and narration files.', 'Delete', true)) return;
      const btn = document.getElementById('deleteGitHubBtn');
      const status = document.getElementById('deleteStatus');
      const error = document.getElementById('deleteError');
      btn.textContent = 'Deleting...'; btn.disabled = true;
      error.style.display = 'none'; status.style.display = 'none';

      try {
        const res = await fetch(apiBase + '/delete-article', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + getToken() },
          body: JSON.stringify({ slug }),
        });
        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error(data.error || 'Delete failed');
        }
        status.textContent = 'Article fully deleted (GitHub + database + storage). Vercel will rebuild shortly.';
        status.style.display = 'block';
        btn.textContent = 'Deleted';
      } catch (err) {
        error.textContent = 'Delete failed: ' + err.message;
        error.style.display = 'block';
        btn.textContent = 'Delete Article';
        btn.disabled = false;
      }
    });

    // ─── Tab switching with ARIA ───
    var editTabs = Array.from(document.querySelectorAll('.admin-tab[role="tab"]'));
    function activateEditTab(tab) {
      editTabs.forEach(function(t) { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); t.setAttribute('tabindex', '-1'); });
      document.querySelectorAll('.admin-tab-panel').forEach(function(p) { p.style.display = 'none'; });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');
      tab.setAttribute('tabindex', '0');
      var panel = document.getElementById('tab-' + tab.dataset.tab);
      if (panel) { panel.style.display = 'block'; }
    }
    editTabs.forEach(function(tab, idx) {
      tab.addEventListener('click', function() { activateEditTab(tab); });
      tab.addEventListener('keydown', function(e) {
        var next = -1;
        if (e.key === 'ArrowRight') next = (idx + 1) % editTabs.length;
        else if (e.key === 'ArrowLeft') next = (idx - 1 + editTabs.length) % editTabs.length;
        else if (e.key === 'Home') next = 0;
        else if (e.key === 'End') next = editTabs.length - 1;
        if (next >= 0) { e.preventDefault(); editTabs[next].focus(); activateEditTab(editTabs[next]); }
      });
    });

    // ─── Get active tab ───
    function getActiveTab() {
      const active = document.querySelector('.admin-tab.active');
      return active ? active.dataset.tab : 'metadata';
    }

    // ─── Keyboard shortcut: Cmd+S / Ctrl+S ───
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 's') {
        e.preventDefault();
        if (autosaveTimer) { clearTimeout(autosaveTimer); autosaveTimer = null; }

        const tab = getActiveTab();
        if (tab === 'metadata') {
          document.getElementById('saveMetaBtn')?.click();
        } else if (tab === 'content') {
          document.getElementById('saveContentBtn')?.click();
        } else if (tab === 'refine') {
          const saveRefine = document.getElementById('saveRefineBtn');
          if (saveRefine && !saveRefine.disabled) saveRefine.click();
        }
      }
    });

    // Word count
    function updateWordCount() {
      const html = document.getElementById('contentHtml')?.value || '';
      const wc = html.replace(/<[^>]*>/g, '').split(/\s+/).filter(Boolean).length;
      const el = document.getElementById('contentWordCount');
      if (el) el.textContent = wc + ' words';
    }
    updateWordCount();
    document.getElementById('contentHtml')?.addEventListener('input', updateWordCount);

    // ─── Preview content in iframe ───
    function updatePreview(html) {
      const frame = document.getElementById('previewFrame');
      frame.srcdoc = '<!DOCTYPE html><html><head><meta charset="UTF-8"/><link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:wght@400;600&family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet"/><style>*{margin:0;padding:0;box-sizing:border-box}body{font-family:"Crimson Pro",serif;color:#1b1a18;background:#e7e6e3;padding:2rem;max-width:720px;margin:0 auto;font-size:1.125rem;line-height:1.8}h1,h2,h3{font-family:"Playfair Display",serif;margin:2rem 0 1rem;line-height:1.3}h1{font-size:2.25rem}h2{font-size:1.5rem}p{margin-bottom:1rem}ul,ol{margin:1rem 0;padding-left:1.5rem}li{margin-bottom:.5rem}strong{font-weight:600}.pull-quote{border-left:3px solid #dc2626;padding:1rem 1.5rem;margin:2rem 0;background:rgba(220,38,38,.05);font-style:italic;font-size:1.15rem;font-family:"Playfair Display",serif}.info-card{background:#fef2f2;border:1px solid #fecaca;border-radius:.75rem;padding:1.5rem;margin:2rem 0}.info-card h4{font-family:"Playfair Display",serif;font-size:1.125rem;color:#b91c1c;margin-bottom:.75rem}.info-card ul{font-size:.875rem}section{margin-bottom:1.5rem}.hero{text-align:center;padding:2rem 0 3rem;border-bottom:1px solid #d6d3d1;margin-bottom:2rem}.cat{display:inline-block;padding:.25rem .75rem;background:#fef2f2;color:#dc2626;border-radius:1rem;font-family:Inter,sans-serif;font-size:.6875rem;text-transform:uppercase;letter-spacing:.05em;font-weight:600;margin-bottom:1rem}.meta{font-family:Inter,sans-serif;font-size:.8125rem;color:#78716c;margin-top:.75rem}</style></head><body><div class="hero"><span class="cat">' + esc(articleData.category) + '</span><h1>' + esc(articleData.title) + '</h1><div class="meta">' + esc(articleData.read_time) + ' min read</div></div>' + html + '</body></html>';
    }

    document.getElementById('previewContentBtn')?.addEventListener('click', () => {
      const html = document.getElementById('contentHtml').value;
      updatePreview(html);
    });

    // ─── Save metadata ───
    document.getElementById('editForm')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (autosaveTimer) { clearTimeout(autosaveTimer); autosaveTimer = null; }

      const btn = document.getElementById('saveMetaBtn');
      const status = document.getElementById('metaStatus');
      const error = document.getElementById('metaError');
      btn.textContent = 'Saving...'; btn.disabled = true;
      error.style.display = 'none'; status.style.display = 'none';

      try {
        await doSaveMetadata();
        status.textContent = 'Metadata saved to database.'; status.style.display = 'block';
        showAutosave('saved', 'Saved');
        btn.textContent = 'Saved';
        setTimeout(() => { btn.textContent = 'Save Metadata'; }, 3000);
        setTimeout(() => { status.style.display = 'none'; }, 4000);
      } catch (err) {
        error.textContent = err.message; error.style.display = 'block';
        showAutosave('error', 'Save failed');
      } finally { btn.disabled = false; }
    });

    // ─── Save content ───
    document.getElementById('saveContentBtn')?.addEventListener('click', async () => {
      if (autosaveTimer) { clearTimeout(autosaveTimer); autosaveTimer = null; }

      const btn = document.getElementById('saveContentBtn');
      const status = document.getElementById('contentStatus');
      const error = document.getElementById('contentError');
      btn.textContent = 'Saving...'; btn.disabled = true;
      error.style.display = 'none'; status.style.display = 'none';

      try {
        await doSaveContent();
        status.textContent = 'Content saved to database.'; status.style.display = 'block';
        showAutosave('saved', 'Saved');
        btn.textContent = 'Saved';
        setTimeout(() => { btn.textContent = 'Save Content'; }, 3000);
        setTimeout(() => { status.style.display = 'none'; }, 4000);
        updatePreview(currentHtml);
      } catch (err) {
        error.textContent = err.message; error.style.display = 'block';
        showAutosave('error', 'Save failed');
      } finally { btn.disabled = false; }
    });

    // ─── AI Refine ───
    const refineMessages = [];

    async function sendRefine(instruction) {
      if (!instruction?.trim()) return;
      const messagesEl = document.getElementById('refineMessages');
      const sendBtn = document.getElementById('refineSendBtn');
      const saveBtn = document.getElementById('saveRefineBtn');
      const input = document.getElementById('refineInput');

      messagesEl.appendChild(createChatMsg(instruction, 'user'));
      messagesEl.appendChild(createSpinnerMsg('refineSpinner'));
      messagesEl.scrollTop = messagesEl.scrollHeight;
      refineMessages.push({ role: 'user', content: instruction });
      if (input) input.value = '';
      sendBtn.disabled = true;

      try {
        const res = await fetch(apiBase + '/refine-article', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + getToken() },
          body: JSON.stringify({
            currentHtml: currentHtml,
            currentMetadata: articleData,
            messages: refineMessages.slice(-6),
            instruction,
          }),
        });
        if (!res.ok) throw new Error('Refine failed');

        const data = await res.json();
        document.getElementById('refineSpinner')?.remove();

        if (data.html) {
          currentHtml = data.html;
          suppressAutosave = true;
          document.getElementById('contentHtml').value = currentHtml;
          suppressAutosave = false;
          updateWordCount();
          updatePreview(currentHtml);
          saveBtn.disabled = false;
        }

        const msg = data.message || 'Article updated. Click "Save Refined Article" to keep changes.';
        messagesEl.appendChild(createChatMsg(msg, 'assistant'));
        refineMessages.push({ role: 'assistant', content: msg });
        messagesEl.scrollTop = messagesEl.scrollHeight;
      } catch (err) {
        document.getElementById('refineSpinner')?.remove();
        messagesEl.appendChild(createChatMsg('Error: ' + err.message, 'system'));
      } finally {
        sendBtn.disabled = false;
      }
    }

    document.getElementById('refineSendBtn')?.addEventListener('click', () => {
      sendRefine(document.getElementById('refineInput')?.value);
    });
    document.getElementById('refineInput')?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') { e.preventDefault(); sendRefine(e.target.value); }
    });
    document.querySelectorAll('#refineTemplates .admin-template-btn').forEach(btn => {
      btn.addEventListener('click', () => sendRefine(btn.dataset.prompt));
    });

    // Save refined article to database
    document.getElementById('saveRefineBtn')?.addEventListener('click', async () => {
      const btn = document.getElementById('saveRefineBtn');
      const status = document.getElementById('refineStatus');
      btn.textContent = 'Saving...'; btn.disabled = true;

      try {
        const res = await fetch(apiBase + '/articles-api', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + getToken() },
          body: JSON.stringify({
            action: 'save',
            article: { slug, article_html: currentHtml }
          }),
        });
        if (!res.ok) throw new Error('Save failed');
        status.textContent = 'Refined article saved to database.'; status.style.display = 'block';
        showAutosave('saved', 'Saved');
        btn.textContent = 'Saved'; setTimeout(() => { btn.textContent = 'Save Refined Article'; btn.disabled = true; }, 3000);
        updatePreview(currentHtml);
      } catch (err) {
        const error = document.getElementById('refineError');
        if (error) { error.textContent = 'Save failed: ' + err.message; error.style.display = 'block'; }
        btn.disabled = false;
      }
    });
  </script>
</body>
</html>
