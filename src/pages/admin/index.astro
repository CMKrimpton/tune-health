---
export const prerender = false;
import PipelineMonitor from '../../components/admin/PipelineMonitor';
import ArticlesManager from '../../components/admin/ArticlesManager';
import AgentsPanel from '../../components/admin/AgentsPanel';
import SocialDashboard from '../../components/admin/SocialDashboard';

const edgeFunctionBase = (process.env.PUBLIC_SUPABASE_URL || import.meta.env.PUBLIC_SUPABASE_URL || '').trim();
const apiBase = edgeFunctionBase ? `${edgeFunctionBase}/functions/v1` : '';

// ─── Fetch articles ───
interface ArticleRecord {
  slug: string; title: string; description: string; category: string;
  tags: string[]; featured: boolean; article_html: string; hero_image: string;
  read_time: number; publish_date: string; updated_at: string; status: string;
  coming_soon: boolean; draft: boolean; gradient_from: string; gradient_to: string;
  keywords: string[]; hero_image_alt: string; sort_order: number;
  narration_url: string | null;
}

let articles: ArticleRecord[] = [];
let fetchError = '';
try {
  const res = await fetch(`${apiBase}/articles-api`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ action: 'list' }),
  });
  if (res.ok) articles = await res.json();
  else fetchError = `API returned ${res.status}`;
} catch (e) {
  fetchError = e instanceof Error ? e.message : 'Failed to connect';
}

// ─── Fetch pipeline status ───
let pipelineLogs: unknown[] = [];
let articleCount = articles.length;
let totalCost = 0;
try {
  const res = await fetch(`${apiBase}/pipeline-admin`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ action: 'status' }),
  });
  if (res.ok) {
    const data = await res.json();
    pipelineLogs = data.logs || [];
    articleCount = data.articleCount ?? articles.length;
    totalCost = data.totalCost ?? 0;
  }
} catch {
  // Non-fatal — pipeline monitor will poll on client
}

// ─── Stats ───
const published = articles.filter(a => a.status === 'published' && !a.coming_soon);
const drafts = articles.filter(a => a.status === 'draft' && !a.coming_soon);
const withIllustration = articles.filter(a => a.hero_image);
const withNarration = articles.filter(a => a.narration_url);
const featuredCount = published.filter(a => a.featured).length;
const avgReadTime = articles.length > 0 ? Math.round(articles.reduce((s, a) => s + (a.read_time || 0), 0) / articles.length) : 0;
const avgCostPerArticle = published.length > 0 && totalCost > 0 ? (totalCost / published.length).toFixed(2) : '—';

// Determine categories count
const uniqueCategories = new Set(articles.map(a => a.category).filter(Boolean));
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Mission Control | alumi news</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/admin.css" />
</head>
<body class="admin-body">
  <header class="admin-header">
    <div class="admin-header-inner">
      <div class="admin-logo">
        <span class="admin-logo-accent">a</span>lumi
        <span class="admin-logo-badge">mission control</span>
      </div>
      <nav class="admin-nav">
        <a href="/admin" class="admin-nav-link active">Dashboard</a>
        <a href="/admin/new" class="admin-nav-link">New Article</a>
        <a href="/admin/social-preview" class="admin-nav-link">Social Preview</a>
        <a href="/" class="admin-nav-link" target="_blank">View Site &rarr;</a>
        <button id="logoutBtn" class="admin-nav-link" style="border:none;background:none;cursor:pointer;font-family:inherit;font-size:inherit;color:inherit">Logout</button>
      </nav>
    </div>
  </header>

  <main class="admin-main">
    {fetchError && (
      <div class="admin-toast admin-toast-error">
        <span><strong>Database error:</strong> {fetchError}</span>
      </div>
    )}

    <!-- Stats Strip -->
    <div class="admin-stats">
      <div class="admin-stat-card">
        <span class="admin-stat-number">{articleCount}</span>
        <span class="admin-stat-label">Total</span>
      </div>
      <div class="admin-stat-card">
        <span class="admin-stat-number" style="color: var(--admin-green)">{published.length}</span>
        <span class="admin-stat-label">Published</span>
      </div>
      <div class="admin-stat-card">
        <span class="admin-stat-number" style={drafts.length > 0 ? "color: var(--admin-yellow)" : ""}>{drafts.length}</span>
        <span class="admin-stat-label">Drafts</span>
      </div>
      <div class="admin-stat-card">
        <span class="admin-stat-number" style="color: var(--admin-accent)">{featuredCount}</span>
        <span class="admin-stat-label">Featured</span>
      </div>
      <div class="admin-stat-card">
        <span class="admin-stat-number" style={withIllustration.length < articles.length ? "color: var(--admin-yellow)" : "color: var(--admin-green)"}>{withIllustration.length}</span>
        <span class="admin-stat-label">Illustrated</span>
      </div>
      <div class="admin-stat-card">
        <span class="admin-stat-number" style={withNarration.length < articles.length ? "color: var(--admin-yellow)" : "color: var(--admin-green)"}>{withNarration.length}</span>
        <span class="admin-stat-label">Narrated</span>
      </div>
      <div class="admin-stat-card">
        <span class="admin-stat-number">{avgReadTime}m</span>
        <span class="admin-stat-label">Avg Read</span>
      </div>
      <div class="admin-stat-card">
        <span class="admin-stat-number" style={totalCost > 50 ? "color: var(--admin-red-light)" : totalCost > 20 ? "color: var(--admin-yellow)" : ""}>${totalCost > 0 ? totalCost.toFixed(2) : '—'}</span>
        <span class="admin-stat-label">Pipeline Spend</span>
      </div>
      <div class="admin-stat-card">
        <span class="admin-stat-number">${avgCostPerArticle}</span>
        <span class="admin-stat-label">$/Article</span>
      </div>
    </div>

    <!-- Tab Navigation -->
    <div class="admin-dashboard-tabs" role="tablist" aria-label="Dashboard sections">
      <button class="admin-dashboard-tab active" data-tab="pipeline" role="tab" aria-selected="true" aria-controls="tab-pipeline" id="tab-btn-pipeline">Pipeline</button>
      <button class="admin-dashboard-tab" data-tab="articles" role="tab" aria-selected="false" aria-controls="tab-articles" id="tab-btn-articles">Articles</button>
      <button class="admin-dashboard-tab" data-tab="agents" role="tab" aria-selected="false" aria-controls="tab-agents" id="tab-btn-agents">AI Agents</button>
      <button class="admin-dashboard-tab" data-tab="social" role="tab" aria-selected="false" aria-controls="tab-social" id="tab-btn-social">Social</button>
    </div>

    <!-- Pipeline Tab -->
    <div id="tab-pipeline" class="admin-tab-panel active" role="tabpanel" aria-labelledby="tab-btn-pipeline">
      <PipelineMonitor
        client:only="react"
        initialLogs={[]}
        initialArticleCount={articleCount}
        apiBase={apiBase}
        initialTotalCost={totalCost}
      />
    </div>

    <!-- Articles Tab -->
    <div id="tab-articles" class="admin-tab-panel" role="tabpanel" aria-labelledby="tab-btn-articles">
      <ArticlesManager
        client:only="react"
        initialArticles={[]}
        apiBase={apiBase}
      />
    </div>

    <!-- AI Agents Tab -->
    <div id="tab-agents" class="admin-tab-panel" role="tabpanel" aria-labelledby="tab-btn-agents">
      <AgentsPanel
        client:only="react"
        apiBase={apiBase}
        initialArticleCount={articleCount}
      />
    </div>

    <!-- Social Tab -->
    <div id="tab-social" class="admin-tab-panel" role="tabpanel" aria-labelledby="tab-btn-social">
      <SocialDashboard
        client:only="react"
        apiBase={apiBase}
      />
    </div>
  </main>

  <script is:inline>
    // Tab switching with ARIA
    try {
      var allTabs = Array.from(document.querySelectorAll('.admin-dashboard-tab'));
      function activateTab(btn) {
        allTabs.forEach(function(b) { b.classList.remove('active'); b.setAttribute('aria-selected', 'false'); b.setAttribute('tabindex', '-1'); });
        document.querySelectorAll('.admin-tab-panel').forEach(function(p) { p.classList.remove('active'); });
        btn.classList.add('active');
        btn.setAttribute('aria-selected', 'true');
        btn.setAttribute('tabindex', '0');
        var tab = btn.getAttribute('data-tab');
        var panel = document.getElementById('tab-' + tab);
        if (panel) panel.classList.add('active');
        if (tab) window.history.replaceState(null, '', '#' + tab);
      }
      allTabs.forEach(function(btn, idx) {
        btn.addEventListener('click', function() { activateTab(btn); });
        btn.addEventListener('keydown', function(e) {
          var next = -1;
          if (e.key === 'ArrowRight') next = (idx + 1) % allTabs.length;
          else if (e.key === 'ArrowLeft') next = (idx - 1 + allTabs.length) % allTabs.length;
          else if (e.key === 'Home') next = 0;
          else if (e.key === 'End') next = allTabs.length - 1;
          if (next >= 0) { e.preventDefault(); allTabs[next].focus(); activateTab(allTabs[next]); }
        });
        // Only the active tab is in tab order
        if (!btn.classList.contains('active')) btn.setAttribute('tabindex', '-1');
      });

      // Logout
      var logoutBtn = document.getElementById('logoutBtn');
      if (logoutBtn) {
        logoutBtn.addEventListener('click', function() {
          document.cookie = 'admin_token=; path=/; expires=Thu, 01 Jan 1970 00:00:00 GMT';
          window.location.href = '/admin/login';
        });
      }

      // URL hash → tab restore
      var hash = window.location.hash.replace('#', '');
      if (hash) {
        var tabBtn = document.querySelector('.admin-dashboard-tab[data-tab="' + hash + '"]');
        if (tabBtn) tabBtn.click();
      }
    } catch(e) { console.error('Tab init error:', e); }
  </script>
</body>
</html>
