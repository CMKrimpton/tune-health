---
export const prerender = false;
import PipelineMonitor from '../../components/admin/PipelineMonitor';
import ArticlesManager from '../../components/admin/ArticlesManager';
import AgentsPanel from '../../components/admin/AgentsPanel';

const edgeFunctionBase = (process.env.PUBLIC_SUPABASE_URL || import.meta.env.PUBLIC_SUPABASE_URL || '').trim();
const apiBase = edgeFunctionBase ? `${edgeFunctionBase}/functions/v1` : '';

// ─── Fetch articles ───
interface ArticleRecord {
  slug: string; title: string; description: string; category: string;
  tags: string[]; featured: boolean; article_html: string; hero_image: string;
  read_time: number; publish_date: string; updated_at: string; status: string;
  coming_soon: boolean; draft: boolean; gradient_from: string; gradient_to: string;
  keywords: string[]; hero_image_alt: string; sort_order: number;
}

let articles: ArticleRecord[] = [];
let fetchError = '';
try {
  const res = await fetch(`${apiBase}/articles-api`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ action: 'list' }),
  });
  if (res.ok) articles = await res.json();
  else fetchError = `API returned ${res.status}`;
} catch (e) {
  fetchError = e instanceof Error ? e.message : 'Failed to connect';
}

// ─── Fetch pipeline status ───
let pipelineLogs: unknown[] = [];
let articleCount = articles.length;
let totalCost = 0;
try {
  const res = await fetch(`${apiBase}/pipeline-admin`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ action: 'status' }),
  });
  if (res.ok) {
    const data = await res.json();
    pipelineLogs = data.logs || [];
    articleCount = data.articleCount ?? articles.length;
    totalCost = data.totalCost ?? 0;
  }
} catch {
  // Non-fatal — pipeline monitor will poll on client
}

// ─── Stats ───
const published = articles.filter(a => a.status === 'published' && !a.coming_soon);
const drafts = articles.filter(a => a.status === 'draft' && !a.coming_soon);
const withIllustration = articles.filter(a => a.hero_image);
const featuredCount = published.filter(a => a.featured).length;
const avgReadTime = articles.length > 0 ? Math.round(articles.reduce((s, a) => s + (a.read_time || 0), 0) / articles.length) : 0;
const avgCostPerArticle = published.length > 0 && totalCost > 0 ? (totalCost / published.length).toFixed(2) : '—';

// Determine categories count
const uniqueCategories = new Set(articles.map(a => a.category).filter(Boolean));
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mission Control | alumi news</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/admin.css" />
</head>
<body class="admin-body">
  <header class="admin-header">
    <div class="admin-header-inner">
      <div class="admin-logo">
        <span class="admin-logo-accent">a</span>lumi
        <span class="admin-logo-badge">mission control</span>
      </div>
      <nav class="admin-nav">
        <a href="/admin" class="admin-nav-link active">Dashboard</a>
        <a href="/admin/new" class="admin-nav-link">New Article</a>
        <a href="/" class="admin-nav-link" target="_blank">View Site &rarr;</a>
        <button id="logoutBtn" class="admin-nav-link" style="border:none;background:none;cursor:pointer;font-family:inherit;font-size:inherit;color:inherit">Logout</button>
      </nav>
    </div>
  </header>

  <main class="admin-main">
    {fetchError && (
      <div style="background:rgba(239,68,68,0.08); border:1px solid rgba(239,68,68,0.2); border-radius:10px; padding:0.75rem 1rem; margin-bottom:1rem; font-size:0.8125rem; color:#fca5a5; display:flex; align-items:center; gap:0.5rem">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span><strong>Database error:</strong> {fetchError}</span>
      </div>
    )}

    <!-- Stats Row — 4 columns, 2 rows -->
    <div class="admin-stats" style="grid-template-columns: repeat(4, 1fr); margin-bottom: 1.5rem">
      <div class="admin-stat-card">
        <span class="admin-stat-number">{articleCount}</span>
        <span class="admin-stat-label">Total</span>
      </div>
      <div class="admin-stat-card">
        <span class="admin-stat-number" style="color: #22c55e">{published.length}</span>
        <span class="admin-stat-label">Published</span>
      </div>
      <div class="admin-stat-card">
        <span class="admin-stat-number" style={drafts.length > 0 ? "color: #f59e0b" : ""}>{drafts.length}</span>
        <span class="admin-stat-label">Drafts</span>
      </div>
      <div class="admin-stat-card">
        <span class="admin-stat-number" style="color: #ef4444">{featuredCount}</span>
        <span class="admin-stat-label">Featured</span>
      </div>
      <div class="admin-stat-card">
        <span class="admin-stat-number" style={withIllustration.length < articles.length ? "color: #f59e0b" : "color: #22c55e"}>{withIllustration.length}</span>
        <span class="admin-stat-label">Illustrated</span>
      </div>
      <div class="admin-stat-card">
        <span class="admin-stat-number">{avgReadTime}m</span>
        <span class="admin-stat-label">Avg Read</span>
      </div>
      <div class="admin-stat-card">
        <span class="admin-stat-number" style={totalCost > 50 ? "color: #f87171" : totalCost > 20 ? "color: #f59e0b" : ""}>${totalCost > 0 ? totalCost.toFixed(2) : '—'}</span>
        <span class="admin-stat-label">Pipeline Spend</span>
      </div>
      <div class="admin-stat-card">
        <span class="admin-stat-number">${avgCostPerArticle}</span>
        <span class="admin-stat-label">$/Article</span>
      </div>
    </div>

    <!-- Tab Navigation -->
    <div class="admin-dashboard-tabs">
      <button class="admin-dashboard-tab active" data-tab="pipeline">Pipeline</button>
      <button class="admin-dashboard-tab" data-tab="articles">Articles</button>
      <button class="admin-dashboard-tab" data-tab="agents">AI Agents</button>
    </div>

    <!-- Pipeline Tab -->
    <div id="tab-pipeline" class="admin-tab-panel active">
      <PipelineMonitor
        client:load
        initialLogs={pipelineLogs}
        initialArticleCount={articleCount}
        apiBase={apiBase}
        initialTotalCost={totalCost}
      />
    </div>

    <!-- Articles Tab -->
    <div id="tab-articles" class="admin-tab-panel">
      <ArticlesManager
        client:load
        initialArticles={articles}
        apiBase={apiBase}
      />
    </div>

    <!-- AI Agents Tab -->
    <div id="tab-agents" class="admin-tab-panel">
      <AgentsPanel
        client:load
        apiBase={apiBase}
        initialArticleCount={articleCount}
      />
    </div>
  </main>

  <script is:inline>
    // Tab switching
    try {
      document.querySelectorAll('.admin-dashboard-tab').forEach(function(btn) {
        btn.addEventListener('click', function() {
          document.querySelectorAll('.admin-dashboard-tab').forEach(function(b) { b.classList.remove('active'); });
          document.querySelectorAll('.admin-tab-panel').forEach(function(p) { p.classList.remove('active'); });
          btn.classList.add('active');
          var tab = btn.getAttribute('data-tab');
          var panel = document.getElementById('tab-' + tab);
          if (panel) panel.classList.add('active');
          if (tab) window.history.replaceState(null, '', '#' + tab);
        });
      });

      // Logout
      var logoutBtn = document.getElementById('logoutBtn');
      if (logoutBtn) {
        logoutBtn.addEventListener('click', function() {
          document.cookie = 'admin_token=; path=/; expires=Thu, 01 Jan 1970 00:00:00 GMT';
          window.location.href = '/admin/login';
        });
      }

      // URL hash → tab restore
      var hash = window.location.hash.replace('#', '');
      if (hash) {
        var tabBtn = document.querySelector('.admin-dashboard-tab[data-tab="' + hash + '"]');
        if (tabBtn) tabBtn.click();
      }
    } catch(e) { console.error('Tab init error:', e); }
  </script>
</body>
</html>
