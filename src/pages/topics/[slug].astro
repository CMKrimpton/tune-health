---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Newsletter from '../../components/Newsletter.astro';
import CommandPaletteWrapper from '../../components/CommandPaletteWrapper.astro';
import SideNav from '../../components/SideNav.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import { getArticlesForCategory, getArticleGradientStyle, formatPublishDateShort, isNewArticle } from '../../utils/articles';
import { CATEGORY_DOMAINS, CATEGORY_META, getCategorySlug, getCategoryFromSlug, getDomainForCategory } from '../../utils/category-domains';
import SEO from '../../components/SEO.astro';

const { slug } = Astro.params;
const category = getCategoryFromSlug(slug || '');
if (!category) return new Response(null, { status: 404, headers: { Location: '/404' } });
const articles = await getArticlesForCategory(category);
const meta = CATEGORY_META[category];
const domain = getDomainForCategory(category);
const featuredArticle = articles[0];
const gridArticles = articles.slice(1);

// Related topics from same domain (excluding current)
const relatedTopics = domain
  ? domain.categories.filter(c => c !== category)
  : [];
---

<BaseLayout
  title={`${category} | alumi news`}
  description={meta?.description || `${category} articles from alumi news.`}
>
  <!-- CollectionPage + BreadcrumbList JSON-LD -->
  <SEO
    slot="head"
    type="collection"
    collection={{
      title: category,
      description: meta?.description || `${category} articles from alumi news.`,
      breadcrumbs: [
        { label: 'Home', href: '/' },
        { label: 'Topics', href: '/topics' },
        { label: category, href: `/topics/${getCategorySlug(category)}` },
      ],
      articleCount: articles.length,
    }}
  />

  <Header slot="header" />

  <!-- Hero -->
  <section class="topic-hero" style={getArticleGradientStyle(category)}>
    <div class="container-editorial relative z-10">
      <div class="max-w-2xl">
        {domain && (
          <span class="inline-flex items-center gap-1.5 text-white/60 text-xs font-medium uppercase tracking-widest mb-4">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d={domain.iconPath} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {domain.label}
          </span>
        )}
        <h1 class="font-serif text-display-2 font-semibold text-white mb-3 leading-tight">{category}</h1>
        {meta && (
          <>
            <p class="text-lg text-white/80 font-medium italic mb-4">{meta.tagline}</p>
            <p class="font-body text-white/70 leading-relaxed max-w-lg">{meta.description}</p>
          </>
        )}
        <div class="flex items-center gap-6 mt-6">
          <span class="text-sm text-white/50 font-medium">{articles.length} articles</span>
          <div class="topic-share flex items-center gap-2">
            <span class="text-xs text-white/40 uppercase tracking-widest">Share</span>
            <ShareButtons
              title={`${category} — alumi news`}
              url={`/topics/${getCategorySlug(category)}`}
              description={meta?.description || `${category} articles from alumi news.`}
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Breadcrumbs -->
  <div class="container-editorial pt-6">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Articles', href: '/articles' },
      { label: category },
    ]} />
  </div>

  <!-- Featured Article -->
  {featuredArticle && (
    <section class="py-10 md:py-14">
      <div class="container-editorial">
        <a href={featuredArticle.href} class="group block">
          <div class="grid lg:grid-cols-2 gap-6 bg-white dark:bg-stone-900 rounded-2xl overflow-hidden border border-stone-200 dark:border-stone-800 transition-[border-color,box-shadow] duration-300 hover:shadow-lg hover:border-stone-300 dark:hover:border-stone-700">
            <div class="relative aspect-[3/2] overflow-hidden hero-img-wrap" style={featuredArticle.heroImage ? undefined : getArticleGradientStyle(category)}>
              {featuredArticle.heroImage && featuredArticle.heroImageLight ? (
                <>
                  <img src={featuredArticle.heroImage} alt={featuredArticle.heroImageAlt || featuredArticle.title} class="w-full h-full object-cover hidden dark:block" loading="eager" />
                  <img src={featuredArticle.heroImageLight} alt={featuredArticle.heroImageAlt || featuredArticle.title} class="w-full h-full object-cover dark:hidden" loading="eager" />
                </>
              ) : featuredArticle.heroImage ? (
                <img src={featuredArticle.heroImage} alt={featuredArticle.heroImageAlt || featuredArticle.title} class="w-full h-full object-cover" loading="eager" />
              ) : null}
              {isNewArticle(featuredArticle.publishDate) && (
                <span class="absolute top-3 left-3 card-badge card-badge-new">New</span>
              )}
            </div>
            <div class="p-6 lg:p-8 flex flex-col justify-center">
              <div class="flex items-center gap-2 text-xs font-medium uppercase tracking-widest mb-4">
                <span class="text-primary-600">{featuredArticle.readTime} min read</span>
                <span class="text-stone-300 dark:text-stone-600">/</span>
                <span class="text-stone-500">{formatPublishDateShort(featuredArticle.publishDate)}</span>
              </div>
              <h2 class="font-serif text-heading-2 font-semibold mb-3 group-hover:text-primary-600 transition-colors leading-tight">{featuredArticle.title}</h2>
              <p class="font-body text-stone-600 dark:text-stone-400 leading-relaxed line-clamp-3">{featuredArticle.description}</p>
              <span class="inline-flex items-center gap-2 mt-6 font-semibold text-sm text-primary-600 group-hover:gap-3 transition-[gap]">
                Read Article
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7" stroke-width="2"/></svg>
              </span>
            </div>
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- Article Grid -->
  {gridArticles.length > 0 && (
    <section class="py-10 md:py-14 bg-stone-50 dark:bg-stone-900/30">
      <div class="container-editorial">
        <div class="flex items-center justify-between mb-8">
          <div class="flex items-center gap-6">
            <span class="section-label">All Articles</span>
            <div class="flex-1 h-px bg-stone-200 dark:bg-stone-800"></div>
          </div>
          <div class="sort-dropdown" id="topicSortDropdown">
            <button class="sort-dropdown-trigger" aria-haspopup="listbox" aria-expanded="false" aria-label="Sort articles">
              <span class="sort-dropdown-label">Newest</span>
              <svg class="sort-dropdown-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M6 9l6 6 6-6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <ul class="sort-dropdown-menu" role="listbox">
              <li role="option" data-value="newest" class="sort-dropdown-option active">Newest</li>
              <li role="option" data-value="oldest" class="sort-dropdown-option">Oldest</li>
              <li role="option" data-value="shortest" class="sort-dropdown-option">Shortest</li>
              <li role="option" data-value="longest" class="sort-dropdown-option">Longest</li>
              <li role="option" data-value="az" class="sort-dropdown-option">A — Z</li>
            </ul>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="topicGrid">
          {gridArticles.map((article) => (
            <a href={article.href} class="topic-grid-card group block" data-read-time={article.readTime} data-date={article.sortOrder || new Date(article.publishDate).getTime()} data-title={article.title.toLowerCase()}>
              <div class="bg-white dark:bg-stone-900 rounded-2xl overflow-hidden border border-stone-200 dark:border-stone-800 transition-[border-color,box-shadow] duration-300 hover:shadow-lg hover:border-stone-300 dark:hover:border-stone-700 h-full flex flex-col">
                <div class="relative aspect-[3/2] overflow-hidden hero-img-wrap" style={article.heroImage ? undefined : getArticleGradientStyle(category)}>
                  {article.heroImage && article.heroImageLight ? (
                    <>
                      <img src={article.heroImage} alt={article.heroImageAlt || article.title} class="w-full h-full object-cover hidden dark:block" loading="lazy" />
                      <img src={article.heroImageLight} alt={article.heroImageAlt || article.title} class="w-full h-full object-cover dark:hidden" loading="lazy" />
                    </>
                  ) : article.heroImage ? (
                    <img src={article.heroImage} alt={article.heroImageAlt || article.title} class="w-full h-full object-cover" loading="lazy" />
                  ) : null}
                  {isNewArticle(article.publishDate) && (
                    <span class="absolute top-2.5 left-2.5 card-badge card-badge-new">New</span>
                  )}
                  {article.narrationUrl && (
                    <span class="absolute top-2.5 right-2.5 card-badge card-badge-narration" title="Audio narration">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M15.536 8.464a5 5 0 010 7.072M18.364 5.636a9 9 0 010 12.728M12 12h.01M11 7.5V4a1 1 0 00-1.707-.707L5.586 7H4a1 1 0 00-1 1v8a1 1 0 001 1h1.586l3.707 3.707A1 1 0 0011 20v-3.5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                  )}
                </div>
                <div class="p-5 flex flex-col flex-1">
                  <div class="flex items-center gap-2 mb-2">
                    <span class="text-xs text-stone-400">{formatPublishDateShort(article.publishDate)}</span>
                    <span class="text-xs text-stone-400">·</span>
                    <span class="text-xs text-stone-400">{article.readTime} min</span>
                  </div>
                  <h3 class="font-serif text-lg font-semibold mb-2 group-hover:text-primary-600 transition-colors leading-snug line-clamp-2">{article.title}</h3>
                  <p class="font-body text-base text-stone-500 dark:text-stone-400 line-clamp-2 flex-1">{article.description}</p>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Related Topics -->
  {relatedTopics.length > 0 && (
    <section class="py-10 md:py-14">
      <div class="container-editorial">
        <div class="flex items-center gap-6 mb-6">
          <span class="section-label">Related Topics</span>
          <div class="flex-1 h-px bg-stone-200 dark:bg-stone-800"></div>
        </div>
        <div class="flex flex-wrap gap-3 max-w-2xl">
          {relatedTopics.map((topic) => (
            <a href={`/topics/${getCategorySlug(topic)}`} class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full border border-stone-200 dark:border-stone-700 text-sm font-medium text-stone-600 dark:text-stone-400 hover:border-primary-300 hover:text-primary-600 dark:hover:border-primary-700 dark:hover:text-primary-400 transition-colors duration-200 bg-white dark:bg-stone-900">
              {topic}
              <svg class="w-3.5 h-3.5 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M9 5l7 7-7 7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <Newsletter variant="compact" />

  <Footer slot="footer" />
  <CommandPaletteWrapper />
  <SideNav />
</BaseLayout>

<style>
  .topic-hero {
    @apply pt-32 md:pt-36 pb-12 md:pb-16 relative;
  }

  .topic-hero::after {
    content: '';
    @apply absolute inset-0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.4) 100%);
  }

  /* Share buttons in dark hero */
  .topic-share :global(.share-btn) {
    color: rgba(255, 255, 255, 0.55);
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.12);
  }

  .topic-share :global(.share-btn:hover) {
    color: #fff;
    background: rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.25);
  }

  /* ─── Glass Sort Dropdown ─── */
  .sort-dropdown {
    position: relative;
  }

  .sort-dropdown-trigger {
    @apply flex items-center gap-2 px-4 py-2 text-sm font-medium;
    @apply bg-white dark:bg-stone-800;
    @apply border border-stone-200 dark:border-stone-700;
    @apply rounded-full cursor-pointer;
    @apply text-stone-700 dark:text-stone-300;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .sort-dropdown-trigger:hover {
    @apply border-stone-300 dark:border-stone-600;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .sort-dropdown-chevron {
    @apply w-4 h-4 text-stone-400;
    transition: transform 0.2s ease;
  }

  .sort-dropdown.open .sort-dropdown-chevron {
    transform: rotate(180deg);
  }

  .sort-dropdown-menu {
    @apply absolute right-0 mt-2 z-50;
    @apply bg-white/95 dark:bg-stone-900/95 backdrop-blur-md;
    @apply border border-stone-200/60 dark:border-stone-700/60;
    @apply rounded-xl overflow-hidden;
    @apply opacity-0 invisible;
    min-width: 160px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1), 0 2px 8px rgba(0, 0, 0, 0.06);
    transform: translateY(-4px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
    list-style: none;
    padding: 0.25rem;
    margin: 0;
  }

  :global(.dark) .sort-dropdown-menu {
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3), 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  .sort-dropdown.open .sort-dropdown-menu {
    @apply opacity-100 visible;
    transform: translateY(0);
  }

  .sort-dropdown-option {
    @apply px-3 py-2 text-sm cursor-pointer;
    @apply text-stone-600 dark:text-stone-400;
    @apply rounded-lg;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .sort-dropdown-option:hover {
    @apply bg-stone-100 dark:bg-stone-800;
    @apply text-stone-900 dark:text-white;
  }

  .sort-dropdown-option.active {
    @apply text-primary-600 dark:text-primary-400 font-medium;
  }
</style>

<script>
  function initTopicPage() {
    const grid = document.getElementById('topicGrid');
    const dropdown = document.getElementById('topicSortDropdown');
    if (!grid || !dropdown) return;

    const cards = Array.from(grid.querySelectorAll('.topic-grid-card')) as HTMLElement[];
    initSortDropdown(dropdown, (value) => {
      cards.sort((a, b) => {
        switch (value) {
          case 'oldest': return Number(a.dataset.date || 0) - Number(b.dataset.date || 0);
          case 'shortest': return Number(a.dataset.readTime || 0) - Number(b.dataset.readTime || 0);
          case 'longest': return Number(b.dataset.readTime || 0) - Number(a.dataset.readTime || 0);
          case 'az': return (a.dataset.title || '').localeCompare(b.dataset.title || '');
          default: return Number(b.dataset.date || 0) - Number(a.dataset.date || 0);
        }
      });
      cards.forEach(card => grid.appendChild(card));
    });
  }

  function initSortDropdown(dropdown: HTMLElement, onChange: (value: string) => void) {
    const trigger = dropdown.querySelector('.sort-dropdown-trigger') as HTMLButtonElement;
    const menu = dropdown.querySelector('.sort-dropdown-menu') as HTMLElement;
    const label = dropdown.querySelector('.sort-dropdown-label') as HTMLElement;
    const options = dropdown.querySelectorAll('.sort-dropdown-option');
    if (!trigger || !menu || !label) return;

    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = dropdown.classList.toggle('open');
      trigger.setAttribute('aria-expanded', String(isOpen));
    });

    options.forEach(option => {
      option.addEventListener('click', () => {
        const value = (option as HTMLElement).dataset.value || 'newest';
        label.textContent = option.textContent;
        options.forEach(o => o.classList.remove('active'));
        option.classList.add('active');
        dropdown.classList.remove('open');
        trigger.setAttribute('aria-expanded', 'false');
        onChange(value);
      });
    });

    document.addEventListener('click', (e) => {
      if (!dropdown.contains(e.target as Node)) {
        dropdown.classList.remove('open');
        trigger.setAttribute('aria-expanded', 'false');
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && dropdown.classList.contains('open')) {
        dropdown.classList.remove('open');
        trigger.setAttribute('aria-expanded', 'false');
        trigger.focus();
      }
    });
  }

  initTopicPage();
  document.addEventListener('astro:after-swap', initTopicPage);
</script>
