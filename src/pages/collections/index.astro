---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Newsletter from '../../components/Newsletter.astro';
import CommandPaletteWrapper from '../../components/CommandPaletteWrapper.astro';
import SideNav from '../../components/SideNav.astro';
import { getAllCollections } from '../../utils/collections';
import { getArticles } from '../../utils/articles';

const collections = getAllCollections();
const allArticles = await getArticles();
const articleMap = new Map(allArticles.map(a => [a.slug, a]));
---

<BaseLayout
  title="Collections | alumi news"
  description="Curated reading lists on the topics that matter — themed, ordered, and editorially selected."
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="pt-32 md:pt-36 pb-10 md:pb-12 bg-stone-50 dark:bg-stone-950 border-b border-stone-200 dark:border-stone-800">
    <div class="container-editorial">
      <span class="section-label mb-4 block">Curated</span>
      <h1 class="font-serif text-display-2 font-semibold mb-4 leading-tight">
        Collections
      </h1>
      <p class="font-body text-body-lg text-stone-600 dark:text-stone-400 max-w-lg">
        Themed reading lists, editorially ordered. Each collection tells a story across multiple articles.
      </p>
    </div>
  </section>

  <!-- Collections Grid -->
  <section class="py-12 md:py-16">
    <div class="container-editorial">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {collections.map((collection, i) => {
          const articleCount = collection.articleSlugs.filter(s => articleMap.has(s)).length;
          const totalReadTime = collection.articleSlugs.reduce((sum, s) => sum + (articleMap.get(s)?.readTime || 0), 0);
          return (
            <a href={`/collections/${collection.slug}`} class={`group block reveal${i > 0 ? ` reveal-delay-${Math.min(i, 4)}` : ''}`}>
              <div class="h-full rounded-2xl overflow-hidden border border-stone-200 dark:border-stone-800 transition-[border-color,box-shadow] duration-300 hover:shadow-lg hover:border-stone-300 dark:hover:border-stone-700 flex flex-col">
                <div class="aspect-[16/9] relative" style={`background: ${collection.gradient.pattern}, ${collection.gradient.bg};`}>
                  <div class="absolute inset-0 flex items-end p-6">
                    <h2 class="font-serif text-xl font-semibold text-white leading-snug">{collection.title}</h2>
                  </div>
                </div>
                <div class="p-5 flex flex-col flex-1 bg-white dark:bg-stone-900">
                  <p class="font-body text-base text-stone-600 dark:text-stone-400 mb-4 flex-1">{collection.description}</p>
                  <div class="flex items-center justify-between pt-3 border-t border-stone-100 dark:border-stone-800">
                    <span class="text-xs text-stone-400">{articleCount} articles · {totalReadTime} min</span>
                    <svg class="w-4 h-4 text-stone-300 dark:text-stone-600 group-hover:text-primary-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7" stroke-width="2"/></svg>
                  </div>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <Newsletter variant="compact" />

  <Footer slot="footer" />
  <CommandPaletteWrapper />
  <SideNav />
</BaseLayout>
