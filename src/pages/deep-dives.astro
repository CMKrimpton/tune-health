---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CommandPaletteWrapper from '../components/CommandPaletteWrapper.astro';
import SideNav from '../components/SideNav.astro';
import { getAllSeries, getArticleGradientStyle } from '../utils/articles';

const publishedSeries = await getAllSeries();

const comingSoonSeries = [
  {
    number: 'II',
    title: 'The Neuroscience of Habit Formation',
    description: 'A four-part exploration of how habits form, persist, and can be intentionally restructured. From the basal ganglia to practical behavioral strategies.',
    category: 'Neuroscience',
    parts: 4,
    totalTime: '45 min',
    gradient: 'from-violet-600 to-purple-700',
  },
  {
    number: 'III',
    title: 'Understanding Your Microbiome',
    description: 'The gut-brain connection, microbial diversity, and practical steps for optimization. How trillions of microorganisms influence your health.',
    category: 'Nutrition',
    parts: 6,
    totalTime: '60 min',
    gradient: 'from-emerald-500 to-teal-600',
  },
  {
    number: 'IV',
    title: "Precision Medicine: A Patient's Guide",
    description: 'How genetic testing, biomarkers, and personalized protocols are reshaping healthcare. Navigate the new frontier of individualized treatment.',
    category: 'Medicine',
    parts: 3,
    totalTime: '35 min',
    gradient: 'from-cyan-500 to-blue-600',
  },
  {
    number: 'V',
    title: 'Sleep Architecture Deep Dive',
    description: 'Understanding the stages of sleep, circadian biology, and evidence-based strategies for optimizing rest and recovery.',
    category: 'Sleep Science',
    parts: 5,
    totalTime: '50 min',
    gradient: 'from-indigo-500 to-purple-600',
  },
];
---

<BaseLayout
  title="Deep Dives | alumi news"
  description="Comprehensive multi-part guides on complex health topics."
>
  <Header slot="header" />

  <!-- Hero Section -->
  <section class="deep-dives-hero">
    <div class="container-editorial">
      <div class="max-w-3xl">
        <span class="section-label">Comprehensive Guides</span>
        <h1 class="font-serif text-display-2 font-semibold mt-2 mb-6">
          Deep Dives<br/>
          <span class="italic font-normal text-primary-600">Into Health Science</span>
        </h1>
        <p class="font-body text-body-lg text-stone-600 dark:text-stone-400 max-w-xl">
          Multi-part series that go beyond surface-level explanations. Each Deep Dive
          thoroughly explores a complex topic, connecting research to practical application.
        </p>
      </div>
    </div>
  </section>

  <!-- Published Series -->
  {publishedSeries.length > 0 && (
    <section class="py-16 md:py-24">
      <div class="container-editorial">
        <div class="flex items-center gap-6 mb-10">
          <span class="section-label">Published Series</span>
          <div class="flex-1 h-px bg-stone-300 dark:bg-stone-700"></div>
          <span class="text-sm text-stone-400">{publishedSeries.length} series</span>
        </div>

        {publishedSeries.map((series) => (
          <div class="mb-12 last:mb-0" id={series.name.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}>
            <div class="flex items-center gap-4 mb-6">
              <span class="inline-flex items-center gap-2 px-3 py-1 bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400 text-xs font-semibold uppercase tracking-widest rounded-full">
                Series
              </span>
              <h2 class="font-serif text-heading-1 font-semibold">{series.name}</h2>
              <span class="text-sm text-stone-400">{series.articles.length} parts</span>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
              {series.articles.map((article, i) => (
                <a href={article.href} class={`group block reveal${i > 0 ? ` reveal-delay-${Math.min(i, 5)}` : ''}`}>
                  <div class="bg-white dark:bg-stone-900 rounded-2xl overflow-hidden border border-stone-200 dark:border-stone-800 transition-all duration-300 hover:shadow-lg hover:border-stone-300 dark:hover:border-stone-700 h-full flex flex-col">
                    <div class="relative aspect-[16/10] overflow-hidden" style={article.heroImage ? undefined : getArticleGradientStyle(article.category)}>
                      {article.heroImage && (
                        <img src={article.heroImage} alt={article.heroImageAlt || article.title} class="w-full h-full object-cover" loading="lazy" />
                      )}
                      <div class="absolute top-3 left-4 flex items-center gap-2">
                        <span class="px-2 py-0.5 bg-stone-900/70 text-white text-xs font-semibold rounded">Part {article.seriesOrder}</span>
                      </div>
                    </div>
                    <div class="p-5 flex flex-col flex-1">
                      <div class="flex items-center gap-2 mb-2">
                        <span class="text-xs font-semibold uppercase tracking-wide text-primary-600">{article.category}</span>
                        <span class="text-xs text-stone-400">{article.readTime} min</span>
                      </div>
                      <h3 class="font-serif text-lg font-semibold mb-2 group-hover:text-primary-600 transition-colors leading-snug line-clamp-2">{article.title}</h3>
                      <p class="font-body text-sm text-stone-500 dark:text-stone-400 line-clamp-2 flex-1">{article.description}</p>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Coming Soon Series -->
  <section class="py-16 md:py-24 bg-stone-50 dark:bg-stone-900/30">
    <div class="container-editorial">
      <div class="flex items-center gap-6 mb-10">
        <span class="section-label">Coming Soon</span>
        <div class="flex-1 h-px bg-stone-300 dark:bg-stone-700"></div>
        <span class="text-sm text-stone-400">{comingSoonSeries.length} series</span>
      </div>

      <div class="space-y-6">
        {comingSoonSeries.map((item) => (
          <div class="deep-dive-feature-card group reveal opacity-75 cursor-default">
            <div class={`deep-dive-feature-image bg-gradient-to-br ${item.gradient}`}>
              <span class="deep-dive-feature-number">{item.number}</span>
            </div>
            <div class="deep-dive-feature-content">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-xs font-semibold uppercase tracking-wide text-primary-600">{item.category}</span>
                <span class="px-2 py-0.5 bg-stone-200 dark:bg-stone-700 text-stone-600 dark:text-stone-400 text-xs font-medium rounded">Coming Soon</span>
              </div>
              <h2 class="font-serif text-heading-2 font-semibold mb-3">
                {item.title}
              </h2>
              <p class="font-body text-body text-stone-600 dark:text-stone-400 mb-6">
                {item.description}
              </p>
              <div class="flex items-center gap-6 pt-4 border-t border-stone-100 dark:border-stone-800">
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" stroke-width="2"/>
                  </svg>
                  <span class="text-sm text-stone-500">{item.parts} Parts</span>
                </div>
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="10" stroke-width="2"/>
                    <path d="M12 6v6l4 2" stroke-width="2"/>
                  </svg>
                  <span class="text-sm text-stone-500">{item.totalTime} total</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- App Bridge -->
  <section class="py-16 md:py-20">
    <div class="container-editorial">
      <div class="max-w-2xl mx-auto text-center reveal">
        <span class="section-label mb-4 block">Apply What You Learn</span>
        <h2 class="font-serif text-heading-2 font-semibold mb-4">From Research to Results</h2>
        <p class="font-body text-body-lg text-stone-600 dark:text-stone-400 mb-8" style="line-height: 1.8;">
          Deep Dives teach the science. alumi Health lets you apply it — run your own N=1 experiments,
          track biomarkers, and ask Claude Opus follow-up questions about any study.
        </p>
        <a
          href="https://tune-sigma.vercel.app?utm_source=alumi-news&utm_medium=deep-dives"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary magnetic inline-flex"
          aria-label="Try alumi Health free"
        >
          <span>Try alumi Health Free</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M7 17L17 7M17 7H7M17 7v10" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="py-16 md:py-24 bg-stone-100 dark:bg-stone-900">
    <div class="container-editorial">
      <div class="max-w-2xl mx-auto text-center">
        <span class="section-label">Get Notified</span>
        <h2 class="font-serif text-heading-1 font-semibold mt-2 mb-4">Be First to Read</h2>
        <p class="font-body text-body-lg text-stone-600 dark:text-stone-400 mb-8">
          Subscribe to get notified when new Deep Dives are published.
        </p>
        <a href="/subscribe" class="btn-primary magnetic inline-flex">
          <span>Subscribe to Newsletter</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M5 12h14M12 5l7 7-7 7" stroke-width="2"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
  <CommandPaletteWrapper />
  <SideNav />
</BaseLayout>

<style>
  .deep-dives-hero {
    @apply pt-24 md:pt-28 pb-10 md:pb-14 bg-stone-50 dark:bg-stone-900/50;
    @apply border-b border-stone-200 dark:border-stone-800;
  }

  .deep-dive-feature-card {
    @apply grid grid-cols-1 lg:grid-cols-[200px_1fr];
    @apply bg-white dark:bg-stone-900 rounded-2xl overflow-hidden;
    @apply border border-stone-200 dark:border-stone-800;
    @apply transition-all duration-300;
  }

  .deep-dive-feature-card:hover {
    @apply shadow-lg dark:shadow-stone-900/50;
  }

  .deep-dive-feature-image {
    @apply flex items-center justify-center;
    @apply min-h-[160px] lg:min-h-full;
  }

  .deep-dive-feature-number {
    @apply font-serif text-6xl font-bold text-white/40;
  }

  .deep-dive-feature-content {
    @apply p-6 md:p-8;
  }
</style>
