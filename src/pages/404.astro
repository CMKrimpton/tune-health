---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CommandPaletteWrapper from '../components/CommandPaletteWrapper.astro';
import SideNav from '../components/SideNav.astro';
---

<BaseLayout
  title="Page Not Found | alumi news"
  description="The page you're looking for doesn't exist or has been moved."
>
  <meta slot="head" name="robots" content="noindex, nofollow" />
  <Header slot="header" />

  <div class="not-found-page">
    <div class="not-found-container">
      <p class="font-serif text-display-1 font-semibold text-stone-200 dark:text-stone-800 select-none leading-none" aria-hidden="true">
        404
      </p>
      <h1 class="font-serif text-heading-1 font-semibold mt-4 mb-4">
        Page not found
      </h1>
      <p class="text-lg text-stone-600 dark:text-stone-400 max-w-md mx-auto mb-10">
        The page you're looking for doesn't exist, or it may have been moved to a new address.
      </p>
      <div class="not-found-actions">
        <a href="/" class="btn-primary" aria-label="Back to home page">Back to Home</a>
        <a href="/articles" class="btn-secondary" aria-label="Browse all articles">Browse Articles</a>
      </div>
    </div>
  </div>

  <Footer slot="footer" />
  <CommandPaletteWrapper />
  <SideNav />
</BaseLayout>

<style>
  .not-found-page {
    @apply min-h-[60dvh] flex items-center justify-center py-24 px-6;
  }

  .not-found-container {
    @apply text-center max-w-xl mx-auto;
  }

  .not-found-actions {
    @apply flex flex-col sm:flex-row items-center justify-center gap-4;
  }
</style>
