---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CommandPaletteWrapper from '../components/CommandPaletteWrapper.astro';
import SideNav from '../components/SideNav.astro';
import AppPromo from '../components/AppPromo.astro';
import { getArticles, getComingSoonArticles, getFeaturedArticles, formatPublishDateShort, getArticleGradientStyle } from '../utils/articles';

const allArticles = await getArticles();
const comingSoon = await getComingSoonArticles();
const featured = await getFeaturedArticles();
const heroArticle = featured[0];

// Homepage shows max 9 articles (excluding the featured hero)
const gridArticles = allArticles.filter(a => a.slug !== heroArticle?.slug).slice(0, 9);
const categories = [...new Set(allArticles.map(a => a.category))].sort();
---

<BaseLayout
  title="alumi news | Evidence. Wherever It Leads."
  description="The bullshit filter for health. Independent analysis of health claims from any source - peer-reviewed journals and naturopathic remedies alike."
>
  <Header slot="header" variant="home" />

  <!-- Loader - only shown on initial page load, not View Transitions -->
  <div class="loader" id="loader" data-astro-transition-scope="loader">
    <div class="loader-content">
      <div class="loader-logo">
        <span class="t">a</span>
        <span>lumi</span>
      </div>
      <div class="loader-bar">
        <div class="loader-progress"></div>
      </div>
    </div>
  </div>

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-bg">
      <div class="gradient-radial-primary absolute inset-0"></div>
      <div class="hero-pattern"></div>
      <div class="hero-glow"></div>
    </div>

    <div class="container-editorial">
      <div class="max-w-narrow mx-auto text-center">
        <div class="hero-badge inline-flex items-center gap-2 px-3 py-1.5 bg-stone-100 dark:bg-stone-800 rounded-full text-xs font-medium tracking-wide uppercase text-stone-600 dark:text-stone-400 mb-6">
          <span class="w-1.5 h-1.5 bg-primary-600 rounded-full animate-pulse"></span>
          <span>Spring 2026 — {allArticles.length} Articles Published</span>
        </div>

        <h1 class="hero-title font-serif text-display-1 font-semibold mb-4 text-balance" transition:name="hero-title">
          <span class="block">Evidence.</span>
          <span class="block italic font-normal text-primary-600">Wherever it leads.</span>
        </h1>

        <p class="hero-subtitle font-body text-body-lg text-stone-600 dark:text-stone-400 max-w-lg mx-auto mb-8" style="line-height: 1.7;">
          Independent health analysis for people who think for themselves.
          Peer-reviewed journals and naturopathic claims — held to the same standard.
        </p>

        <div class="hero-cta flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#featured" class="btn-primary magnetic">
            <span>Explore Articles</span>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path d="M5 12h14M12 5l7 7-7 7" stroke-width="2"/>
            </svg>
          </a>
          <a href="#newsletter" class="btn-secondary magnetic">Subscribe Free</a>
        </div>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2">
      <span class="text-overline text-stone-400">Scroll to explore</span>
      <div class="w-px h-10 bg-gradient-to-b from-stone-400 to-transparent animate-pulse"></div>
    </div>

    <div class="hidden lg:flex absolute bottom-8 right-10 gap-8 items-end">
      <div class="text-right">
        <span class="block font-serif text-2xl font-semibold counter" data-count={allArticles.length}>0</span>
        <span class="text-overline text-stone-400">Published</span>
      </div>
      <div class="text-right">
        <span class="block font-serif text-2xl font-semibold counter" data-count="7">0</span>
        <span class="text-overline text-stone-400">Categories</span>
      </div>
      <div class="text-right">
        <span class="block text-xs text-stone-400 uppercase tracking-widest">Est. 2024</span>
      </div>
    </div>
  </section>

  <!-- Featured Article -->
  {heroArticle && (
    <section class="py-14 md:py-20 bg-stone-50 dark:bg-stone-900/50" id="featured">
      <div class="container-editorial">
        <div class="flex items-center gap-6 mb-8">
          <span class="section-label">Featured Story</span>
          <div class="flex-1 h-px bg-stone-200 dark:bg-stone-800"></div>
        </div>

        <a href={heroArticle.href} class="featured-card group block reveal">
          <div class="featured-image-container">
            <div class="featured-image-inner" style={heroArticle.heroImage ? undefined : getArticleGradientStyle(heroArticle.category)}>
              {heroArticle.heroImage ? (
                <img src={heroArticle.heroImage} alt={heroArticle.heroImageAlt || heroArticle.title} class="w-full h-full object-cover" loading="eager" />
              ) : (
                <div class="absolute inset-0 flex items-end p-8">
                  <span class="font-serif text-[6rem] lg:text-[8rem] font-bold text-white/[0.06] leading-none select-none">01</span>
                </div>
              )}
            </div>
          </div>

          <div class="p-6 lg:p-8 flex flex-col justify-center">
            <div class="flex items-center gap-2 text-xs font-medium uppercase tracking-widest mb-4">
              <span class="text-primary-600">{heroArticle.category}</span>
              <span class="text-stone-300 dark:text-stone-600">/</span>
              <span class="text-stone-500">{heroArticle.readTime} min read</span>
            </div>

            <h2 class="font-serif text-heading-1 font-semibold mb-4 group-hover:text-primary-600 transition-colors leading-tight">
              {heroArticle.title}
            </h2>

            <p class="font-body text-body-lg text-stone-600 dark:text-stone-400 mb-8 flex-1 leading-relaxed">
              {heroArticle.description}
            </p>

            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 pt-6 border-t border-stone-100 dark:border-stone-800">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-primary-600 flex items-center justify-center text-white text-sm font-semibold">an</div>
                <div>
                  <span class="block text-sm font-semibold">alumi news Editorial</span>
                  <span class="block text-xs text-stone-500">Medical Review Board</span>
                </div>
              </div>

              <span class="inline-flex items-center gap-2 font-semibold text-sm text-primary-600 group-hover:gap-3 transition-all">
                Read Article
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path d="M5 12h14M12 5l7 7-7 7" stroke-width="2"/>
                </svg>
              </span>
            </div>
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- Categories -->
  <section class="py-8 border-b border-stone-200 dark:border-stone-800" id="categories">
    <div class="container-editorial">
      <div class="categories-scroll">
        <button class="category-chip active" data-category="all">
          <span class="text-sm font-medium">All</span>
        </button>
        {categories.map((cat) => (
          <button class="category-chip" data-category={cat}>
            <span class="text-sm font-medium">{cat}</span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest Articles Grid -->
  <section class="py-14 md:py-20" id="latest">
    <div class="container-editorial">
      <div class="flex items-center justify-between mb-8">
        <div>
          <span class="section-label">Latest Stories</span>
          <h2 class="font-serif text-heading-2 font-semibold mt-1">Fresh Perspectives</h2>
        </div>
        <a href="/articles" class="hidden md:inline-flex items-center gap-2 text-sm font-medium text-stone-500 hover:text-primary-600 transition-colors">
          View all {allArticles.length} articles
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M5 12h14M12 5l7 7-7 7" stroke-width="2"/>
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="articleGrid">
        {gridArticles.map((article, i) => (
          <a
            href={article.href}
            class={`article-card group reveal${i === 0 ? ' article-card-large' : ''}${i > 0 ? ` reveal-delay-${Math.min(i, 5)}` : ''}`}
            data-category={article.category}
          >
            <div class="article-card-image">
              <div class="article-card-image-inner relative overflow-hidden" style={article.heroImage ? undefined : getArticleGradientStyle(article.category)}>
                {article.heroImage && (
                  <img src={article.heroImage} alt={article.heroImageAlt || article.title} class="w-full h-full object-cover" loading={i < 3 ? 'eager' : 'lazy'} />
                )}
                <span class="article-card-number absolute bottom-4 left-4">{String(i + 1).padStart(2, '0')}</span>
              </div>
            </div>
            <div class="article-card-content">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-xs font-semibold uppercase tracking-wide text-primary-600">{article.category}</span>
                <span class="text-xs text-stone-400">{formatPublishDateShort(article.publishDate)}</span>
              </div>
              <h3 class={`font-serif ${i === 0 ? 'text-heading-3' : 'text-xl'} font-semibold mb-2 group-hover:text-primary-600 transition-colors`}>{article.title}</h3>
              <p class={`font-body ${i === 0 ? '' : 'text-sm '}text-stone-600 dark:text-stone-400 ${i === 0 ? 'mb-4 line-clamp-3' : 'line-clamp-2'}`}>{article.description}</p>
              <div class="flex items-center justify-between pt-3 mt-auto border-t border-stone-100 dark:border-stone-800">
                <span class="text-xs text-stone-400 font-medium">{article.readTime} min read</span>
                <svg class="w-4 h-4 text-stone-300 dark:text-stone-600 group-hover:text-primary-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path d="M5 12h14M12 5l7 7-7 7" stroke-width="2"/>
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- View All CTA -->
      <div class="mt-12 text-center">
        <a href="/articles" class="btn-secondary magnetic inline-flex">
          <span>Browse all {allArticles.length} articles</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M5 12h14M12 5l7 7-7 7" stroke-width="2"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- About / Mission Section -->
  <section class="py-16 md:py-24 bg-stone-900 dark:bg-stone-950 text-white" id="about">
    <div class="container-editorial">
      <div class="max-w-3xl mx-auto">
        <span class="section-label !text-primary-400 mb-6 block">Our Mission</span>
        <h2 class="font-serif text-heading-1 font-semibold mb-8 leading-tight">Health Without the Hype</h2>

        <div class="font-body text-body-lg text-stone-300 space-y-6" style="line-height: 1.85;">
          <p>
            Health information is broken. Mainstream sources defer to authority and industry-funded research.
            Alternative health cherry-picks studies and sells false hope. Both sides have conflicts of interest
            they don't disclose.
          </p>
          <p class="text-white font-semibold text-xl font-serif italic">
            alumi news exists to cut through it all.
          </p>
          <p>
            We treat peer-reviewed journals and naturopathic claims with the same respect — and the same skepticism.
            We'll tell you when a cheap generic outperforms an expensive supplement, and when a folk remedy has more
            science behind it than a blockbuster medication. We follow evidence wherever it leads, even when it's inconvenient.
          </p>
        </div>

        <div class="mt-10 pt-6 border-t border-stone-700/50 grid grid-cols-3 gap-6 max-w-md">
          <div>
            <span class="block text-xl font-serif font-semibold text-primary-400 mb-1">No</span>
            <span class="text-xs text-stone-500 uppercase tracking-widest">Sponsors</span>
          </div>
          <div>
            <span class="block text-xl font-serif font-semibold text-primary-400 mb-1">No</span>
            <span class="text-xs text-stone-500 uppercase tracking-widest">Sacred Cows</span>
          </div>
          <div>
            <span class="block text-xl font-serif font-semibold text-primary-400 mb-1">No</span>
            <span class="text-xs text-stone-500 uppercase tracking-widest">Bullshit</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- alumi Health App Promo -->
  <AppPromo />

  <!-- Deep Dives -->
  <section class="py-14 md:py-20 bg-stone-100 dark:bg-stone-900" id="deep-dives">
    <div class="container-editorial">
      <div class="mb-8">
        <span class="section-label">Deep Dives</span>
        <h2 class="font-serif text-heading-2 font-semibold mt-1">Comprehensive Guides</h2>
      </div>

      <div class="space-y-4">
        <a href="/deep-dives" class="deep-dive-card group reveal opacity-90 hover:opacity-100">
          <div class="deep-dive-image">
            <img
              src="https://images.unsplash.com/photo-1507413245164-6160d8298b31?w=200&h=200&fit=crop&q=80"
              alt="Neural connections"
              class="w-full h-full object-cover"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-stone-900/50"></div>
            <span class="deep-dive-number">I</span>
          </div>
          <div class="min-w-0 flex-1">
            <span class="text-xs font-semibold uppercase tracking-widest text-primary-600 mb-2 block">Series &middot; Coming Soon</span>
            <h3 class="font-serif text-xl font-semibold mb-1 group-hover:text-primary-600 transition-colors">The Neuroscience of Habit Formation</h3>
            <p class="text-sm text-stone-500 dark:text-stone-400 hidden md:block mb-2">A four-part exploration of how habits form, persist, and can be intentionally restructured.</p>
            <div class="flex gap-2 text-xs text-stone-400">
              <span>4 Parts</span>
              <span>&middot;</span>
              <span>45 min total</span>
            </div>
          </div>
          <span class="hidden md:block text-lg text-stone-300 group-hover:text-primary-600 transition-colors">&rarr;</span>
        </a>

        <a href="/deep-dives" class="deep-dive-card group reveal reveal-delay-1 opacity-90 hover:opacity-100">
          <div class="deep-dive-image">
            <img
              src="https://images.unsplash.com/photo-1628771065518-0d82f1938462?w=200&h=200&fit=crop&q=80"
              alt="Gut health"
              class="w-full h-full object-cover"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-stone-900/50"></div>
            <span class="deep-dive-number">II</span>
          </div>
          <div class="min-w-0 flex-1">
            <span class="text-xs font-semibold uppercase tracking-widest text-primary-600 mb-2 block">Series &middot; Coming Soon</span>
            <h3 class="font-serif text-xl font-semibold mb-1 group-hover:text-primary-600 transition-colors">Understanding Your Microbiome</h3>
            <p class="text-sm text-stone-500 dark:text-stone-400 hidden md:block mb-2">The gut-brain connection, microbial diversity, and practical steps for optimization.</p>
            <div class="flex gap-2 text-xs text-stone-400">
              <span>6 Parts</span>
              <span>&middot;</span>
              <span>60 min total</span>
            </div>
          </div>
          <span class="hidden md:block text-lg text-stone-300 group-hover:text-primary-600 transition-colors">&rarr;</span>
        </a>

        <a href="/deep-dives" class="deep-dive-card group reveal reveal-delay-2 opacity-90 hover:opacity-100">
          <div class="deep-dive-image">
            <img
              src="https://images.unsplash.com/photo-1579154204601-01588f351e67?w=200&h=200&fit=crop&q=80"
              alt="DNA strand"
              class="w-full h-full object-cover"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-stone-900/50"></div>
            <span class="deep-dive-number">III</span>
          </div>
          <div class="min-w-0 flex-1">
            <span class="text-xs font-semibold uppercase tracking-widest text-primary-600 mb-2 block">Guide &middot; Coming Soon</span>
            <h3 class="font-serif text-xl font-semibold mb-1 group-hover:text-primary-600 transition-colors">Precision Medicine: A Patient's Guide</h3>
            <p class="text-sm text-stone-500 dark:text-stone-400 hidden md:block mb-2">How genetic testing, biomarkers, and personalized protocols are reshaping healthcare.</p>
            <div class="flex gap-2 text-xs text-stone-400">
              <span>3 Parts</span>
              <span>&middot;</span>
              <span>35 min total</span>
            </div>
          </div>
          <span class="hidden md:block text-lg text-stone-300 group-hover:text-primary-600 transition-colors">&rarr;</span>
        </a>
      </div>

      <div class="mt-8 text-center">
        <a href="/deep-dives" class="inline-flex items-center gap-2 text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors">
          View all Deep Dives
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M5 12h14M12 5l7 7-7 7" stroke-width="2"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="py-14 md:py-20" id="newsletter">
    <div class="container-editorial">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div>
          <span class="section-label">Newsletter</span>
          <h2 class="font-serif text-heading-1 font-semibold mt-2 mb-3">Real Wealth Starts Here</h2>
          <p class="font-body text-body-lg text-stone-600 dark:text-stone-400 mb-6" style="line-height: 1.7;">
            Weekly evidence-based health insights delivered to your inbox.
            No hype, no sales pitches — just the research that matters.
          </p>

          <form class="mb-8" id="newsletterForm">
            <div class="flex flex-col sm:flex-row gap-3 mb-4">
              <input type="email" required placeholder="you@example.com"
                     class="flex-1 px-5 py-3 bg-stone-100 dark:bg-stone-800 border border-stone-200 dark:border-stone-700 rounded-full text-base focus:outline-none focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 transition-all"
                     aria-label="Email address">
              <button type="submit" class="btn-primary whitespace-nowrap">
                <span>Subscribe</span>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path d="M5 12h14M12 5l7 7-7 7" stroke-width="2"/>
                </svg>
              </button>
            </div>
            <p class="text-xs text-stone-400">No spam. Unsubscribe anytime.</p>
          </form>

          <div class="flex flex-wrap gap-6">
            <div class="flex items-center gap-2 text-sm text-stone-600 dark:text-stone-400">
              <svg class="w-4 h-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path d="M5 13l4 4L19 7" stroke-width="2"/>
              </svg>
              <span>Weekly insights</span>
            </div>
            <div class="flex items-center gap-2 text-sm text-stone-600 dark:text-stone-400">
              <svg class="w-4 h-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path d="M5 13l4 4L19 7" stroke-width="2"/>
              </svg>
              <span>Evidence-based</span>
            </div>
            <div class="flex items-center gap-2 text-sm text-stone-600 dark:text-stone-400">
              <svg class="w-4 h-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path d="M5 13l4 4L19 7" stroke-width="2"/>
              </svg>
              <span>Free forever</span>
            </div>
          </div>
        </div>

        <!-- Newsletter Visual — Real article previews -->
        <div class="newsletter-visual">
          {allArticles.slice(0, 3).map((article, i) => (
            <div class={`newsletter-card newsletter-card-${i + 1}`}>
              <div class="flex items-center justify-between mb-3">
                <span class={`px-2 py-1 text-xs font-semibold uppercase rounded ${i === 0 ? 'bg-primary-100 dark:bg-primary-900/30 text-primary-600' : i === 1 ? 'bg-amber-100 dark:bg-amber-900/30 text-amber-600' : 'bg-blue-100 dark:bg-blue-900/30 text-blue-600'}`}>
                  {i === 0 ? 'New' : i === 1 ? 'Popular' : 'Featured'}
                </span>
                <span class="text-xs text-stone-400">{formatPublishDateShort(article.publishDate)}</span>
              </div>
              <h4 class="font-serif font-semibold mb-1 line-clamp-1">{article.title}</h4>
              <p class="text-sm text-stone-500 line-clamp-1">{article.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
  <CommandPaletteWrapper />
  <SideNav />

  <script>
    // Track if this is the initial page load vs View Transition
    let isInitialLoad = true;
    let heroAnimated = false;

    function initHomePage(isViewTransition = false) {
      const loader = document.getElementById('loader');
      const heroBadge = document.querySelector('.hero-badge') as HTMLElement;
      const heroTitle = document.querySelector('.hero-title') as HTMLElement;
      const heroSubtitle = document.querySelector('.hero-subtitle') as HTMLElement;
      const heroCta = document.querySelector('.hero-cta') as HTMLElement;
      const heroElements = [heroBadge, heroTitle, heroSubtitle, heroCta].filter(Boolean);

      // Reveal hero elements with CSS animation
      function revealHero() {
        if (heroAnimated) return;
        heroAnimated = true;

        // Add active class to trigger CSS transitions
        heroElements.forEach(el => {
          if (el) el.classList.add('active');
        });

        // Animate counters
        animateCounters();
      }

      // Simple counter animation without GSAP
      function animateCounters() {
        const counters = document.querySelectorAll('.counter');
        counters.forEach((counter) => {
          const el = counter as HTMLElement;
          const target = parseInt(el.dataset.count || '0');
          if (isNaN(target)) return;

          const duration = 1500;
          const startTime = performance.now();

          function updateCounter(currentTime: number) {
            const elapsed = currentTime - startTime;
            const progress = Math.min(elapsed / duration, 1);
            // Ease out cubic
            const eased = 1 - Math.pow(1 - progress, 3);
            el.innerText = Math.round(eased * target).toString();

            if (progress < 1) {
              requestAnimationFrame(updateCounter);
            }
          }

          requestAnimationFrame(updateCounter);
        });
      }

      // Hide loader and reveal hero
      function hideLoader() {
        if (loader && !loader.classList.contains('hidden')) {
          loader.style.opacity = '0';
          setTimeout(() => {
            loader.classList.add('hidden');
            document.body.style.overflow = '';
            revealHero();
          }, 500);
        } else {
          revealHero();
        }
      }

      // Category filtering
      const categoryChips = document.querySelectorAll('.category-chip');
      const articleCards = document.querySelectorAll('#articleGrid .article-card');

      categoryChips.forEach(chip => {
        chip.addEventListener('click', () => {
          // Update active state
          categoryChips.forEach(c => c.classList.remove('active'));
          chip.classList.add('active');

          const category = (chip as HTMLElement).dataset.category;

          articleCards.forEach(card => {
            const cardEl = card as HTMLElement;
            const cardCategory = cardEl.dataset.category;

            if (category === 'all' || cardCategory === category) {
              cardEl.style.display = '';
              // Re-trigger reveal animation
              cardEl.classList.remove('active');
              requestAnimationFrame(() => cardEl.classList.add('active'));
            } else {
              cardEl.style.display = 'none';
            }
          });
        });
      });

      // Newsletter form - only bind once
      const newsletterForm = document.getElementById('newsletterForm');
      if (newsletterForm && !newsletterForm.dataset.bound) {
        newsletterForm.dataset.bound = 'true';
        newsletterForm.addEventListener('submit', (e) => {
          e.preventDefault();
          const btn = newsletterForm.querySelector('button[type="submit"]') as HTMLButtonElement;
          const input = newsletterForm.querySelector('input[type="email"]') as HTMLInputElement;
          const originalText = btn.innerHTML;

          btn.innerHTML = `<span>Subscribing...</span>`;
          btn.disabled = true;
          if (input) input.disabled = true;

          setTimeout(() => {
            btn.innerHTML = `
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path d="M5 13l4 4L19 7" stroke-width="2"/>
              </svg>
              <span>Subscribed!</span>
            `;

            setTimeout(() => {
              btn.innerHTML = originalText;
              btn.disabled = false;
              if (input) {
                input.disabled = false;
                input.value = '';
              }
            }, 3000);
          }, 1200);
        });
      }

      // Handle initial load vs View Transition
      if (isInitialLoad && !isViewTransition) {
        // Initial page load - wait for loader
        if (loader && !loader.classList.contains('hidden')) {
          setTimeout(hideLoader, 1600);
        } else {
          hideLoader();
        }
        isInitialLoad = false;
      } else if (isViewTransition) {
        // View Transition back to home - show immediately without animation
        if (loader) {
          loader.classList.add('hidden');
        }

        // Instantly show hero elements (no animation)
        heroElements.forEach(el => {
          if (el) {
            el.style.opacity = '1';
            el.style.transform = 'translateY(0)';
          }
        });

        // Set counters to final values instantly
        const counters = document.querySelectorAll('.counter');
        counters.forEach((counter) => {
          const el = counter as HTMLElement;
          el.innerText = el.dataset.count || '0';
        });
      }
    }

    // Run on initial load
    initHomePage(false);

    // Run after View Transitions
    document.addEventListener('astro:after-swap', () => {
      if (window.location.pathname === '/' || window.location.pathname === '/index.html') {
        initHomePage(true);
      }
    });
  </script>
</BaseLayout>
