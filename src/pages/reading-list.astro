---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CommandPaletteWrapper from '../components/CommandPaletteWrapper.astro';
import SideNav from '../components/SideNav.astro';
import { getArticles, getArticleGradientStyle, formatPublishDateShort } from '../utils/articles';

const allArticles = await getArticles();

// Pass all article data as JSON so the client-side JS can render bookmarked ones
const articleMap = Object.fromEntries(
  allArticles.map(a => [a.slug, {
    slug: a.slug,
    title: a.title,
    description: a.description,
    category: a.category,
    readTime: a.readTime,
    publishDate: a.publishDate,
    href: a.href,
    heroImage: a.heroImage,
    heroImageAlt: a.heroImageAlt,
    gradient: getArticleGradientStyle(a.category),
  }])
);
---

<BaseLayout
  title="Reading List | alumi news"
  description="Your saved articles from alumi news. Pick up where you left off."
>
  <Header slot="header" />

  <section class="py-14 md:py-20">
    <div class="container-editorial">
      <div class="max-w-3xl mx-auto">
        <div class="mb-10">
          <span class="text-xs font-semibold uppercase tracking-widest text-primary-600 mb-2 block">Your Library</span>
          <h1 class="font-serif text-display-2 font-semibold mb-3">Reading List</h1>
          <p class="font-body text-body-lg text-stone-600 dark:text-stone-400">
            Articles you've saved for later. Stored locally in your browser.
          </p>
        </div>

        <!-- Loading state -->
        <div id="readingListLoading" class="py-12 text-center">
          <div class="w-8 h-8 border-2 border-stone-300 dark:border-stone-600 border-t-primary-600 rounded-full animate-spin mx-auto mb-4"></div>
          <p class="text-sm text-stone-500">Loading your reading list...</p>
        </div>

        <!-- Empty state -->
        <div id="readingListEmpty" class="py-16 text-center hidden">
          <div class="max-w-sm mx-auto bg-stone-50 dark:bg-stone-900 rounded-2xl p-10 border border-stone-200 dark:border-stone-800">
            <div class="w-16 h-16 rounded-2xl bg-stone-100 dark:bg-stone-800 flex items-center justify-center mx-auto mb-6">
              <svg class="w-8 h-8 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h2 class="font-serif text-xl font-semibold mb-2">No saved articles yet</h2>
            <p class="text-stone-500 dark:text-stone-400 mb-6">
              Tap the bookmark icon on any article to save it here for later reading.
            </p>
            <a href="/articles" class="btn-primary inline-flex">
              <span>Browse Articles</span>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path d="M5 12h14M12 5l7 7-7 7" stroke-width="2"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Article list -->
        <div id="readingListArticles" class="space-y-4 hidden">
          <div class="flex items-center justify-between mb-2">
            <span id="readingListCount" class="text-sm text-stone-500 dark:text-stone-400"></span>
            <button id="clearReadingList" class="text-xs font-medium text-stone-400 hover:text-red-500 dark:hover:text-red-400 transition-colors">
              Clear all
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script define:vars={{ articleMap }}>
    function initReadingList() {
      const STORAGE_KEY = 'alumi-reading-list';
      const loading = document.getElementById('readingListLoading');
      const empty = document.getElementById('readingListEmpty');
      const listContainer = document.getElementById('readingListArticles');
      const countEl = document.getElementById('readingListCount');
      const clearBtn = document.getElementById('clearReadingList');

      if (!loading || !empty || !listContainer) return;

      function getReadingList() {
        try {
          return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
        } catch {
          return [];
        }
      }

      function saveReadingList(list) {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(list));
      }

      function renderList() {
        const slugs = getReadingList();
        loading.classList.add('hidden');

        if (slugs.length === 0) {
          empty.classList.remove('hidden');
          listContainer.classList.add('hidden');
          return;
        }

        empty.classList.add('hidden');
        listContainer.classList.remove('hidden');
        countEl.textContent = `${slugs.length} saved article${slugs.length !== 1 ? 's' : ''}`;

        // Clear existing cards (keep header)
        const existingCards = listContainer.querySelectorAll('.reading-list-card');
        existingCards.forEach(c => c.remove());

        // Render cards
        slugs.forEach((slug) => {
          const article = articleMap[slug];
          if (!article) return;

          const card = document.createElement('a');
          card.href = article.href;
          card.className = 'reading-list-card group flex gap-4 p-4 rounded-xl bg-white dark:bg-stone-900 border border-stone-200 dark:border-stone-800 hover:border-primary-200 dark:hover:border-primary-800 hover:shadow-card transition-all duration-200';
          card.innerHTML = `
            <div class="w-20 h-20 rounded-lg overflow-hidden flex-shrink-0">
              ${article.heroImage
                ? `<img src="${article.heroImage}" alt="" class="w-full h-full object-cover" loading="lazy" />`
                : `<div class="w-full h-full" style="${article.gradient}"></div>`
              }
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-xs font-semibold uppercase tracking-wide text-primary-600">${article.category}</span>
                <span class="text-xs text-stone-400">${article.readTime} min</span>
              </div>
              <h3 class="font-serif text-base font-semibold mb-1 group-hover:text-primary-600 transition-colors duration-200 line-clamp-2">${article.title}</h3>
              <p class="text-sm text-stone-500 dark:text-stone-400 line-clamp-1">${article.description}</p>
            </div>
            <button class="remove-bookmark flex-shrink-0 w-8 h-8 rounded-lg flex items-center justify-center text-stone-300 dark:text-stone-600 hover:text-red-500 dark:hover:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors" data-remove-slug="${slug}" aria-label="Remove from reading list" title="Remove">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path d="M6 18L18 6M6 6l12 12" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          `;

          listContainer.appendChild(card);
        });

        // Attach remove handlers
        listContainer.querySelectorAll('[data-remove-slug]').forEach((btn) => {
          btn.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            const slug = btn.getAttribute('data-remove-slug');
            const list = getReadingList().filter((s) => s !== slug);
            saveReadingList(list);
            renderList();
          });
        });
      }

      // Clear all handler
      clearBtn?.addEventListener('click', () => {
        if (confirm('Remove all saved articles?')) {
          saveReadingList([]);
          renderList();
        }
      });

      renderList();
    }

    // Run after DOM is ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initReadingList);
    } else {
      initReadingList();
    }
    document.addEventListener('astro:after-swap', initReadingList);
  </script>

  <Footer slot="footer" />
  <CommandPaletteWrapper />
  <SideNav />
</BaseLayout>
