---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Newsletter from '../../components/Newsletter.astro';
import CommandPaletteWrapper from '../../components/CommandPaletteWrapper.astro';
import SideNav from '../../components/SideNav.astro';
import { getArticles, getComingSoonArticles, getCategoriesWithCounts, formatPublishDateShort, getArticleGradientStyle, getAllTags, isNewArticle } from '../../utils/articles';

const articles = await getArticles();
const comingSoon = await getComingSoonArticles();
const categoriesWithCounts = await getCategoriesWithCounts();
const allTags = await getAllTags();

// Featured: top 3 articles
const featuredArticles = articles.slice(0, 3);

// Group articles by category for the "All" overview
const articlesByCategory = new Map<string, typeof articles>();
articles.forEach(a => {
  const existing = articlesByCategory.get(a.category) || [];
  existing.push(a);
  articlesByCategory.set(a.category, existing);
});

// Sort categories by article count (most articles first) for better overview
const sortedCategories = [...articlesByCategory.entries()]
  .sort((a, b) => b[1].length - a[1].length);
---

<BaseLayout
  title="Articles | alumi news"
  description="Evidence-based health insights and clinical research reviews."
>
  <Header slot="header" />

  <!-- Hero Section -->
  <section class="articles-hero">
    <div class="container-editorial">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8">
        <div class="max-w-2xl">
          <span class="section-label">The Library</span>
          <h1 class="font-serif text-display-2 font-semibold mt-3 mb-4 leading-tight">
            Evidence-Based<br/>
            <span class="italic font-normal text-primary-600">Health Insights</span>
          </h1>
          <p class="font-body text-body-lg text-stone-600 dark:text-stone-400 max-w-lg">
            {articles.length} articles across {categoriesWithCounts.length} topics — every one researched and reviewed.
          </p>
        </div>

        <!-- Search + Sort -->
        <div class="flex flex-col sm:flex-row gap-3 w-full max-w-md">
          <div class="relative flex-1">
            <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="11" cy="11" r="8" stroke-width="2"/>
              <path d="m21 21-4.35-4.35" stroke-width="2"/>
            </svg>
            <input
              type="text"
              id="articleSearch"
              placeholder="Search articles..."
              class="w-full pl-12 pr-5 py-3 bg-white dark:bg-stone-800 border border-stone-200 dark:border-stone-700 rounded-full text-base focus:outline-none focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 transition-[border-color,box-shadow]"
              aria-label="Search articles"
            />
          </div>
          <select
            id="articleSort"
            class="px-4 py-3 bg-white dark:bg-stone-800 border border-stone-200 dark:border-stone-700 rounded-full text-sm focus:outline-none focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 transition-[border-color,box-shadow] cursor-pointer"
            aria-label="Sort articles"
          >
            <option value="newest">Newest</option>
            <option value="oldest">Oldest</option>
            <option value="shortest">Shortest</option>
            <option value="longest">Longest</option>
            <option value="az">A — Z</option>
          </select>
        </div>
      </div>
    </div>
  </section>

  <!-- Active Filters Bar (hidden by default, shown when tag filter is active) -->
  <div id="activeFilters" class="bg-stone-50 dark:bg-stone-900/30 border-b border-stone-200 dark:border-stone-800" style="display: none;">
    <div class="container-editorial py-3">
      <div class="flex items-center gap-3 flex-wrap">
        <span class="text-xs text-stone-400 uppercase tracking-widest">Filters:</span>
        <span id="activeTagPill" class="inline-flex items-center gap-1.5 px-3 py-1 bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400 text-sm font-medium rounded-full">
          <span id="activeTagLabel"></span>
          <button id="clearTagFilter" class="hover:text-primary-800 dark:hover:text-primary-300 transition-colors" aria-label="Clear tag filter">&times;</button>
        </span>
        <button id="clearAllFilters" class="text-xs text-stone-400 hover:text-stone-600 dark:hover:text-stone-300 transition-colors ml-auto">Clear all</button>
      </div>
    </div>
  </div>

  <!-- Featured Row: Top 3 Articles -->
  <section class="py-12 md:py-16" id="featuredRow">
    <div class="container-editorial">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        {/* Lead article — large card */}
        {featuredArticles[0] && (
          <a href={featuredArticles[0].href} class="article-lead-card group reveal block" data-category={featuredArticles[0].category} data-title={featuredArticles[0].title.toLowerCase()} data-tags={featuredArticles[0].tags.join(' ').toLowerCase()}>
            <div class="relative aspect-[4/3] overflow-hidden rounded-t-2xl lg:rounded-2xl" style={featuredArticles[0].heroImage ? undefined : getArticleGradientStyle(featuredArticles[0].category)}>
              {featuredArticles[0].heroImage ? (
                <img src={featuredArticles[0].heroImage} alt={featuredArticles[0].heroImageAlt || featuredArticles[0].title} class="w-full h-full object-cover" loading="eager" />
              ) : (
                <span class="absolute top-6 right-6 font-serif text-[7rem] font-bold text-white/[0.06] leading-none select-none">01</span>
              )}
              <div class="absolute inset-0 lead-card-overlay"></div>
              <div class="absolute bottom-0 left-0 right-0 p-6 lg:p-8 lead-card-text">
                <div class="flex items-center gap-2 mb-3">
                  <span class="px-2.5 py-1 bg-primary-600 text-white text-xs font-semibold uppercase tracking-wide rounded">{featuredArticles[0].category}</span>
                  <span class="text-xs lead-card-meta">{featuredArticles[0].readTime} min read</span>
                </div>
                <h2 class="font-serif text-heading-2 font-semibold mb-2 leading-tight transition-colors lead-card-title group-hover:text-primary-600 dark:group-hover:text-primary-300">{featuredArticles[0].title}</h2>
                <p class="font-body text-sm lead-card-desc line-clamp-2">{featuredArticles[0].description}</p>
              </div>
            </div>
          </a>
        )}

        {/* Two stacked cards */}
        <div class="flex flex-col gap-6">
          {featuredArticles.slice(1, 3).map((article, i) => (
            <a href={article.href} class={`article-side-card group reveal${i > 0 ? ' reveal-delay-1' : ''} flex-1 block`} data-category={article.category} data-title={article.title.toLowerCase()} data-tags={article.tags.join(' ').toLowerCase()}>
              <div class="grid grid-cols-[140px_1fr] sm:grid-cols-[180px_1fr] h-full bg-white dark:bg-stone-900 rounded-2xl overflow-hidden border border-stone-200 dark:border-stone-800 transition-[border-color,box-shadow] duration-300 hover:shadow-lg hover:border-stone-300 dark:hover:border-stone-700">
                <div class="relative overflow-hidden" style={article.heroImage ? undefined : getArticleGradientStyle(article.category)}>
                  {article.heroImage && (
                    <img src={article.heroImage} alt={article.heroImageAlt || article.title} class="w-full h-full object-cover" loading="eager" />
                  )}
                </div>
                <div class="p-5 flex flex-col justify-center">
                  <div class="flex items-center gap-2 mb-2">
                    <span class="text-xs font-semibold uppercase tracking-wide text-primary-600">{article.category}</span>
                    <span class="text-xs text-stone-400">{article.readTime} min</span>
                  </div>
                  <h3 class="font-serif text-lg font-semibold mb-1.5 group-hover:text-primary-600 transition-colors leading-snug line-clamp-2">{article.title}</h3>
                  <p class="font-body text-sm text-stone-500 dark:text-stone-400 line-clamp-2 hidden sm:block">{article.description}</p>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Category Overview (shown when "All" is active, no search) -->
  <section class="py-12 md:py-16 bg-stone-50 dark:bg-stone-900/30" id="categoryOverview">
    <div class="container-editorial">
      <div class="flex items-center gap-6 mb-10">
        <span class="section-label">Browse by Topic</span>
        <div class="flex-1 h-px bg-stone-200 dark:bg-stone-800"></div>
        <span class="text-xs text-stone-400 uppercase tracking-widest" id="articleCount">{articles.length} articles</span>
      </div>

      <div class="space-y-14" id="categorySections">
        {sortedCategories.map(([category, catArticles], catIdx) => (
          <div class="category-section reveal" data-cat-section={category}>
            <div class="flex items-center justify-between mb-5">
              <div class="flex items-center gap-3">
                <h3 class="font-serif text-xl font-semibold">{category}</h3>
                <span class="text-xs text-stone-500 bg-stone-200 dark:bg-stone-800 px-2.5 py-0.5 rounded-full font-medium">{catArticles.length}</span>
              </div>
              {catArticles.length > 4 && (
                <button class="text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors inline-flex items-center gap-1 cat-see-all rounded focus-visible:outline-2 focus-visible:outline-primary-500 focus-visible:outline-offset-2" data-cat-filter={category} type="button">
                  See all {catArticles.length}
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7" stroke-width="2"/></svg>
                </button>
              )}
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
              {catArticles.slice(0, 4).map((article) => (
                <a href={article.href} class="group block">
                  <div class="bg-white dark:bg-stone-900 rounded-xl overflow-hidden border border-stone-200 dark:border-stone-800 transition-[border-color,box-shadow] duration-300 hover:shadow-lg hover:border-stone-300 dark:hover:border-stone-700 h-full flex flex-col">
                    <div class="relative aspect-[16/10] overflow-hidden" style={article.heroImage ? undefined : getArticleGradientStyle(article.category)}>
                      {article.heroImage && (
                        <img src={article.heroImage} alt={article.heroImageAlt || article.title} class="w-full h-full object-cover" loading="lazy" />
                      )}
                      {isNewArticle(article.publishDate) && (
                        <span class="absolute top-2 left-2 card-badge card-badge-new">New</span>
                      )}
                      {article.narrationUrl && (
                        <span class="absolute top-2 right-2 card-badge card-badge-narration" title="Audio narration">
                          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M15.536 8.464a5 5 0 010 7.072M18.364 5.636a9 9 0 010 12.728M12 12h.01M11 7.5V4a1 1 0 00-1.707-.707L5.586 7H4a1 1 0 00-1 1v8a1 1 0 001 1h1.586l3.707 3.707A1 1 0 0011 20v-3.5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </span>
                      )}
                    </div>
                    <div class="p-4 flex flex-col flex-1">
                      <span class="text-xs text-stone-400 mb-1.5">{article.readTime} min read</span>
                      <h4 class="font-serif text-base font-semibold group-hover:text-primary-600 transition-colors leading-snug line-clamp-2">{article.title}</h4>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Filtered Grid (shown when a category is selected or search is active) -->
  <section class="py-12 md:py-16 bg-stone-50 dark:bg-stone-900/30" id="filteredView" style="display: none;">
    <div class="container-editorial">
      <!-- Category header (shown when a specific category is selected) -->
      <div id="categoryHeader" class="mb-10" style="display: none;">
        <div class="flex items-center gap-6 mb-2">
          <button class="text-sm text-stone-500 hover:text-stone-700 dark:hover:text-stone-300 transition-colors inline-flex items-center gap-1" id="backToAll" type="button">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 12H5M5 12l7 7M5 12l7-7" stroke-width="2"/></svg>
            All topics
          </button>
          <div class="flex-1 h-px bg-stone-200 dark:bg-stone-800"></div>
        </div>
        <h2 class="font-serif text-heading-2 font-semibold" id="categoryTitle"></h2>
        <span class="text-sm text-stone-500 mt-1 block" id="filteredCount"></span>
      </div>

      <!-- Search results header -->
      <div id="searchHeader" class="mb-10" style="display: none;">
        <div class="flex items-center gap-6">
          <span class="section-label">Search Results</span>
          <div class="flex-1 h-px bg-stone-200 dark:bg-stone-800"></div>
          <span class="text-xs text-stone-400 uppercase tracking-widest" id="searchCount"></span>
        </div>
      </div>

      <!-- No results message -->
      <div id="noResults" style="display: none;" class="py-16 text-center">
        <p class="font-serif text-heading-3 text-stone-400 dark:text-stone-500 mb-2">No articles found</p>
        <p class="text-sm text-stone-500 dark:text-stone-600">Try a different search term or topic.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="articlesGrid">
        {articles.map((article) => (
          <a href={article.href} class="article-grid-card group block" data-category={article.category} data-title={article.title.toLowerCase()} data-tags={article.tags.join(' ').toLowerCase()} data-keywords={(article.keywords ?? []).join(' ').toLowerCase()} data-read-time={article.readTime} data-date={article.sortOrder || new Date(article.publishDate).getTime()} data-narration={article.narrationUrl ? '1' : ''}>
            <div class="bg-white dark:bg-stone-900 rounded-2xl overflow-hidden border border-stone-200 dark:border-stone-800 transition-[border-color,box-shadow] duration-300 hover:shadow-lg hover:border-stone-300 dark:hover:border-stone-700 h-full flex flex-col">
              <div class="relative aspect-[16/10] overflow-hidden" style={article.heroImage ? undefined : getArticleGradientStyle(article.category)}>
                {article.heroImage && (
                  <img src={article.heroImage} alt={article.heroImageAlt || article.title} class="w-full h-full object-cover" loading="lazy" />
                )}
                {/* Discovery badges */}
                <div class="absolute top-2.5 left-2.5 flex flex-col gap-1">
                  {isNewArticle(article.publishDate) && (
                    <span class="card-badge card-badge-new">New</span>
                  )}
                </div>
                {article.narrationUrl && (
                  <span class="absolute top-2.5 right-2.5 card-badge card-badge-narration" title="Audio narration">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M15.536 8.464a5 5 0 010 7.072M18.364 5.636a9 9 0 010 12.728M12 12h.01M11 7.5V4a1 1 0 00-1.707-.707L5.586 7H4a1 1 0 00-1 1v8a1 1 0 001 1h1.586l3.707 3.707A1 1 0 0011 20v-3.5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </span>
                )}
              </div>
              <div class="p-5 flex flex-col flex-1">
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-xs font-semibold uppercase tracking-wide text-primary-600">{article.category}</span>
                  <span class="text-xs text-stone-400">{formatPublishDateShort(article.publishDate)}</span>
                </div>
                <h3 class="font-serif text-lg font-semibold mb-2 group-hover:text-primary-600 transition-colors leading-snug line-clamp-2">{article.title}</h3>
                <p class="font-body text-sm text-stone-500 dark:text-stone-400 line-clamp-2 mb-3 flex-1">{article.description}</p>
                <div class="flex items-center justify-between pt-3 border-t border-stone-100 dark:border-stone-800">
                  <span class="text-xs text-stone-400">{article.readTime} min read</span>
                  <svg class="w-4 h-4 text-stone-300 dark:text-stone-600 group-hover:text-primary-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path d="M5 12h14M12 5l7 7-7 7" stroke-width="2"/>
                  </svg>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Coming Soon -->
  {comingSoon.length > 0 && (
    <section class="py-12 md:py-16">
      <div class="container-editorial">
        <div class="flex items-center gap-6 mb-8">
          <span class="section-label">Coming Soon</span>
          <div class="flex-1 h-px bg-stone-200 dark:bg-stone-800"></div>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {comingSoon.map((article) => (
            <div class="bg-white dark:bg-stone-900 rounded-2xl overflow-hidden border border-stone-200 dark:border-stone-800 opacity-75">
              <div class="relative aspect-[16/10] overflow-hidden" style={article.heroImage ? undefined : getArticleGradientStyle(article.category)}>
                {article.heroImage && (
                  <img src={article.heroImage} alt={article.heroImageAlt || article.title} class="w-full h-full object-cover grayscale-[30%]" loading="lazy" />
                )}
                <span class="absolute top-3 right-3 px-2 py-1 bg-stone-900/80 text-white text-xs font-medium rounded">Coming Soon</span>
              </div>
              <div class="p-5">
                <span class="text-xs font-semibold uppercase tracking-wide text-primary-600 mb-2 block">{article.category}</span>
                <h3 class="font-serif text-lg font-semibold">{article.title}</h3>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- App CTA -->
  <section class="py-12 md:py-16 bg-white dark:bg-stone-900">
    <div class="container-editorial">
      <div class="max-w-2xl mx-auto flex flex-col sm:flex-row items-start sm:items-center gap-6 reveal">
        <div class="flex-1">
          <h3 class="font-serif text-xl font-semibold mb-2">Take Your Learning Further</h3>
          <p class="font-body text-sm text-stone-600 dark:text-stone-400 leading-relaxed">
            Upload labs, photograph meals, and run personal experiments — powered by Claude Opus.
          </p>
        </div>
        <a
          href="https://tune-sigma.vercel.app?utm_source=alumi-news&utm_medium=articles-index"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary text-sm whitespace-nowrap min-h-[44px]"
          aria-label="Try alumi Health free"
        >
          <span>Try alumi Health</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M7 17L17 7M17 7H7M17 7v10" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <Newsletter variant="compact" />

  <Footer slot="footer" />
  <CommandPaletteWrapper />
  <SideNav />
</BaseLayout>

<script>
  function initArticlesPage() {
    const searchInput = document.getElementById('articleSearch') as HTMLInputElement;
    const sortSelect = document.getElementById('articleSort') as HTMLSelectElement;
    const categoryOverview = document.getElementById('categoryOverview');
    const filteredView = document.getElementById('filteredView');
    const featuredRow = document.getElementById('featuredRow');
    const categoryHeader = document.getElementById('categoryHeader');
    const searchHeader = document.getElementById('searchHeader');
    const articlesGrid = document.getElementById('articlesGrid');
    const allCards = Array.from(document.querySelectorAll('#articlesGrid .article-grid-card')) as HTMLElement[];
    const backToAll = document.getElementById('backToAll');
    const seeAllBtns = document.querySelectorAll('.cat-see-all');
    const activeFiltersBar = document.getElementById('activeFilters');
    const activeTagLabel = document.getElementById('activeTagLabel');
    const clearTagBtn = document.getElementById('clearTagFilter');
    const clearAllBtn = document.getElementById('clearAllFilters');

    // Read URL params
    const params = new URLSearchParams(window.location.search);
    const topicParam = params.get('topic');
    const tagParam = params.get('tag');
    let activeCategory = 'all';
    let activeTag = tagParam || '';

    if (topicParam) {
      const validCategories = new Set<string>();
      allCards.forEach(card => {
        const cat = card.dataset.category;
        if (cat) validCategories.add(cat);
      });
      const topicLower = topicParam.toLowerCase();
      for (const cat of validCategories) {
        if (cat.toLowerCase() === topicLower) {
          activeCategory = cat;
          break;
        }
      }
    }

    function updateUrl() {
      const url = new URL(window.location.href);
      if (activeCategory === 'all') url.searchParams.delete('topic');
      else url.searchParams.set('topic', activeCategory);
      if (!activeTag) url.searchParams.delete('tag');
      else url.searchParams.set('tag', activeTag);
      history.replaceState(null, '', url.toString());
    }

    function showView(mode: 'overview' | 'filtered') {
      if (mode === 'overview') {
        if (categoryOverview) categoryOverview.style.display = '';
        if (filteredView) filteredView.style.display = 'none';
        if (featuredRow) featuredRow.style.display = '';
      } else {
        if (categoryOverview) categoryOverview.style.display = 'none';
        if (filteredView) filteredView.style.display = '';
        if (featuredRow) featuredRow.style.display = 'none';
      }
    }

    function sortCards() {
      const sortBy = sortSelect?.value || 'newest';
      allCards.sort((a, b) => {
        switch (sortBy) {
          case 'oldest':
            return Number(a.dataset.date || 0) - Number(b.dataset.date || 0);
          case 'shortest':
            return Number(a.dataset.readTime || 0) - Number(b.dataset.readTime || 0);
          case 'longest':
            return Number(b.dataset.readTime || 0) - Number(a.dataset.readTime || 0);
          case 'az':
            return (a.dataset.title || '').localeCompare(b.dataset.title || '');
          default: // newest
            return Number(b.dataset.date || 0) - Number(a.dataset.date || 0);
        }
      });
      if (articlesGrid) {
        allCards.forEach(card => articlesGrid.appendChild(card));
      }
    }

    function filterArticles() {
      const query = searchInput?.value.toLowerCase().trim() || '';
      const isSearching = !!query;
      const isCategoryFiltered = activeCategory !== 'all';
      const isTagFiltered = !!activeTag;
      const hasAnyFilter = isSearching || isCategoryFiltered || isTagFiltered;

      // Show/hide active filter bar
      if (activeFiltersBar) {
        activeFiltersBar.style.display = isTagFiltered ? '' : 'none';
        if (activeTagLabel) activeTagLabel.textContent = activeTag;
      }

      if (!hasAnyFilter && sortSelect?.value === 'newest') {
        showView('overview');
        return;
      }

      showView(hasAnyFilter ? 'filtered' : 'overview');
      if (!hasAnyFilter) return;

      let visibleCount = 0;
      const tagLower = activeTag.toLowerCase();

      allCards.forEach(card => {
        const category = card.dataset.category || '';
        const title = card.dataset.title || '';
        const tags = card.dataset.tags || '';
        const keywords = card.dataset.keywords || '';

        const matchesCategory = !isCategoryFiltered || category === activeCategory;
        const matchesTag = !isTagFiltered || tags.includes(tagLower);
        const matchesSearch = !isSearching || title.includes(query) || tags.includes(query) || keywords.includes(query) || category.toLowerCase().includes(query);

        if (matchesCategory && matchesTag && matchesSearch) {
          card.style.display = '';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });

      if (categoryHeader) categoryHeader.style.display = isCategoryFiltered && !isSearching && !isTagFiltered ? '' : 'none';
      if (searchHeader) searchHeader.style.display = isSearching || isTagFiltered ? '' : 'none';

      if (isCategoryFiltered && !isSearching && !isTagFiltered) {
        const titleEl = document.getElementById('categoryTitle');
        const countEl = document.getElementById('filteredCount');
        if (titleEl) titleEl.textContent = activeCategory;
        if (countEl) countEl.textContent = `${visibleCount} article${visibleCount !== 1 ? 's' : ''}`;
      }

      if (isSearching || isTagFiltered) {
        const countEl = document.getElementById('searchCount');
        const label = isTagFiltered && !isSearching ? `Tagged "${activeTag}"` : '';
        if (countEl) countEl.textContent = `${label ? label + ' · ' : ''}${visibleCount} result${visibleCount !== 1 ? 's' : ''}`;
      }

      const noResults = document.getElementById('noResults');
      if (noResults) noResults.style.display = visibleCount === 0 ? 'block' : 'none';
    }

    function setCategory(cat: string) {
      activeCategory = cat;
      updateUrl();
      filterArticles();
      if (cat !== 'all') {
        filteredView?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }

    function setTag(tag: string) {
      activeTag = tag;
      updateUrl();
      sortCards();
      filterArticles();
      if (tag) {
        filteredView?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }

    // "See all" buttons in category sections
    seeAllBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const cat = (btn as HTMLElement).dataset.catFilter || '';
        if (searchInput) searchInput.value = '';
        activeTag = '';
        setCategory(cat);
      });
    });

    // "Back to all" button
    backToAll?.addEventListener('click', () => {
      if (searchInput) searchInput.value = '';
      activeTag = '';
      setCategory('all');
      categoryOverview?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    // Tag filter clear
    clearTagBtn?.addEventListener('click', () => setTag(''));
    clearAllBtn?.addEventListener('click', () => {
      if (searchInput) searchInput.value = '';
      activeCategory = 'all';
      setTag('');
      setCategory('all');
    });

    // Sort change
    sortSelect?.addEventListener('change', () => {
      sortCards();
      // If sorted non-default, switch to filtered view to show sorted results
      if (sortSelect.value !== 'newest') {
        showView('filtered');
        filterArticles();
      } else {
        filterArticles();
      }
    });

    // Debounced search
    let searchTimer: ReturnType<typeof setTimeout>;
    searchInput?.addEventListener('input', () => {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(() => {
        if (searchInput.value.trim()) {
          activeCategory = 'all';
        }
        filterArticles();
      }, 150);
    });

    // Apply initial state
    if (activeTag) {
      sortCards();
    }
    filterArticles();
  }

  initArticlesPage();
  document.addEventListener('astro:after-swap', initArticlesPage);
</script>

