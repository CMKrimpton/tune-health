  }

  /* ─── Glass Sort Dropdown ─── */
  .sort-dropdown {
    position: relative;
  }

  .sort-dropdown-trigger {
    @apply flex items-center gap-2 px-4 py-3 text-sm font-medium;
    @apply bg-white dark:bg-stone-800;
    @apply border border-stone-200 dark:border-stone-700;
    @apply rounded-full cursor-pointer;
    @apply text-stone-700 dark:text-stone-300;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .sort-dropdown-trigger:hover {
    @apply border-stone-300 dark:border-stone-600;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .sort-dropdown-chevron {
    @apply w-4 h-4 text-stone-400;
    transition: transform 0.2s ease;
  }

  .sort-dropdown.open .sort-dropdown-chevron {
    transform: rotate(180deg);
  }

  .sort-dropdown-menu {
    @apply absolute right-0 mt-2 z-50;
    @apply bg-white/95 dark:bg-stone-900/95 backdrop-blur-md;
    @apply border border-stone-200/60 dark:border-stone-700/60;
    @apply rounded-xl overflow-hidden;
    @apply opacity-0 invisible;
    min-width: 160px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1), 0 2px 8px rgba(0, 0, 0, 0.06);
    transform: translateY(-4px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
    list-style: none;
    padding: 0.25rem;
    margin: 0;
  }

  :global(.dark) .sort-dropdown-menu {
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3), 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  .sort-dropdown.open .sort-dropdown-menu {
    @apply opacity-100 visible;
    transform: translateY(0);
  }

  .sort-dropdown-option {
    @apply px-3 py-2.5 text-sm cursor-pointer;
    @apply text-stone-600 dark:text-stone-400;
    @apply rounded-lg;
    min-height: 44px;
    display: flex;
    align-items: center;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .sort-dropdown-option:hover {
    @apply bg-stone-100 dark:bg-stone-800;
    @apply text-stone-900 dark:text-white;
  }

  .sort-dropdown-option.active {
    @apply text-primary-600 dark:text-primary-400 font-medium;
  }

</style>
