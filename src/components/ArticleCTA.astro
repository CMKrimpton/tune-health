---
/**
 * ArticleCTA — contextual call-to-action shown at the end of articles.
 * Maps the article's category to the most relevant alumi Health feature.
 */
import { getCTAForCategory, getAppLink } from '../utils/funnel';

interface Props {
  category: string;
  slug?: string;
}

const { category, slug } = Astro.props;
const cta = getCTAForCategory(category);
const categorySlug = category.toLowerCase().replace(/\s+/g, '-');
const appLink = getAppLink(cta.appPath, {
  medium: 'article-cta',
  campaign: categorySlug,
  content: slug,
});
---

<aside class="app-cta reveal" role="complementary" aria-label="Try alumi Health">
  <div class="flex flex-col sm:flex-row gap-6 sm:gap-8 items-start">
    <!-- Icon -->
    <div class="app-cta-icon flex-shrink-0" aria-hidden="true">
      {cta.icon === 'lab' && (
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path d="M9 3v2m6-2v2M9 5a2 2 0 00-2 2v1a2 2 0 002 2h.93a2 2 0 011.664.89l.812 1.22A2 2 0 0114.07 12H15a2 2 0 002-2V7a2 2 0 00-2-2M9 5h6M7 21h10a2 2 0 002-2v-5.586a1 1 0 00-.293-.707l-1.414-1.414A1 1 0 0016.586 11H7.414a1 1 0 00-.707.293l-1.414 1.414A1 1 0 005 13.414V19a2 2 0 002 2z" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      )}
      {cta.icon === 'meal' && (
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path d="M3 9a2 2 0 012-2h14a2 2 0 012 2M3 9v9a2 2 0 002 2h14a2 2 0 002-2V9M3 9l3-4h12l3 4M12 13v4M8 13v2m8-2v2" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      )}
      {cta.icon === 'ai' && (
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      )}
      {cta.icon === 'experiment' && (
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      )}
    </div>

    <!-- Content -->
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-[10px] font-semibold uppercase tracking-widest text-stone-400 dark:text-stone-500">From reading to action</span>
      </div>
      <h3 class="font-serif text-xl sm:text-2xl font-semibold mb-2 text-stone-900 dark:text-stone-100">{cta.headline}</h3>
      <p class="font-body text-stone-600 dark:text-stone-400 mb-4 leading-relaxed">{cta.description}</p>
      <div class="flex flex-wrap items-center gap-3">
        <a
          href={appLink}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary text-sm"
          aria-label={`Try ${cta.featureName} in alumi Health`}
        >
          <span>Try Free</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M5 12h14M12 5l7 7-7 7" stroke-width="2"/>
          </svg>
        </a>
        <span class="app-cta-feature-pill">{cta.featureName}</span>
      </div>
    </div>

    <!-- Brand mark -->
    <div class="hidden sm:block flex-shrink-0 text-right">
      <span class="text-xs font-medium text-stone-400 dark:text-stone-500">
        <span class="text-primary-500 font-bold">a</span>lumi Health
      </span>
    </div>
  </div>
</aside>
