---
/**
 * SideNav - Glass sidebar that reveals on left edge hover
 * Premium editorial navigation experience
 */
import { getArticles, getCategories, getCategoriesWithCounts, getAllSeries, truncate, isNewArticle } from '../utils/articles';
import { CATEGORY_DOMAINS, getCategorySlug } from '../utils/category-domains';

const articles = await getArticles();
const featuredArticles = articles.slice(0, 5);
const categoriesWithCounts = await getCategoriesWithCounts();
const countMap = new Map(categoriesWithCounts.map(c => [c.name, c.count]));
const publishedSeries = await getAllSeries();
---

<aside class="side-nav" id="sideNav" aria-label="Sidebar navigation">
  <!-- Hover trigger zone -->
  <div class="side-nav-trigger" id="sideNavTrigger"></div>

  <!-- Glass panel -->
  <nav class="side-nav-panel">
    <div class="side-nav-content">
      <!-- Logo -->
      <a href="/" class="side-nav-logo">
        <span class="text-primary-600 font-bold">a</span>lumi
      </a>

      <!-- Scrollable content -->
      <div class="side-nav-scroll">
        <!-- Sections -->
        <div class="side-nav-section">
          <span class="side-nav-label">Sections</span>
          <ul class="side-nav-links">
            <li>
              <a href="/" class="side-nav-link">
                <span class="side-nav-link-text">Home</span>
              </a>
            </li>
            <li>
              <a href="/articles" class="side-nav-link">
                <span class="side-nav-link-text">All Articles</span>
              </a>
            </li>
            <li>
              <a href="/deep-dives" class="side-nav-link">
                <span class="side-nav-link-text">Deep Dives</span>
              </a>
            </li>
            <li>
              <a href="/start-here" class="side-nav-link">
                <span class="side-nav-link-text">Start Here</span>
              </a>
            </li>
            <li>
              <a href="/collections" class="side-nav-link">
                <span class="side-nav-link-text">Collections</span>
              </a>
            </li>
          </ul>
        </div>

        <!-- Topics — grouped by domain -->
        {CATEGORY_DOMAINS.map((domain) => {
          const activeCats = domain.categories.filter(c => (countMap.get(c) || 0) > 0);
          if (activeCats.length === 0) return null;
          return (
            <div class="side-nav-section">
              <span class="side-nav-label">{domain.label}</span>
              <ul class="side-nav-links">
                {activeCats.map((cat) => (
                  <li>
                    <a href={`/topics/${getCategorySlug(cat)}`} class="side-nav-link">
                      <span class="side-nav-link-text">{cat}</span>
                      <span class="side-nav-meta">{countMap.get(cat)}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          );
        })}

        <!-- Featured -->
        <div class="side-nav-section">
          <span class="side-nav-label">Featured</span>
          <ul class="side-nav-links">
            {featuredArticles.map((article) => (
              <li>
                <a href={article.href} class="side-nav-link">
                  <span class="side-nav-link-text">{truncate(article.title, 30)}</span>
                  {isNewArticle(article.publishDate) && (
                    <span class="side-nav-badge">New</span>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Series -->
        {publishedSeries.length > 0 && (
          <div class="side-nav-section">
            <span class="side-nav-label">Series</span>
            <ul class="side-nav-links">
              {publishedSeries.map((series) => (
                <li>
                  <a href={series.articles[0].href} class="side-nav-link">
                    <span class="side-nav-link-text">{truncate(series.name, 28)}</span>
                    <span class="side-nav-meta">{series.articles.length} parts</span>
                  </a>
                </li>
              ))}
              <li>
                <a href="/deep-dives" class="side-nav-link">
                  <span class="side-nav-link-text text-primary-600 dark:text-primary-400">All Deep Dives</span>
                </a>
              </li>
            </ul>
          </div>
        )}

        <!-- More -->
        <div class="side-nav-section">
          <span class="side-nav-label">More</span>
          <ul class="side-nav-links">
            <li>
              <a href="/reading-list" class="side-nav-link" id="sideNavReadingList">
                <svg class="w-3.5 h-3.5 flex-shrink-0 text-stone-400 dark:text-stone-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span class="side-nav-link-text">Reading List</span>
                <span class="side-nav-reading-count" id="sideNavReadingCount" style="display: none;"></span>
              </a>
            </li>
            <li>
              <a href="/subscribe" class="side-nav-link">
                <span class="side-nav-link-text">Subscribe</span>
              </a>
            </li>
            <li>
              <a href="/about" class="side-nav-link">
                <span class="side-nav-link-text">About</span>
              </a>
            </li>
            <li>
              <a href="/rss.xml" class="side-nav-link" aria-label="RSS Feed">
                <svg class="w-3.5 h-3.5 flex-shrink-0 text-stone-400 dark:text-stone-500" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M6.503 20.752c0 1.794-1.456 3.248-3.251 3.248-1.796 0-3.252-1.454-3.252-3.248 0-1.794 1.456-3.248 3.252-3.248 1.795.001 3.251 1.454 3.251 3.248zm-6.503-12.572v4.811c6.05.062 10.96 4.966 11.022 11.009h4.817c-.062-8.71-7.118-15.758-15.839-15.82zm0-8.18v4.819c12.484.074 22.592 10.175 22.661 22.66h4.823c-.074-15.14-12.345-27.404-27.484-27.479z"/>
                </svg>
                <span class="side-nav-link-text">RSS Feed</span>
              </a>
            </li>
          </ul>
        </div>

        <!-- App Promo -->
        <div class="side-nav-section">
          <span class="side-nav-label">App</span>
          <a
            href="https://tune-sigma.vercel.app?utm_source=alumi-news&utm_medium=sidenav"
            target="_blank"
            rel="noopener noreferrer"
            class="block p-3 rounded-xl bg-primary-50 dark:bg-primary-900/20 border border-primary-100 dark:border-primary-800/50 hover:bg-primary-100 dark:hover:bg-primary-900/30 transition-colors duration-200"
            aria-label="Try alumi Health — AI-powered health tracking"
          >
            <span class="block text-xs font-semibold text-primary-600 dark:text-primary-400 mb-0.5">
              <span class="font-bold">a</span>lumi Health
            </span>
            <span class="block text-xs text-stone-500 dark:text-stone-400 leading-snug mb-2">
              Track your health with AI. Labs, meals, and experiments.
            </span>
            <span class="inline-flex items-center gap-1 text-xs font-semibold text-primary-600 dark:text-primary-400">
              Try Free
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path d="M5 12h14M12 5l7 7-7 7" stroke-width="2"/>
              </svg>
            </span>
          </a>
        </div>
      </div>

      <!-- Fixed footer -->
      <div class="side-nav-footer">
        <div class="side-nav-actions">
          <button class="side-nav-action-btn" id="sideNavSearch" title="Search">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <circle cx="11" cy="11" r="8" stroke-width="2"/>
              <path d="m21 21-4.35-4.35" stroke-width="2"/>
            </svg>
            <span class="sr-only">Search</span>
          </button>
          <button class="side-nav-action-btn" id="sideNavTheme" title="Toggle theme">
            <!-- System icon (monitor) -->
            <svg data-theme-icon="system" class="w-4 h-4 text-stone-500 dark:text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2" stroke-width="2"/>
              <line x1="8" y1="21" x2="16" y2="21" stroke-width="2"/>
              <line x1="12" y1="17" x2="12" y2="21" stroke-width="2"/>
            </svg>
            <!-- Light icon (sun) -->
            <svg data-theme-icon="light" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:none">
              <circle cx="12" cy="12" r="5" stroke-width="2"/>
              <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" stroke-width="2"/>
            </svg>
            <!-- Dark icon (moon) -->
            <svg data-theme-icon="dark" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:none">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" stroke-width="2"/>
            </svg>
            <span class="sr-only">Toggle theme</span>
          </button>
        </div>
        <a href="/subscribe" class="side-nav-subscribe-btn">
          Subscribe
        </a>
        <p class="side-nav-hint">⌘K to search</p>
      </div>
    </div>
  </nav>
</aside>

<style>
  .side-nav-scroll {
    @apply flex-1 overflow-y-auto overflow-x-hidden;
    @apply -mx-2 px-2;
    scrollbar-width: thin;
    scrollbar-color: theme('colors.stone.400 / 30%') transparent;
  }

  .side-nav-scroll::-webkit-scrollbar {
    width: 4px;
  }

  .side-nav-scroll::-webkit-scrollbar-track {
    background: transparent;
  }

  .side-nav-scroll::-webkit-scrollbar-thumb {
    background: theme('colors.stone.400 / 30%');
    border-radius: 2px;
  }

  .side-nav-scroll::-webkit-scrollbar-thumb:hover {
    background: theme('colors.stone.400 / 50%');
  }

  .side-nav-badge {
    @apply text-xs font-semibold uppercase tracking-wide;
    @apply px-1.5 py-0.5 rounded;
    @apply bg-primary-100 text-primary-700;
    @apply dark:bg-primary-900/30 dark:text-primary-400;
  }

  .side-nav-meta {
    @apply text-xs text-stone-400 dark:text-stone-500;
  }

  .side-nav-reading-count {
    @apply text-xs font-semibold;
    @apply min-w-[18px] h-[18px] px-1 rounded-full;
    @apply bg-primary-100 text-primary-700;
    @apply dark:bg-primary-900/30 dark:text-primary-400;
    @apply inline-flex items-center justify-center;
  }

  .side-nav-actions {
    @apply flex items-center gap-2 mb-3;
  }

  .side-nav-action-btn {
    @apply w-11 h-11 rounded-lg;
    @apply flex items-center justify-center;
    @apply text-stone-500 dark:text-stone-400;
    @apply hover:bg-stone-100 dark:hover:bg-stone-800;
    @apply hover:text-stone-700 dark:hover:text-stone-200;
    @apply transition-colors duration-200;
  }

  .side-nav-subscribe-btn {
    @apply w-full py-2 px-4 rounded-lg;
    @apply bg-primary-600 text-white text-sm font-medium;
    @apply hover:bg-primary-700;
    @apply transition-colors duration-200 text-center;
    @apply mb-3;
  }

  .side-nav-hint {
    @apply text-xs text-stone-400 dark:text-stone-400 text-center;
  }
</style>

<script>
  let sideNavController: AbortController | null = null;

  function initSideNav() {
    if (sideNavController) sideNavController.abort();
    sideNavController = new AbortController();
    const signal = sideNavController.signal;

    const sideNav = document.getElementById('sideNav');
    const trigger = document.getElementById('sideNavTrigger');

    if (!sideNav || !trigger) return;

    let isOpen = false;
    let closeTimeout: ReturnType<typeof setTimeout>;

    function openNav() {
      clearTimeout(closeTimeout);
      if (!isOpen) {
        isOpen = true;
        sideNav.classList.add('open');
      }
    }

    function closeNav() {
      closeTimeout = setTimeout(() => {
        isOpen = false;
        sideNav.classList.remove('open');
      }, 300);
    }

    trigger.addEventListener('mouseenter', openNav, { signal });

    sideNav.querySelector('.side-nav-panel')?.addEventListener('mouseenter', () => {
      clearTimeout(closeTimeout);
    }, { signal });

    sideNav.addEventListener('mouseleave', closeNav, { signal });

    // Search button → command palette
    document.getElementById('sideNavSearch')?.addEventListener('click', () => {
      document.getElementById('cmdkTrigger')?.click();
    }, { signal });

    // Theme toggle
    document.getElementById('sideNavTheme')?.addEventListener('click', () => {
      (window as unknown as { toggleTheme?: () => void }).toggleTheme?.();
    }, { signal });

    // Reading list count badge
    function updateReadingCount() {
      const countEl = document.getElementById('sideNavReadingCount');
      if (!countEl) return;
      try {
        const list = JSON.parse(localStorage.getItem('alumi-reading-list') || '[]');
        if (list.length > 0) {
          countEl.textContent = String(list.length);
          countEl.style.display = '';
        } else {
          countEl.style.display = 'none';
        }
      } catch { countEl.style.display = 'none'; }
    }
    updateReadingCount();
    window.addEventListener('storage', updateReadingCount, { signal });

    // Active page tracking — cleaner matching logic
    const currentPath = window.location.pathname;
    const isActive = (href: string) => {
      if (href === '/') return currentPath === '/';
      const cleanHref = href.split('?')[0].split('#')[0]; // strip query/hash
      return currentPath === cleanHref || currentPath.startsWith(cleanHref + '/');
    };

    sideNav.querySelectorAll('.side-nav-link').forEach(link => {
      const href = link.getAttribute('href');
      if (href && isActive(href)) link.classList.add('active');
    });
  }

  initSideNav();
  document.addEventListener('astro:after-swap', initSideNav);
</script>
