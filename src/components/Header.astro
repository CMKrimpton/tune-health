---
import MenuDropdownContent from './MenuDropdownContent.astro';

interface Props {
  variant?: 'home' | 'article';
}

const { variant = 'home' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<header class="nav-header" id="header" transition:persist>
  <nav class="nav-inner">
    <!-- Left Nav - Menu Button -->
    <div class="flex-1 flex items-center gap-6">
      {variant === 'home' ? (
        <div class="relative" id="menuDropdownWrapper">
          <button
            class="menu-toggle-btn group"
            id="menuToggleBtn"
            aria-label="Open menu"
            aria-expanded="false"
          >
            <div class="menu-icon">
              <span class="menu-icon-line"></span>
              <span class="menu-icon-line"></span>
              <span class="menu-icon-line"></span>
            </div>
            <span class="hidden lg:inline text-sm font-medium text-stone-600 dark:text-stone-400 group-hover:text-stone-900 dark:group-hover:text-white transition-colors">Menu</span>
          </button>

          <div class="menu-dropdown" id="menuDropdown">
            <MenuDropdownContent currentPath={currentPath} showLatest={true} />
          </div>
        </div>
      ) : (
        <div class="flex items-center gap-3">
          <div class="relative" id="menuDropdownWrapper">
            <button
              class="menu-toggle-btn group"
              id="menuToggleBtn"
              aria-label="Open menu"
              aria-expanded="false"
            >
              <div class="menu-icon">
                <span class="menu-icon-line"></span>
                <span class="menu-icon-line"></span>
                <span class="menu-icon-line"></span>
              </div>
            </button>

            <div class="menu-dropdown" id="menuDropdown">
              <MenuDropdownContent currentPath={currentPath} />
            </div>
          </div>
          <a href="/" class="flex items-center gap-1 text-sm font-medium text-stone-500 dark:text-stone-400 hover:text-stone-900 dark:hover:text-white transition-colors">
            <span class="hidden sm:inline">Home</span>
          </a>
          <span class="text-stone-300 dark:text-stone-700">/</span>
          <a href="/articles" class="text-sm font-medium text-stone-500 dark:text-stone-400 hover:text-stone-900 dark:hover:text-white transition-colors">Articles</a>
        </div>
      )}
    </div>

    <!-- Logo -->
    <a href="/" class="flex items-baseline font-sans text-xl md:text-2xl font-semibold group">
      <span class="text-primary-600 font-bold text-2xl md:text-3xl transition-transform duration-300 group-hover:scale-110" transition:name="logo-a">a</span><span class="text-stone-900 dark:text-white" transition:name="logo-lumi">lumi</span>
      <em class="ml-1.5 font-normal text-stone-600 dark:text-stone-400" transition:name="logo-news">news</em>
    </a>

    <!-- Right Nav -->
    <div class="flex-1 flex items-center justify-end gap-3">
      <!-- alumi Health Link -->
      <a
        href="https://tune-sigma.vercel.app?utm_source=alumi-news&utm_medium=header"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-primary-600 dark:text-primary-400 bg-primary-50 dark:bg-primary-900/20 rounded-full hover:bg-primary-100 dark:hover:bg-primary-900/40 transition-colors"
        aria-label="Try alumi Health — AI-powered health tracking"
      >
        <span><span class="font-bold">a</span>lumi Health</span>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path d="M7 17L17 7M17 7H7M17 7v10" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>

      <!-- Command Palette Trigger -->
      <button
        class="hidden sm:flex items-center gap-2 px-3 py-1.5 text-sm text-stone-500 dark:text-stone-400 bg-stone-100 dark:bg-stone-800 rounded-lg hover:bg-stone-200 dark:hover:bg-stone-700 transition-colors"
        id="cmdkTrigger"
        aria-label="Open command palette"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <circle cx="11" cy="11" r="8" stroke-width="2"/>
          <path d="m21 21-4.35-4.35" stroke-width="2"/>
        </svg>
        <span class="text-xs">⌘K</span>
      </button>

      <!-- Mobile Search -->
      <button class="sm:hidden w-10 h-10 rounded-full flex items-center justify-center hover:bg-stone-100 dark:hover:bg-stone-800 transition-colors" id="cmdkTriggerMobile" aria-label="Search">
        <svg class="w-5 h-5 text-stone-600 dark:text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <circle cx="11" cy="11" r="8" stroke-width="2"/>
          <path d="m21 21-4.35-4.35" stroke-width="2"/>
        </svg>
      </button>

      <!-- Theme Toggle (cycles: system → light → dark) -->
      <button class="w-10 h-10 rounded-full flex items-center justify-center hover:bg-stone-100 dark:hover:bg-stone-800 transition-colors" id="themeToggle" aria-label="Toggle theme">
        <!-- System icon (monitor) -->
        <svg data-theme-icon="system" class="w-5 h-5 text-stone-500 dark:text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <rect x="2" y="3" width="20" height="14" rx="2" ry="2" stroke-width="2"/>
          <line x1="8" y1="21" x2="16" y2="21" stroke-width="2"/>
          <line x1="12" y1="17" x2="12" y2="21" stroke-width="2"/>
        </svg>
        <!-- Light icon (sun) -->
        <svg data-theme-icon="light" class="w-5 h-5 text-stone-600 dark:text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:none">
          <circle cx="12" cy="12" r="5" stroke-width="2"/>
          <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" stroke-width="2"/>
        </svg>
        <!-- Dark icon (moon) -->
        <svg data-theme-icon="dark" class="w-5 h-5 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:none">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" stroke-width="2"/>
        </svg>
      </button>
    </div>
  </nav>
</header>

<style>
  /* Menu Toggle Button */
  .menu-toggle-btn {
    @apply flex items-center gap-2;
    @apply px-2 py-2 lg:px-3 lg:py-2;
    @apply rounded-lg;
    @apply hover:bg-stone-100 dark:hover:bg-stone-800;
    @apply transition-all duration-200;
  }

  .menu-icon {
    @apply flex flex-col justify-center gap-1 w-5 h-5;
  }

  .menu-icon-line {
    @apply w-full h-0.5 bg-stone-600 dark:bg-stone-400;
    @apply transition-all duration-300 origin-center;
  }

  .menu-toggle-btn[aria-expanded="true"] .menu-icon-line:nth-child(1) {
    @apply translate-y-[6px] rotate-45;
  }

  .menu-toggle-btn[aria-expanded="true"] .menu-icon-line:nth-child(2) {
    @apply opacity-0;
  }

  .menu-toggle-btn[aria-expanded="true"] .menu-icon-line:nth-child(3) {
    @apply -translate-y-[6px] -rotate-45;
  }

  /* Dropdown Menu */
  .menu-dropdown {
    @apply absolute top-full left-0 mt-2;
    @apply w-screen max-w-md lg:max-w-2xl;
    @apply opacity-0 invisible;
    @apply transform -translate-y-2;
    @apply z-50;
    transition: opacity 0.3s ease, transform 0.3s ease, visibility 0.3s ease;
  }

  .menu-dropdown.open {
    @apply opacity-100 visible translate-y-0;
  }
</style>

<script>
  let headerController: AbortController | null = null;

  function initHeader() {
    // Clean up previous listeners to prevent leaks across View Transitions
    if (headerController) headerController.abort();
    headerController = new AbortController();
    const signal = headerController.signal;

    const menuBtn = document.getElementById('menuToggleBtn');
    const menuDropdown = document.getElementById('menuDropdown');
    const menuWrapper = document.getElementById('menuDropdownWrapper');

    if (!menuBtn || !menuDropdown || !menuWrapper) return;

    let isOpen = false;
    let isHovering = false;
    let closeTimeout: ReturnType<typeof setTimeout> | null = null;

    function openMenu() {
      if (closeTimeout) {
        clearTimeout(closeTimeout);
        closeTimeout = null;
      }
      isOpen = true;
      menuBtn.setAttribute('aria-expanded', 'true');
      menuDropdown.classList.add('open');
    }

    function closeMenu() {
      isOpen = false;
      menuBtn.setAttribute('aria-expanded', 'false');
      menuDropdown.classList.remove('open');
    }

    // Open on hover
    menuWrapper.addEventListener('mouseenter', () => {
      isHovering = true;
      openMenu();
    }, { signal });

    // Close on mouse leave with guard against race condition
    menuWrapper.addEventListener('mouseleave', () => {
      isHovering = false;
      closeTimeout = setTimeout(() => {
        if (!isHovering) closeMenu();
      }, 250); // Match CSS transition duration
    }, { signal });

    // Click toggle for mobile/touch
    menuBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      if (isOpen) closeMenu(); else openMenu();
    }, { signal });

    // Close on escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) closeMenu();
    }, { signal });

    // Close when clicking a link inside the dropdown
    menuDropdown.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => closeMenu(), { signal });
    });

    // Close on outside click (touch devices)
    document.addEventListener('click', (e) => {
      if (isOpen && !menuWrapper.contains(e.target as Node)) closeMenu();
    }, { signal });
  }

  initHeader();
  document.addEventListener('astro:after-swap', initHeader);
</script>
