---
/**
 * ShareButtons — expanded share row for article pages.
 * X, LinkedIn, Facebook, Reddit, Bluesky, WhatsApp, Email, copy-link, and native Web Share API.
 */

interface Props {
  title: string;
  url: string;
  description?: string;
  variant?: 'inline' | 'vertical';
}

const { title, url, description = '', variant = 'inline' } = Astro.props;

const siteUrl = Astro.site?.origin || 'https://tune-health.vercel.app';
const fullUrl = `${siteUrl}${url}`;
const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(fullUrl);
const encodedDescription = encodeURIComponent(description || title);

const twitterHref = `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`;
const linkedInHref = `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`;
const facebookHref = `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`;
const redditHref = `https://reddit.com/submit?url=${encodedUrl}&title=${encodedTitle}`;
const blueskyHref = `https://bsky.app/intent/compose?text=${encodedTitle}%20${encodedUrl}`;
const whatsappHref = `https://api.whatsapp.com/send?text=${encodedTitle}%20${fullUrl}`;
const emailHref = `mailto:?subject=${encodedTitle}&body=I thought you'd find this interesting:%0A%0A${encodedUrl}`;

const isVertical = variant === 'vertical';
---

<div
  class:list={['share-buttons', { 'share-buttons--vertical': isVertical, 'share-buttons--inline': !isVertical }]}
  role="group"
  aria-label="Share this article"
>
  <!-- X / Twitter -->
  <a
    href={twitterHref}
    target="_blank"
    rel="noopener noreferrer"
    class="share-btn share-btn--x"
    aria-label={`Share on X`}
    title="Share on X"
  >
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
    </svg>
  </a>

  <!-- LinkedIn -->
  <a
    href={linkedInHref}
    target="_blank"
    rel="noopener noreferrer"
    class="share-btn share-btn--linkedin"
    aria-label={`Share on LinkedIn`}
    title="Share on LinkedIn"
  >
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
    </svg>
  </a>

  <!-- Facebook -->
  <a
    href={facebookHref}
    target="_blank"
    rel="noopener noreferrer"
    class="share-btn share-btn--facebook"
    aria-label={`Share on Facebook`}
    title="Share on Facebook"
  >
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
    </svg>
  </a>

  <!-- Reddit -->
  <a
    href={redditHref}
    target="_blank"
    rel="noopener noreferrer"
    class="share-btn share-btn--reddit"
    aria-label={`Share on Reddit`}
    title="Share on Reddit"
  >
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/>
    </svg>
  </a>

  <!-- Bluesky -->
  <a
    href={blueskyHref}
    target="_blank"
    rel="noopener noreferrer"
    class="share-btn share-btn--bluesky"
    aria-label={`Share on Bluesky`}
    title="Share on Bluesky"
  >
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.785 2.627 3.62 3.501 6.204 3.254-3.96.582-6.71 2.483-4.058 6.77 2.953 4.327 6.227 1.726 7.23-.278.998 2.004 3.57 4.605 7.23.278 2.652-4.287-.098-6.188-4.058-6.77 2.584.247 5.42-.627 6.204-3.254.246-.83.624-5.79.624-6.479 0-.688-.139-1.86-.902-2.203-.66-.299-1.664-.621-4.3 1.24C12.04 4.747 9.087 8.686 12 10.8z"/>
    </svg>
  </a>

  <!-- WhatsApp (visible on mobile, hidden on large screens for vertical) -->
  <a
    href={whatsappHref}
    target="_blank"
    rel="noopener noreferrer"
    class:list={['share-btn share-btn--whatsapp', { 'hidden lg:hidden': false }]}
    aria-label={`Share on WhatsApp`}
    title="Share on WhatsApp"
  >
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>

  <!-- Email -->
  <a
    href={emailHref}
    class="share-btn share-btn--email"
    aria-label={`Share via email`}
    title="Share via email"
  >
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
      <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </a>

  <!-- Copy link -->
  <button
    class="share-btn share-btn--copy"
    data-share-copy
    data-share-url={fullUrl}
    aria-label="Copy article link"
    title="Copy link"
  >
    <svg class="w-4 h-4 share-copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
      <path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M10.172 13.828a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.102 1.101" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <svg class="w-4 h-4 share-check-icon hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
      <path d="M5 13l4 4L19 7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <!-- Native Web Share (mobile only) -->
  <button
    class="share-btn share-btn--native hidden"
    data-web-share
    data-share-title={title}
    data-share-text={description || title}
    data-share-url={fullUrl}
    aria-label="Share article"
    title="More sharing options"
  >
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
      <path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <polyline points="16 6 12 2 8 6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <line x1="12" y1="2" x2="12" y2="15" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
</div>

<style>
  .share-buttons--inline {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .share-buttons--vertical {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.375rem;
  }

  .share-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 9999px;
    color: var(--tw-stone-500, #78716c);
    transition: color 0.2s ease-out, background-color 0.2s ease-out, transform 0.2s ease-out;
    cursor: pointer;
    border: none;
    background: transparent;
  }

  .share-buttons--vertical .share-btn {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: theme('colors.stone.100 / 80%');
  }

  :global(.dark) .share-buttons--vertical .share-btn {
    background: theme('colors.stone.800 / 80%');
  }

  .share-btn:hover {
    transform: scale(1.05);
  }

  .share-btn:focus-visible {
    outline: 2px solid theme('colors.primary.500');
    outline-offset: 2px;
  }

  .share-btn--x:hover { color: var(--brand-x, #000); }
  :global(.dark) .share-btn--x:hover { color: var(--brand-x-dark, #fff); }

  .share-btn--linkedin:hover { color: var(--brand-linkedin, #0a66c2); }
  .share-btn--facebook:hover { color: var(--brand-facebook, #1877f2); }
  .share-btn--reddit:hover { color: var(--brand-reddit, #ff4500); }
  .share-btn--bluesky:hover { color: var(--brand-bluesky, #0085ff); }
  .share-btn--whatsapp:hover { color: var(--brand-whatsapp, #25d366); }

  .share-btn--email:hover {
    color: var(--tw-stone-700, #44403c);
  }
  :global(.dark) .share-btn--email:hover {
    color: var(--tw-stone-200, #e7e5e4);
  }

  .share-btn--copy:hover,
  .share-btn--native:hover {
    color: var(--tw-stone-700, #44403c);
    background-color: var(--tw-stone-100, #f5f5f4);
  }
  :global(.dark) .share-btn--copy:hover,
  :global(.dark) .share-btn--native:hover {
    color: var(--tw-stone-200, #e7e5e4);
    background-color: var(--tw-stone-800, #292524);
  }

  .share-btn--copy.copied {
    color: #16a34a;
  }
  :global(.dark) .share-btn--copy.copied {
    color: #4ade80;
  }

  /* On inline variant, hide some platforms on small screens */
  .share-buttons--inline .share-btn--bluesky,
  .share-buttons--inline .share-btn--reddit {
    display: none;
  }

  @media (min-width: 640px) {
    .share-buttons--inline .share-btn--bluesky,
    .share-buttons--inline .share-btn--reddit {
      display: flex;
    }
  }
</style>

<script>
  function initShareButtons() {
    // Copy link buttons
    document.querySelectorAll<HTMLButtonElement>('[data-share-copy]').forEach((btn) => {
      if ((btn as HTMLElement).dataset.bound === 'share') return;
      (btn as HTMLElement).dataset.bound = 'share';

      btn.addEventListener('click', async () => {
        const url = btn.getAttribute('data-share-url');
        if (!url) return;

        try {
          await navigator.clipboard.writeText(url);
        } catch {
          const textarea = document.createElement('textarea');
          textarea.value = url;
          textarea.style.position = 'fixed';
          textarea.style.opacity = '0';
          document.body.appendChild(textarea);
          textarea.select();
          document.execCommand('copy');
          document.body.removeChild(textarea);
        }

        const copyIcon = btn.querySelector('.share-copy-icon') as HTMLElement;
        const checkIcon = btn.querySelector('.share-check-icon') as HTMLElement;

        btn.classList.add('copied');
        btn.setAttribute('aria-label', 'Link copied!');
        copyIcon?.classList.add('hidden');
        checkIcon?.classList.remove('hidden');

        setTimeout(() => {
          btn.classList.remove('copied');
          btn.setAttribute('aria-label', 'Copy article link');
          copyIcon?.classList.remove('hidden');
          checkIcon?.classList.add('hidden');
        }, 2000);
      });
    });

    // Native Web Share API
    document.querySelectorAll<HTMLButtonElement>('[data-web-share]').forEach((btn) => {
      if ('share' in navigator) {
        btn.classList.remove('hidden');

        if ((btn as HTMLElement).dataset.bound === 'webshare') return;
        (btn as HTMLElement).dataset.bound = 'webshare';

        btn.addEventListener('click', async () => {
          try {
            await navigator.share({
              title: btn.dataset.shareTitle || '',
              text: btn.dataset.shareText || '',
              url: btn.dataset.shareUrl || '',
            });
          } catch {
            // User cancelled or share failed — do nothing
          }
        });
      }
    });
  }

  initShareButtons();
  document.addEventListener('astro:after-swap', initShareButtons);
</script>
