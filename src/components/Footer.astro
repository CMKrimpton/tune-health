---
import { getArticles, getCategories } from '../utils/articles';

const articles = await getArticles();
const categories = await getCategories();
const latestArticles = articles.slice(0, 4);
---

<footer class="footer">
  <div class="container-editorial">
    <!-- Brand Tagline -->
    <div class="mb-16 max-w-lg">
      <a href="/" class="inline-flex items-baseline gap-1 font-sans text-2xl font-semibold mb-5">
        <span class="text-primary-500 font-bold text-3xl">a</span>
        <span class="text-white">lumi</span>
        <em class="font-normal text-stone-500">news</em>
      </a>
      <p class="font-serif text-xl text-stone-300 italic leading-relaxed">
        Health is wealth. We help you protect it.
      </p>
    </div>

    <!-- Columns -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12 mb-16">
      <!-- Latest -->
      <div class="col-span-2 md:col-span-1">
        <h4 class="text-[10px] font-semibold uppercase tracking-widest text-stone-500 mb-4">Latest</h4>
        <ul class="space-y-2.5">
          {latestArticles.map((article) => (
            <li>
              <a href={article.href} class="text-sm text-stone-400 hover:text-white transition-colors duration-200 leading-snug block">
                {article.title.length > 45 ? article.title.slice(0, 45) + '...' : article.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Explore -->
      <div>
        <h4 class="text-[10px] font-semibold uppercase tracking-widest text-stone-500 mb-4">Explore</h4>
        <ul class="space-y-2.5">
          <li><a href="/articles" class="text-sm text-stone-400 hover:text-white transition-colors duration-200">All Articles</a></li>
          <li><a href="/deep-dives" class="text-sm text-stone-400 hover:text-white transition-colors duration-200">Deep Dives</a></li>
          <li><a href="/about" class="text-sm text-stone-400 hover:text-white transition-colors duration-200">About</a></li>
          <li><a href="/subscribe" class="text-sm text-stone-400 hover:text-white transition-colors duration-200">Subscribe</a></li>
        </ul>
      </div>

      <!-- Topics -->
      <div>
        <h4 class="text-[10px] font-semibold uppercase tracking-widest text-stone-500 mb-4">Topics</h4>
        <ul class="space-y-2.5">
          {categories.slice(0, 6).map((cat) => (
            <li>
              <a href={`/articles?topic=${cat.toLowerCase().replace(/\s+/g, '-')}`} class="text-sm text-stone-400 hover:text-white transition-colors duration-200">
                {cat}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Quick Actions -->
      <div>
        <h4 class="text-[10px] font-semibold uppercase tracking-widest text-stone-500 mb-4">Quick</h4>
        <p class="text-xs text-stone-500 mb-3">
          Press <kbd class="px-1.5 py-0.5 bg-stone-800 border border-stone-700 rounded text-xs font-mono text-stone-400">⌘K</kbd> to search
        </p>
        <a href="/subscribe" class="inline-flex items-center gap-2 text-sm font-medium text-primary-500 hover:text-primary-400 transition-colors">
          Subscribe free
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M5 12h14M12 5l7 7-7 7" stroke-width="2"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- alumi Health promo -->
    <div class="pt-8 mt-2 border-t border-stone-800 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6 mb-12">
      <div>
        <span class="inline-flex items-baseline font-sans text-lg font-semibold mb-2">
          <span class="text-primary-500 font-bold text-xl">a</span><span class="text-white">lumi</span>
          <em class="ml-1 font-normal text-stone-400">Health</em>
        </span>
        <p class="text-sm text-stone-400 max-w-md leading-relaxed">
          AI-powered health tracking. Lab results, meal analysis, and personal experiments — all in one platform.
        </p>
        <p class="text-xs text-stone-600 mt-1">Free to start. No credit card required.</p>
      </div>
      <a
        href="https://tune-sigma.vercel.app?utm_source=alumi-news&utm_medium=footer"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-medium bg-white/10 text-white hover:bg-white/20 transition-colors whitespace-nowrap"
        aria-label="Try alumi Health free"
      >
        Start Free Trial
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path d="M7 17L17 7M17 7H7M17 7v10" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-stone-800 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
      <div class="flex items-center gap-4">
        <p class="text-xs text-stone-600">© {new Date().getFullYear()} alumi news</p>
        <span class="text-xs text-stone-700">·</span>
        <p class="text-xs text-stone-600">{articles.length} published</p>
      </div>
      <p class="text-xs text-stone-600 max-w-md md:text-right leading-relaxed">
        Content is for informational purposes only and is not a substitute
        for professional medical advice, diagnosis, or treatment.
      </p>
    </div>
  </div>
</footer>
