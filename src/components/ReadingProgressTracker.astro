---
/**
 * ReadingProgressTracker — saves scroll position to localStorage per article.
 * Include in ArticleLayout. Entirely client-side.
 */
interface Props {
  slug: string;
  title: string;
  category: string;
  readTime: number;
}

const { slug, title, category, readTime } = Astro.props;
---

<script define:vars={{ slug, title, category, readTime }}>
  (function initReadingTracker() {
    const STORAGE_KEY = 'alumi-reading-progress';
    const articleContent = document.getElementById('article-content');
    if (!articleContent) return;

    function getProgress() {
      try {
        return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
      } catch { return {}; }
    }

    function saveProgress(percent) {
      const progress = getProgress();
      progress[slug] = {
        slug,
        scrollPercent: Math.round(percent),
        lastRead: Date.now(),
        title,
        category,
        readTime,
      };
      localStorage.setItem(STORAGE_KEY, JSON.stringify(progress));
    }

    let ticking = false;
    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const rect = articleContent.getBoundingClientRect();
        const articleTop = rect.top + window.scrollY;
        const articleHeight = rect.height;
        const scrolled = window.scrollY - articleTop;
        const viewportHeight = window.innerHeight;
        const totalScrollable = articleHeight - viewportHeight;

        if (totalScrollable <= 0) {
          ticking = false;
          return;
        }

        const percent = Math.min(100, Math.max(0, (scrolled / totalScrollable) * 100));

        // Only record after 5% (skip bounces)
        if (percent >= 5) {
          saveProgress(percent >= 90 ? 100 : percent);
        }

        ticking = false;
      });
    }

    window.addEventListener('scroll', onScroll, { passive: true });
  })();
</script>
