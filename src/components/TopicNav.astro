---
import { getArticles, getCategoriesWithCounts, truncate, isNewArticle } from '../utils/articles';
import { getCategorySlug, CATEGORY_META } from '../utils/category-domains';

const categoriesWithCounts = await getCategoriesWithCounts();
const allArticles = await getArticles();
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/' || currentPath === '/index.html';

// Determine active state
const isArticlesPage = currentPath.startsWith('/articles');
const isTopicsPage = currentPath.startsWith('/topics/');
const currentTopicSlug = isTopicsPage ? currentPath.split('/').pop() : null;

// Build per-category article previews (latest 4)
const categoryPreviews = new Map<string, typeof allArticles>();
categoriesWithCounts.forEach(({ name }) => {
  categoryPreviews.set(
    name,
    allArticles.filter((a) => a.category === name).slice(0, 4)
  );
});
---

<nav class:list={['topic-nav', { 'topic-nav-hidden': isHome }]} id="topicNav" aria-label="Topics">
  <!-- Scrollable pill bar -->
  <div class="topic-nav-inner container-editorial">
    <a
      href="/articles"
      class:list={['topic-nav-link', { active: isArticlesPage && !isTopicsPage }]}
    >All</a>
    {categoriesWithCounts.map(({ name }) => {
      const slug = getCategorySlug(name);
      return (
        <a
          href={`/topics/${slug}`}
          class:list={['topic-nav-link', { active: currentTopicSlug === slug }]}
          data-topic-trigger={name}
        >{name}</a>
      );
    })}
  </div>

  <!-- Dropdown panels — rendered OUTSIDE the scrollable container to avoid overflow clipping -->
  {categoriesWithCounts.map(({ name, count }) => {
    const slug = getCategorySlug(name);
    const meta = CATEGORY_META[name];
    const previews = categoryPreviews.get(name) || [];
    return (
      <div class="topic-dropdown" data-topic-panel={name}>
        <div class="topic-dropdown-inner">
          <div class="topic-dropdown-header">
            <div>
              <h3 class="topic-dropdown-title">{name}</h3>
              {meta && <p class="topic-dropdown-tagline">{meta.tagline}</p>}
            </div>
            <span class="topic-dropdown-count">{count} articles</span>
          </div>

          {previews.length > 0 && (
            <ul class="topic-dropdown-list">
              {previews.map((article) => (
                <li>
                  <a href={article.href} class="topic-dropdown-article">
                    <span class="topic-dropdown-article-title">{truncate(article.title, 52)}</span>
                    <span class="topic-dropdown-article-meta">
                      {article.readTime} min
                      {isNewArticle(article.publishDate) && <span class="topic-dropdown-new">New</span>}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          )}

          <a href={`/topics/${slug}`} class="topic-dropdown-viewall">
            View all {name} articles
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path d="M9 5l7 7-7 7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    );
  })}
</nav>

<style>
  .topic-nav {
    @apply fixed left-0 right-0 z-[39];
    top: 3.5rem; /* h-14 default */
    @apply bg-stone-50/95 dark:bg-stone-950/95 backdrop-blur-md;
    @apply border-b border-stone-200/60 dark:border-stone-800/60;
    transition: transform 0.375s ease, border-color 0.2s ease;
  }

  @media (min-width: 768px) {
    .topic-nav {
      top: 4rem; /* md:h-16 */
    }
  }

  .topic-nav.header-hidden,
  .topic-nav.topic-nav-hidden {
    transform: translateY(-100%);
    pointer-events: none;
    visibility: hidden;
  }

  .topic-nav-inner {
    @apply flex items-center gap-1 h-10 overflow-x-auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .topic-nav-inner::-webkit-scrollbar {
    display: none;
  }

  .topic-nav-link {
    @apply flex-shrink-0 px-3 py-1 text-xs font-medium;
    @apply text-stone-500 dark:text-stone-400;
    @apply rounded-full transition-colors duration-200;
    @apply hover:text-stone-900 dark:hover:text-white;
  }

  .topic-nav-link.active {
    @apply text-stone-900 dark:text-white;
    @apply bg-stone-200/60 dark:bg-stone-800/60;
  }

  /* ─── Topic Dropdown (positioned via JS, lives outside scroll container) ─── */
  .topic-dropdown {
    @apply absolute pt-2;
    @apply opacity-0 invisible;
    top: 100%;
    left: 0;
    width: min(320px, calc(100vw - 16px));
    @apply z-50;
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
    pointer-events: none;
    transform: translateY(-4px);
  }

  .topic-dropdown.open {
    @apply opacity-100 visible;
    pointer-events: auto;
    transform: translateY(0);
  }

  .topic-dropdown-inner {
    @apply bg-white/95 dark:bg-stone-900/95 backdrop-blur-md;
    @apply border border-stone-200/50 dark:border-stone-700/50;
    @apply rounded-xl;
    @apply p-4;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.1), 0 4px 16px rgba(0, 0, 0, 0.06);
  }

  :global(.dark) .topic-dropdown-inner {
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35), 0 4px 16px rgba(0, 0, 0, 0.25);
  }

  .topic-dropdown-header {
    @apply flex items-start justify-between mb-3 pb-3;
    @apply border-b border-stone-100 dark:border-stone-800;
  }

  .topic-dropdown-title {
    @apply text-sm font-semibold text-stone-900 dark:text-white;
  }

  .topic-dropdown-tagline {
    @apply text-xs text-stone-500 dark:text-stone-400 mt-0.5;
    @apply italic;
  }

  .topic-dropdown-count {
    @apply text-[10px] font-medium text-stone-400 dark:text-stone-500;
    @apply bg-stone-100 dark:bg-stone-800 px-1.5 py-0.5 rounded;
    @apply flex-shrink-0;
  }

  .topic-dropdown-list {
    @apply space-y-0.5 mb-3;
  }

  .topic-dropdown-article {
    @apply flex items-center justify-between gap-3;
    @apply px-2 py-2 rounded-lg;
    @apply hover:bg-stone-50 dark:hover:bg-stone-800/70;
    @apply transition-colors duration-150;
    min-height: 36px;
  }

  .topic-dropdown-article-title {
    @apply text-sm text-stone-700 dark:text-stone-300;
    @apply line-clamp-1;
  }

  .topic-dropdown-article-meta {
    @apply text-[10px] text-stone-400 dark:text-stone-500 flex-shrink-0;
    @apply flex items-center gap-1.5;
  }

  .topic-dropdown-new {
    @apply px-1 py-px rounded text-[9px] font-semibold uppercase;
    @apply bg-primary-100 text-primary-700;
    @apply dark:bg-primary-900/30 dark:text-primary-400;
  }

  .topic-dropdown-viewall {
    @apply flex items-center justify-center gap-1.5;
    @apply text-xs font-medium text-primary-600 dark:text-primary-400;
    @apply hover:text-primary-700 dark:hover:text-primary-300;
    @apply py-2 rounded-lg;
    @apply bg-stone-50 dark:bg-stone-800/50;
    @apply hover:bg-primary-50 dark:hover:bg-primary-900/20;
    @apply transition-colors duration-200;
  }

  /* Hide on mobile — MobileNav handles navigation there */
  @media (pointer: coarse) and (max-width: 1023px) {
    .topic-nav {
      display: none;
    }
  }
</style>

<script>
  let topicNavController: AbortController | null = null;

  function initTopicDropdowns() {
    if (topicNavController) topicNavController.abort();
    topicNavController = new AbortController();
    const signal = topicNavController.signal;

    const nav = document.getElementById('topicNav');
    if (!nav) return;

    const triggers = nav.querySelectorAll<HTMLElement>('[data-topic-trigger]');
    const panels = nav.querySelectorAll<HTMLElement>('[data-topic-panel]');
    const panelMap = new Map<string, HTMLElement>();
    panels.forEach((p) => {
      const name = p.getAttribute('data-topic-panel');
      if (name) panelMap.set(name, p);
    });

    let activePanel: HTMLElement | null = null;
    let activeTrigger: HTMLElement | null = null;
    let closeTimeout: ReturnType<typeof setTimeout> | null = null;

    function positionPanel(trigger: HTMLElement, panel: HTMLElement) {
      const triggerRect = trigger.getBoundingClientRect();
      const navRect = nav!.getBoundingClientRect();
      const panelWidth = Math.min(320, window.innerWidth - 16);

      // Center the panel under the trigger pill
      let left = triggerRect.left - navRect.left + (triggerRect.width / 2) - (panelWidth / 2);

      // Clamp horizontally within viewport
      const maxLeft = navRect.width - panelWidth - 8;
      left = Math.max(8, Math.min(left, maxLeft));

      panel.style.left = `${left}px`;
      panel.style.width = `${panelWidth}px`;

      // Clamp vertically — ensure dropdown doesn't overflow below viewport
      const panelInner = panel.querySelector('.topic-dropdown-inner') as HTMLElement;
      if (panelInner) {
        const availableHeight = window.innerHeight - navRect.bottom - 16;
        panelInner.style.maxHeight = `${Math.max(200, availableHeight)}px`;
        panelInner.style.overflowY = 'auto';
      }
    }

    function openPanel(trigger: HTMLElement) {
      if (closeTimeout) { clearTimeout(closeTimeout); closeTimeout = null; }

      const name = trigger.getAttribute('data-topic-trigger');
      if (!name) return;
      const panel = panelMap.get(name);
      if (!panel) return;

      // Close previous
      if (activePanel && activePanel !== panel) {
        activePanel.classList.remove('open');
      }

      positionPanel(trigger, panel);
      panel.classList.add('open');
      activePanel = panel;
      activeTrigger = trigger;
    }

    function closeAll() {
      activePanel?.classList.remove('open');
      activePanel = null;
      activeTrigger = null;
    }

    function scheduleClose() {
      if (closeTimeout) clearTimeout(closeTimeout);
      closeTimeout = setTimeout(() => {
        closeAll();
      }, 200);
    }

    function cancelClose() {
      if (closeTimeout) { clearTimeout(closeTimeout); closeTimeout = null; }
    }

    // Trigger hover
    triggers.forEach((trigger) => {
      trigger.addEventListener('mouseenter', () => openPanel(trigger), { signal });
      trigger.addEventListener('mouseleave', scheduleClose, { signal });
    });

    // Panel hover — keep open while mouse is on the dropdown
    panels.forEach((panel) => {
      panel.addEventListener('mouseenter', cancelClose, { signal });
      panel.addEventListener('mouseleave', scheduleClose, { signal });

      // Close on link click (navigation)
      panel.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', closeAll, { signal });
      });
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeAll();
    }, { signal });
  }

  initTopicDropdowns();
  document.addEventListener('astro:after-swap', initTopicDropdowns);
</script>
