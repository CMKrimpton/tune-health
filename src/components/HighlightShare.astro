---
/**
 * HighlightShare — popup that appears when users select text in articles.
 * Lets them share the selected quote on X, Bluesky, copy it, or share natively.
 */
interface Props {
  articleUrl: string;
}

const { articleUrl } = Astro.props;
const siteUrl = Astro.site?.origin || 'https://tune-health.vercel.app';
const fullUrl = `${siteUrl}${articleUrl}`;
---

<div class="highlight-share" id="highlightShare" role="group" aria-label="Share selected text" data-article-url={fullUrl}>
  <button class="hs-btn" data-hs-action="twitter" aria-label="Share quote on X" title="Share on X">
    <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
    </svg>
  </button>
  <button class="hs-btn" data-hs-action="bluesky" aria-label="Share quote on Bluesky" title="Share on Bluesky">
    <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.785 2.627 3.62 3.501 6.204 3.254-3.96.582-6.71 2.483-4.058 6.77 2.953 4.327 6.227 1.726 7.23-.278.998 2.004 3.57 4.605 7.23.278 2.652-4.287-.098-6.188-4.058-6.77 2.584.247 5.42-.627 6.204-3.254.246-.83.624-5.79.624-6.479 0-.688-.139-1.86-.902-2.203-.66-.299-1.664-.621-4.3 1.24C12.04 4.747 9.087 8.686 12 10.8z"/>
    </svg>
  </button>
  <div class="hs-divider"></div>
  <button class="hs-btn" data-hs-action="copy" aria-label="Copy selected text" title="Copy quote">
    <svg class="w-3.5 h-3.5 hs-copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
      <rect x="9" y="9" width="13" height="13" rx="2" ry="2" stroke-width="1.5"/>
      <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" stroke-width="1.5"/>
    </svg>
    <svg class="w-3.5 h-3.5 hs-check-icon hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
      <path d="M5 13l4 4L19 7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
</div>

<style>
  .highlight-share {
    position: fixed;
    z-index: 50;
    display: none;
    align-items: center;
    gap: 0.125rem;
    padding: 0.375rem;
    border-radius: 12px;
    background: theme('colors.stone.900 / 95%');
    backdrop-filter: blur(12px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25), 0 0 0 1px rgba(255, 255, 255, 0.08);
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.2s ease-out, transform 0.2s ease-out;
    pointer-events: none;
  }

  .highlight-share.visible {
    display: flex;
    opacity: 1;
    transform: translateY(0);
    pointer-events: all;
  }

  .hs-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    color: theme('colors.stone.400');
    background: transparent;
    border: none;
    cursor: pointer;
    transition: color 0.2s ease-out, background-color 0.2s ease-out;
  }

  /* Expand to 44px on touch devices */
  @media (pointer: coarse) {
    .hs-btn {
      width: 44px;
      height: 44px;
    }
  }

  .hs-btn:hover {
    color: #fff;
    background: theme('colors.white / 10%');
  }

  .hs-btn[data-hs-action="twitter"]:hover { color: #fff; }
  .hs-btn[data-hs-action="bluesky"]:hover { color: #0085ff; }
  .hs-btn.copied { color: #4ade80; }

  .hs-divider {
    width: 1px;
    height: 20px;
    background: theme('colors.white / 10%');
    margin: 0 0.125rem;
  }
</style>

<script>
  let hsController: AbortController | null = null;

  function initHighlightShare() {
    if (hsController) hsController.abort();
    hsController = new AbortController();
    const signal = hsController.signal;

    const popup = document.getElementById('highlightShare');
    if (!popup) return;

    const articleContent = document.getElementById('article-content');
    if (!articleContent) return;

    let selectedText = '';
    const articleUrl = popup.dataset.articleUrl || '';

    function showPopup(x: number, y: number) {
      popup.style.left = `${Math.min(x - 60, window.innerWidth - 160)}px`;
      popup.style.top = `${Math.max(y - 50, 8)}px`;
      popup.classList.add('visible');
    }

    function hidePopup() {
      popup.classList.remove('visible');
      selectedText = '';
    }

    // Listen for text selection in article content
    document.addEventListener('selectionchange', () => {
      const selection = window.getSelection();
      if (!selection || selection.isCollapsed || !selection.toString().trim()) {
        setTimeout(() => {
          if (!popup.matches(':hover')) hidePopup();
        }, 200);
        return;
      }

      const text = selection.toString().trim();
      if (text.length < 10 || text.length > 400) {
        hidePopup();
        return;
      }

      const range = selection.getRangeAt(0);
      if (!articleContent.contains(range.commonAncestorContainer)) {
        hidePopup();
        return;
      }

      selectedText = text;
      const rect = range.getBoundingClientRect();
      showPopup(rect.left + rect.width / 2, rect.top + window.scrollY);
    }, { signal });

    // Handle clicks
    popup.querySelectorAll<HTMLButtonElement>('.hs-btn').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        e.stopPropagation();

        if (!selectedText) return;
        const quote = `"${selectedText}"`;
        const action = btn.dataset.hsAction;

        if (action === 'twitter') {
          const tweetText = quote.length > 240
            ? `"${selectedText.slice(0, 220)}..." — alumi news`
            : `${quote} — alumi news`;
          window.open(
            `https://twitter.com/intent/tweet?text=${encodeURIComponent(tweetText)}&url=${encodeURIComponent(articleUrl)}`,
            '_blank',
            'width=550,height=420'
          );
        } else if (action === 'bluesky') {
          const postText = quote.length > 260
            ? `"${selectedText.slice(0, 240)}..." ${articleUrl}`
            : `${quote} ${articleUrl}`;
          window.open(
            `https://bsky.app/intent/compose?text=${encodeURIComponent(postText)}`,
            '_blank',
            'width=550,height=420'
          );
        } else if (action === 'copy') {
          try {
            await navigator.clipboard.writeText(`${quote}\n\n${articleUrl}`);
          } catch {
            // Fallback
            const textarea = document.createElement('textarea');
            textarea.value = `${quote}\n\n${articleUrl}`;
            textarea.style.position = 'fixed';
            textarea.style.opacity = '0';
            document.body.appendChild(textarea);
            textarea.select();
            document.execCommand('copy');
            document.body.removeChild(textarea);
          }

          btn.classList.add('copied');
          const copyIcon = btn.querySelector('.hs-copy-icon') as HTMLElement;
          const checkIcon = btn.querySelector('.hs-check-icon') as HTMLElement;
          copyIcon?.classList.add('hidden');
          checkIcon?.classList.remove('hidden');

          setTimeout(() => {
            btn.classList.remove('copied');
            copyIcon?.classList.remove('hidden');
            checkIcon?.classList.add('hidden');
          }, 1500);
        }
      }, { signal });
    });

    // Hide on scroll
    let scrollTimer: ReturnType<typeof setTimeout>;
    window.addEventListener('scroll', () => {
      clearTimeout(scrollTimer);
      scrollTimer = setTimeout(hidePopup, 100);
    }, { passive: true, signal });

    // Hide on click outside
    document.addEventListener('mousedown', (e) => {
      if (!popup.contains(e.target as Node)) hidePopup();
    }, { signal });
  }

  initHighlightShare();
  document.addEventListener('astro:after-swap', initHighlightShare);
</script>
