---
/**
 * MenuDropdownContent — shared menu content used by both Header variants.
 * Grouped by editorial domain with article counts per category.
 */
import { getArticles, getCategoriesWithCounts, truncate } from '../utils/articles';
import { CATEGORY_DOMAINS, getCategorySlug } from '../utils/category-domains';
import type { Article } from '../utils/articles';

interface Props {
  currentPath: string;
  showLatest?: boolean;
}

const { currentPath, showLatest = false } = Astro.props;

const categoriesWithCounts = await getCategoriesWithCounts();
const countMap = new Map(categoriesWithCounts.map(c => [c.name, c.count]));
const latestArticles: Article[] = showLatest ? (await getArticles()).slice(0, 3) : [];
---

<div class="menu-dropdown-inner">
  <!-- Sections -->
  <div class="menu-section">
    <span class="menu-section-label">Sections</span>
    <div class="menu-grid">
      <a href="/" class:list={["menu-item", { active: currentPath === '/' }]}>
        <span class="menu-item-icon">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" stroke-width="1.5"/>
          </svg>
        </span>
        <span class="menu-item-text">Home</span>
      </a>
      <a href="/articles" class:list={["menu-item", { active: currentPath.startsWith('/articles') }]}>
        <span class="menu-item-icon">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" stroke-width="1.5"/>
          </svg>
        </span>
        <span class="menu-item-text">Articles</span>
      </a>
      <a href="/deep-dives" class:list={["menu-item", { active: currentPath === '/deep-dives' }]}>
        <span class="menu-item-icon">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" stroke-width="1.5"/>
          </svg>
        </span>
        <span class="menu-item-text">Deep Dives</span>
      </a>
      <a href="/start-here" class:list={["menu-item", { active: currentPath === '/start-here' }]}>
        <span class="menu-item-icon">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <span class="menu-item-text">Start Here</span>
      </a>
      <a href="/collections" class:list={["menu-item", { active: currentPath.startsWith('/collections') }]}>
        <span class="menu-item-icon">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" stroke-width="1.5"/>
          </svg>
        </span>
        <span class="menu-item-text">Collections</span>
      </a>
      <a href="/subscribe" class:list={["menu-item", { active: currentPath === '/subscribe' }]}>
        <span class="menu-item-icon">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" stroke-width="1.5"/>
          </svg>
        </span>
        <span class="menu-item-text">Subscribe</span>
      </a>
    </div>
  </div>

  <!-- Topics — grouped by domain -->
  <div class="menu-section">
    <span class="menu-section-label">Topics</span>
    <div class="menu-domains">
      {CATEGORY_DOMAINS.map((domain) => (
        <div class="menu-domain">
          <div class="menu-domain-header">
            <svg class="w-4 h-4 text-stone-400 dark:text-stone-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d={domain.iconPath} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="menu-domain-label">{domain.label}</span>
          </div>
          <ul class="menu-domain-categories">
            {domain.categories.map((cat) => {
              const count = countMap.get(cat) || 0;
              if (count === 0) return null;
              return (
                <li>
                  <a href={`/topics/${getCategorySlug(cat)}`} class="menu-category-link">
                    <span>{cat}</span>
                    <span class="menu-category-count">{count}</span>
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <!-- Latest Articles (only on home variant) -->
  {showLatest && latestArticles.length > 0 && (
    <div class="menu-section">
      <span class="menu-section-label">Latest</span>
      <div class="menu-featured">
        {latestArticles.map((article) => (
          <a href={article.href} class="menu-featured-item">
            <div class="menu-featured-badge">New</div>
            <div>
              <span class="menu-featured-title">{truncate(article.title, 35)}</span>
              <span class="menu-featured-meta">{article.category} · {article.readTime} min</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Footer -->
  <div class="menu-footer">
    <span class="text-xs text-stone-400">Press ⌘K to search</span>
  </div>
</div>

<style>
  /* Glass Dropdown Inner */
  .menu-dropdown-inner {
    @apply bg-white/95 dark:bg-stone-900/95 backdrop-blur-md;
    @apply border border-stone-200/50 dark:border-stone-700/50;
    @apply rounded-2xl;
    @apply p-8;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.12), 0 8px 24px rgba(0, 0, 0, 0.08), 0 0 1px rgba(0, 0, 0, 0.1);
  }

  :global(.dark) .menu-dropdown-inner {
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4), 0 8px 24px rgba(0, 0, 0, 0.3), 0 0 1px rgba(255, 255, 255, 0.05);
  }

  /* Menu Sections */
  .menu-section {
    @apply mb-8 last:mb-0;
  }

  .menu-section-label {
    @apply block text-[10px] font-semibold uppercase tracking-widest;
    @apply text-stone-400 dark:text-stone-400 mb-3;
  }

  /* Menu Grid — 6 items: 2x3 on mobile, 3x2 on tablet, 6x1 on desktop */
  .menu-grid {
    @apply grid grid-cols-2 sm:grid-cols-3 gap-2;
  }

  .menu-item {
    @apply flex items-center gap-3;
    @apply px-4 py-3.5 rounded-xl;
    @apply bg-stone-50 dark:bg-stone-800/50;
    @apply hover:bg-stone-100 dark:hover:bg-stone-800;
    @apply transition-colors duration-200;
  }

  .menu-item-icon {
    @apply w-9 h-9 rounded-lg;
    @apply bg-white dark:bg-stone-700;
    @apply flex items-center justify-center;
    @apply text-stone-500 dark:text-stone-400;
    @apply flex-shrink-0;
  }

  .menu-item-text {
    @apply text-sm font-medium text-stone-700 dark:text-stone-200;
  }

  .menu-item.active {
    @apply bg-primary-50 dark:bg-primary-900/20;
    @apply ring-1 ring-primary-200 dark:ring-primary-800/50;
  }

  .menu-item.active .menu-item-icon {
    @apply bg-primary-100 dark:bg-primary-900/40 text-primary-600 dark:text-primary-400;
  }

  .menu-item.active .menu-item-text {
    @apply text-primary-700 dark:text-primary-300;
  }

  /* Domain-grouped Topics */
  .menu-domains {
    @apply grid grid-cols-2 lg:grid-cols-4 gap-6;
  }

  .menu-domain-header {
    @apply flex items-center gap-2 mb-2 pb-2;
    @apply border-b border-stone-100 dark:border-stone-800;
  }

  .menu-domain-label {
    @apply text-xs font-semibold uppercase tracking-wide;
    @apply text-stone-500 dark:text-stone-400;
  }

  .menu-domain-categories {
    @apply space-y-0.5;
  }

  .menu-category-link {
    @apply flex items-center justify-between;
    @apply px-2 py-2 rounded-lg;
    @apply text-sm text-stone-600 dark:text-stone-300;
    @apply hover:bg-stone-100 dark:hover:bg-stone-800;
    @apply hover:text-primary-600 dark:hover:text-primary-400;
    @apply transition-colors duration-200;
    min-height: 36px;
  }

  .menu-category-count {
    @apply text-[10px] font-medium text-stone-400 dark:text-stone-500;
    @apply bg-stone-100 dark:bg-stone-800 px-1.5 py-0.5 rounded;
  }

  /* Featured */
  .menu-featured {
    @apply space-y-2;
  }

  .menu-featured-item {
    @apply flex items-center gap-4;
    @apply p-4 rounded-xl;
    @apply bg-gradient-to-r from-stone-50 to-transparent;
    @apply dark:from-stone-800/50 dark:to-transparent;
    @apply hover:from-primary-50 dark:hover:from-primary-900/20;
    @apply transition-colors duration-200;
  }

  .menu-featured-badge {
    @apply px-2 py-0.5 rounded text-[10px] font-semibold uppercase;
    @apply bg-primary-100 text-primary-700;
    @apply dark:bg-primary-900/30 dark:text-primary-400;
  }

  .menu-featured-title {
    @apply block text-sm font-medium text-stone-700 dark:text-stone-200;
  }

  .menu-featured-meta {
    @apply block text-xs text-stone-400;
  }

  /* Footer */
  .menu-footer {
    @apply pt-6 mt-6 border-t border-stone-200 dark:border-stone-700;
    @apply text-center;
  }
</style>
