---
/**
 * SeriesNav — prev/next navigation for articles that belong to a series.
 * Shows "Part X of Y" indicator + links to adjacent parts.
 */
import { getSeriesArticles } from '../utils/articles';

interface Props {
  series: string;
  currentSlug: string;
}

const { series, currentSlug } = Astro.props;

const seriesArticles = await getSeriesArticles(series);
const currentIndex = seriesArticles.findIndex((a) => a.slug === currentSlug);
const prevArticle = currentIndex > 0 ? seriesArticles[currentIndex - 1] : null;
const nextArticle = currentIndex < seriesArticles.length - 1 ? seriesArticles[currentIndex + 1] : null;
const partNumber = currentIndex + 1;
const totalParts = seriesArticles.length;
---

{seriesArticles.length > 1 && (
  <nav class="series-nav reveal" aria-label="Series navigation">
    <div class="series-nav-header">
      <a href="/deep-dives" class="series-nav-label">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" stroke-width="1.5"/>
        </svg>
        <span>{series}</span>
      </a>
      <span class="series-nav-count">Part {partNumber} of {totalParts}</span>
    </div>

    <div class="series-nav-progress">
      {seriesArticles.map((article, i) => (
        <a
          href={article.href}
          class:list={[
            'series-nav-dot',
            { 'active': article.slug === currentSlug },
            { 'completed': i < currentIndex },
          ]}
          title={`Part ${i + 1}: ${article.title}`}
          aria-label={`Part ${i + 1}: ${article.title}`}
        />
      ))}
    </div>

    <div class="series-nav-links">
      {prevArticle ? (
        <a href={prevArticle.href} class="series-nav-link">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M19 12H5M12 19l-7-7 7-7" stroke-width="2"/>
          </svg>
          <div class="min-w-0">
            <span class="series-nav-link-label">Previous</span>
            <span class="series-nav-link-title">{prevArticle.title}</span>
          </div>
        </a>
      ) : <span />}

      {nextArticle ? (
        <a href={nextArticle.href} class="series-nav-link text-right">
          <div class="min-w-0">
            <span class="series-nav-link-label">Next</span>
            <span class="series-nav-link-title">{nextArticle.title}</span>
          </div>
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7" stroke-width="2"/>
          </svg>
        </a>
      ) : <span />}
    </div>
  </nav>
)}

<style>
  .series-nav {
    @apply mt-12 p-6 md:p-8 rounded-2xl;
    @apply bg-stone-50 dark:bg-stone-900/60;
    @apply border border-stone-200 dark:border-stone-800;
  }

  .series-nav-header {
    @apply flex items-center justify-between mb-4;
  }

  .series-nav-label {
    @apply inline-flex items-center gap-2;
    @apply text-xs font-semibold uppercase tracking-widest;
    @apply text-primary-600 dark:text-primary-400;
    @apply hover:text-primary-700 dark:hover:text-primary-300 transition-colors duration-200;
  }

  .series-nav-count {
    @apply text-xs font-medium text-stone-400 dark:text-stone-400;
  }

  .series-nav-progress {
    @apply flex items-center gap-2 mb-6;
  }

  .series-nav-dot {
    @apply flex-1 h-2 rounded-full;
    @apply bg-stone-200 dark:bg-stone-700;
    transition: background-color 0.3s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }

  .series-nav-dot.active {
    @apply bg-primary-600 dark:bg-primary-500;
  }

  .series-nav-dot.completed {
    @apply bg-primary-300 dark:bg-primary-700;
  }

  .series-nav-dot:hover {
    @apply bg-primary-400 dark:bg-primary-600;
    transform: scaleY(1.3);
  }

  .series-nav-dot:focus-visible {
    outline: 2px solid theme('colors.primary.500');
    outline-offset: 2px;
  }

  .series-nav-links {
    @apply grid grid-cols-2 gap-4;
  }

  .series-nav-link {
    @apply flex items-center gap-3 p-3 rounded-xl;
    @apply text-stone-600 dark:text-stone-400;
    @apply hover:bg-stone-100 dark:hover:bg-stone-800;
    @apply transition-colors duration-200;
  }

  .series-nav-link-label {
    @apply block text-[10px] font-semibold uppercase tracking-widest text-stone-400 dark:text-stone-400;
  }

  .series-nav-link-title {
    @apply block text-sm font-medium text-stone-700 dark:text-stone-300 line-clamp-1;
  }
</style>
