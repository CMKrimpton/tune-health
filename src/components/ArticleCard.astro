---
/**
 * ArticleCard - Reusable article preview card with View Transitions support
 * Supports different sizes, "coming soon" state, and discovery badges
 */
import { isNewArticle } from '../utils/articles';

interface Props {
  title: string;
  description: string;
  category: string;
  href: string;
  gradient?: { from: string; to: string };
  readTime?: string;
  comingSoon?: boolean;
  size?: 'default' | 'featured';
  class?: string;
  delay?: number;
  heroImage?: string;
  heroImageLight?: string;
  heroImageAlt?: string;
  publishDate?: string;
  narrationUrl?: string;
  series?: string;
  seriesOrder?: number;
  seriesTotal?: number;
}

const {
  title,
  description,
  category,
  href,
  gradient = { from: 'primary-500', to: 'primary-600' },
  readTime,
  comingSoon = false,
  size = 'default',
  class: className = '',
  delay = 0,
  heroImage,
  heroImageLight,
  heroImageAlt,
  publishDate,
  narrationUrl,
  series,
  seriesOrder,
  seriesTotal,
} = Astro.props;

const isFeatured = size === 'featured';
const isNew = publishDate ? isNewArticle(publishDate) : false;
const hasNarration = !!narrationUrl;
const isInSeries = !!series && seriesOrder != null && seriesTotal != null;

// Build gradient class
const gradientClass = `from-${gradient.from} to-${gradient.to}`;

// Build delay class for reveal animations
const delayClass = delay > 0 ? `reveal-delay-${delay}` : '';

// Generate a unique transition name based on the href
const slug = href.split('/').pop() || 'article';
---

{comingSoon ? (
  <div class:list={['article-card group reveal', delayClass, 'opacity-75 cursor-default', className]}>
    <div class="article-card-image relative">
      <div class:list={['article-card-image-inner hero-img-wrap relative overflow-hidden', heroImage ? '' : `bg-gradient-to-br ${gradientClass}`]}>
        {heroImage ? (
          <img src={heroImage} alt={heroImageAlt || title} class="w-full h-full object-cover grayscale-[30%]" loading="lazy" />
        ) : null}
      </div>
      <span class="absolute top-3 right-3 px-2 py-1 bg-stone-900/80 text-white text-xs font-medium rounded">
        Coming Soon
      </span>
    </div>
    <div class="article-card-content">
      <div class="flex items-center gap-3 mb-3">
        <span class="text-xs font-semibold uppercase tracking-wide text-primary-600">{category}</span>
      </div>
      <h3 class="font-serif text-xl font-semibold mb-2">{title}</h3>
      <p class="font-body text-base text-stone-600 dark:text-stone-400 line-clamp-2">{description}</p>
    </div>
  </div>
) : (
  <a href={href} class:list={['article-card group reveal', delayClass, className]}>
    <div class="article-card-image" transition:name={`card-image-${slug}`}>
      <div class:list={['article-card-image-inner hero-img-wrap relative overflow-hidden', heroImage ? '' : `bg-gradient-to-br ${gradientClass}`]}>
        {heroImage && heroImageLight ? (
          <>
            <img src={heroImage} alt={heroImageAlt || title} class="w-full h-full object-cover hidden dark:block" loading="lazy" />
            <img src={heroImageLight} alt={heroImageAlt || title} class="w-full h-full object-cover dark:hidden" loading="lazy" />
          </>
        ) : heroImage ? (
          <img src={heroImage} alt={heroImageAlt || title} class="w-full h-full object-cover" loading="lazy" />
        ) : null}
      </div>
      {/* Discovery badges — top-left stack */}
      <div class="absolute top-3 left-3 flex flex-col gap-1.5">
        {isNew && (
          <span class="card-badge card-badge-new">New</span>
        )}
        {isInSeries && (
          <span class="card-badge card-badge-series">Part {seriesOrder} of {seriesTotal}</span>
        )}
      </div>
      {/* Narration badge — top-right */}
      {hasNarration && (
        <span class="absolute top-3 right-3 card-badge card-badge-narration" title="Audio narration available">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M15.536 8.464a5 5 0 010 7.072M18.364 5.636a9 9 0 010 12.728M12 12h.01M11 7.5V4a1 1 0 00-1.707-.707L5.586 7H4a1 1 0 00-1 1v8a1 1 0 001 1h1.586l3.707 3.707A1 1 0 0011 20v-3.5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      )}
    </div>
    <div class="article-card-content">
      <div class="flex items-center gap-3 mb-3">
        <span class="text-xs font-semibold uppercase tracking-wide text-primary-600">{category}</span>
        {readTime && (
          <>
            <span class="text-stone-400">·</span>
            <span class="text-xs text-stone-500">{readTime}</span>
          </>
        )}
      </div>
      <h3
        class="font-serif text-xl font-semibold mb-2 group-hover:text-primary-600 transition-colors duration-200"
        transition:name={`card-title-${slug}`}
      >
        {title}
      </h3>
      <p class="font-body text-base text-stone-600 dark:text-stone-400 line-clamp-2">{description}</p>
    </div>
  </a>
)}
